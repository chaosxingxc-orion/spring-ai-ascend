package com.huawei.ascend.runtime.engine.alpha.gepa3;

import java.util.Map;
import java.util.Objects;
import java.util.UUID;

/**
 * Federal twin protocol: PEV (2.0 BSP) handoff to ReActAgent (1.0 loop) and back.
 *
 * <h3>Design rationale</h3>
 * <p>The two engines share zero implementation code. They communicate through
 * sealed message types — a typed protocol layer that is the <b>sole</b> coupling
 * surface. Each side can evolve independently as long as it respects the contract.
 *
 * <h3>Protocol guarantees</h3>
 * <ul>
 *   <li><b>Sealed message types</b> — every message is a record. Switch expressions
 *       are compile-time exhaustive; deleting a variant breaks the build.</li>
 *   <li><b>Correlation ID</b> — every handoff carries a unique ID so the response
 *       can be matched to the request even when multiple handoffs are in-flight.</li>
 *   <li><b>BlockingQueue channel</b> — the simplest possible transport: no
 *       dependency on any message broker, event bus, or RPC framework.</li>
 *   <li><b>Independent evolution proof</b> — each side can add new message types
 *       without breaking existing ones; sealed hierarchies guarantee the switch
 *       sites are updated.</li>
 * </ul>
 *
 * <h3>Analogy</h3>
 * <p>This is the TCP handshake between two OS kernels: shared wire protocol,
 * independent network stacks. The protocol is the only shared code.
 *
 * <p>See CODE READING REPORT sections 4-6 for the architectural argument this
 * prototype validates.
 *
 * @author P3 federal-twin spike (2026-07-01)
 */
public final class PevReActProtocol {

    private PevReActProtocol() { /* protocol namespace, not instantiable */ }

    // ── Message direction: PEV → ReActAgent ──────────────────────────

    /** Messages sent from the PEV (2.0 BSP) engine to the ReActAgent (1.0 loop) engine. */
    public sealed interface PevToReAct
            permits PevToReAct.ExecuteSubTask,
                   PevToReAct.CancelSubTask,
                   PevToReAct.QueryContext {

        /** PEV delegates a sub-task to ReActAgent. */
        record ExecuteSubTask(
                String taskId,
                String goal,
                String context,
                Map<String, Object> inputs) implements PevToReAct {
            public ExecuteSubTask {
                Objects.requireNonNull(taskId, "taskId");
                Objects.requireNonNull(goal, "goal");
                Objects.requireNonNull(inputs, "inputs");
            }

            /** Factory: handoff a single tool-call-shaped task. */
            public static ExecuteSubTask of(
                    String taskId, String goal, String context, Map<String, Object> inputs) {
                return new ExecuteSubTask(taskId, goal, context, inputs);
            }
        }

        /** PEV cancels a previously-dispatched sub-task. */
        record CancelSubTask(String taskId) implements PevToReAct {
            public CancelSubTask {
                Objects.requireNonNull(taskId, "taskId");
            }
        }

        /** PEV queries ReActAgent's context (KnowledgeBridge path). */
        record QueryContext(String taskId, String question) implements PevToReAct {
            public QueryContext {
                Objects.requireNonNull(taskId, "taskId");
                Objects.requireNonNull(question, "question");
            }
        }
    }

    // ── Message direction: ReActAgent → PEV ──────────────────────────

    /** Messages sent from the ReActAgent (1.0 loop) engine back to the PEV (2.0 BSP) engine. */
    public sealed interface ReActToPev
            permits ReActToPev.SubTaskCompleted,
                   ReActToPev.SubTaskDegraded,
                   ReActToPev.SubTaskReplanRequested,
                   ReActToPev.ContextResponse {

        /** ReActAgent completed the sub-task successfully. */
        record SubTaskCompleted(
                String taskId,
                Object result,
                String reasoningTrace) implements ReActToPev {
            public SubTaskCompleted {
                Objects.requireNonNull(taskId, "taskId");
                Objects.requireNonNull(result, "result");
            }

            /** Factory with reasoning. */
            public static SubTaskCompleted of(
                    String taskId, Object result, String reasoning) {
                return new SubTaskCompleted(taskId, result, reasoning);
            }
        }

        /**
         * ReActAgent degraded: tool failed irrecoverably (DeviceFailure / PerceptionUnreliable).
         * PEV's AlphaStrategy.executeVerifyLoop receives this and maps to AcceptPartial.
         */
        record SubTaskDegraded(
                String taskId,
                String degradedOutput,
                String cause) implements ReActToPev {
            public SubTaskDegraded {
                Objects.requireNonNull(taskId, "taskId");
                Objects.requireNonNull(cause, "cause");
            }
        }

        /**
         * ReActAgent detected content error (PlanOrAnswerError) and requests PEV replan.
         * PEV can decide: LocalReplan, GlobalReplan, or downgrade to AcceptPartial.
         */
        record SubTaskReplanRequested(
                String taskId,
                String reason) implements ReActToPev {
            public SubTaskReplanRequested {
                Objects.requireNonNull(taskId, "taskId");
                Objects.requireNonNull(reason, "reason");
            }
        }

        /** ReActAgent responds to a QueryContext. */
        record ContextResponse(
                String taskId,
                Map<String, Object> facts) implements ReActToPev {
            public ContextResponse {
                Objects.requireNonNull(taskId, "taskId");
                Objects.requireNonNull(facts, "facts");
            }
        }
    }

    // ── Shared envelope ──────────────────────────────────────────────

    /**
     * A handoff envelope carrying a correlation ID so the response can be matched
     * to the request when multiple handoffs are in-flight on the same channel.
     */
    public record Handoff(
            String correlationId,
            PevToReAct request) {
        public Handoff {
            Objects.requireNonNull(correlationId, "correlationId");
            Objects.requireNonNull(request, "request");
        }

        public static Handoff of(PevToReAct request) {
            return new Handoff(UUID.randomUUID().toString(), request);
        }
    }

    /** The response envelope, carrying the same correlation ID. */
    public record Response(
            String correlationId,
            ReActToPev message) {
        public Response {
            Objects.requireNonNull(correlationId, "correlationId");
            Objects.requireNonNull(message, "message");
        }

        /** Factory that copies correlation ID from the handoff. */
        public static Response to(Handoff handoff, ReActToPev message) {
            return new Response(handoff.correlationId(), message);
        }
    }
}
