package com.huawei.ascend.runtime.engine.alpha.gepa3;

import java.util.*;

/**
 * <h1>P8 minimal kernel: tool-failure to degrade in under 200 lines of java.base</h1>
 *
 * <p>Replaces SingleNodePregelDemo (295+226=521 lines, 7 openjiuwen deps, Reactor Mono)
 * with a self-contained class that exercises E1-E4 using zero frameworks.</p>
 *
 * <h2>What this proves</h2>
 * <ul>
 *   <li>E1 (tool exception) → {@code ToolResult.fail()} → {@code "FAILED:"} prefix</li>
 *   <li>E2 (verifier perception) → rule check on {@code "FAILED:"}, zero LLM wasted</li>
 *   <li>E3 (diagnose) → pure set-intersection → {@code DeviceFailure}</li>
 *   <li>E4 (dispatch) → sealed switch → {@code Degrade}</li>
 *   <li>Green path: tool succeeds, verify fails on content → {@code PlanOrAnswerError} → {@code Replan}</li>
 * </ul>
 *
 * <h2>Key simplifications vs SingleNodePregelDemo</h2>
 * <ul>
 *   <li>Sealed types self-contained — no openjiuwen-core dependency</li>
 *   <li>Single ToolExecutor functional interface — no MockToolProvider, no kernel</li>
 *   <li>Verifier short-circuits on {@code "FAILED:"} — no wasted LLM call</li>
 *   <li>diagnoseRootCause recognizes that tool-failed and verify-failed collapse to same signal
 *       in the production RootCauseRail — no vestigial intersection when sets are identical</li>
 *   <li>No System.out.println — assertions are the output</li>
 *   <li>No DemoResult record — each test is self-contained</li>
 * </ul>
 */
public final class MinimalToolFailureDemo {

    private MinimalToolFailureDemo() {}

    // ========================================================================
    // Sealed types (self-contained, no openjiuwen dependency)
    // ========================================================================

    public sealed interface RootCause
            permits RootCause.DeviceFailure, RootCause.PlanOrAnswerError,
                   RootCause.PerceptionUnreliable {

        record DeviceFailure(Set<String> nodes) implements RootCause {
            public DeviceFailure { nodes = Set.copyOf(nodes); }
        }

        record PlanOrAnswerError(Set<String> nodes) implements RootCause {
            public PlanOrAnswerError { nodes = Set.copyOf(nodes); }
        }

        record PerceptionUnreliable(boolean verifierThrew) implements RootCause {}
    }

    public sealed interface SelfHealAction
            permits SelfHealAction.Degrade, SelfHealAction.Replan {

        record Degrade(String reason) implements SelfHealAction {}

        record Replan(String reason, Set<String> failedNodes, String correctionHint)
                implements SelfHealAction {}
    }

    // ========================================================================
    // ToolResult — minimal equivalent of openjiuwen ToolResult
    // ========================================================================

    public record ToolResult(String toolName, boolean success, String output, String error) {
        public static ToolResult ok(String toolName, String output) {
            return new ToolResult(toolName, true, output, null);
        }

        public static ToolResult fail(String toolName, String error) {
            return new ToolResult(toolName, false, null, error);
        }
    }

    // ========================================================================
    // SPI — single-method interfaces
    // ========================================================================

    @FunctionalInterface
    public interface ToolExecutor {
        /** Execute a tool. Throw on failure; the engine catches and wraps. */
        String execute(String toolName, Map<String, String> args);
    }

    // ========================================================================
    // Engine: executeToolNode + verify + diagnose + dispatch
    // ========================================================================

    /**
     * Execute a single tool node, modeling the two-level propagation:
     * Level 1: toolExecutor throws → caught → ToolResult.fail()
     * Level 2: !success → wrap RuntimeException with context
     * Level 3: catch → "FAILED:" prefix
     *
     * @return the result string (either tool output or "FAILED: ...")
     */
    public static String executeToolNode(String nodeId, String toolName,
                                         Map<String, String> args,
                                         ToolExecutor tools,
                                         Set<String> toolFailedOut) {
        // Level 1: execute, catch tool exceptions → ToolResult.fail()
        ToolResult tr;
        try {
            String output = tools.execute(toolName, args);
            tr = ToolResult.ok(toolName, output);
        } catch (Exception e) {
            tr = ToolResult.fail(toolName, e.getMessage() != null ? e.getMessage()
                    : e.getClass().getSimpleName());
        }

        // Level 2: check success → wrap as RuntimeException
        if (!tr.success()) {
            toolFailedOut.add(nodeId);
            // Level 3: "FAILED:" prefix (mirrors DefaultPregelExecutor:200)
            return "FAILED: " + tr.error();
        }
        return tr.output();
    }

    /**
     * Rule-based verify — zero LLM calls.
     * Checks "FAILED:" prefix deterministically.
     */
    public static Set<String> ruleVerify(Map<String, String> nodeResults) {
        Set<String> failed = new LinkedHashSet<>();
        for (var entry : nodeResults.entrySet()) {
            if (entry.getValue().startsWith("FAILED:")) {
                failed.add(entry.getKey());
            }
        }
        return failed;
    }

    /**
     * Diagnose root cause from tool-failed and verify-failed signals.
     *
     * Priority (same as RootCauseDiagnoser):
     * 1. verifyThrew → PerceptionUnreliable (verifier untrustworthy)
     * 2. tool-failed ∩ verify-failed non-empty → DeviceFailure
     *    NOTE: in RootCauseRail.onToolException, both sets come from the
     *    same extractToolName() call — intersection is degenerate (always 100%).
     *    The intersection logic only adds value when signals are independently
     *    sourced (executor tracks exceptions, verifier tracks content).
     * 3. Otherwise → PlanOrAnswerError
     */
    public static RootCause diagnoseRootCause(boolean verifyThrew,
                                              Set<String> toolFailed,
                                              Set<String> verifyFailed) {
        if (verifyThrew) {
            return new RootCause.PerceptionUnreliable(true);
        }
        // Intersection: tool-failed ∩ verify-failed
        Set<String> tf = toolFailed != null ? toolFailed : Set.of();
        Set<String> vf = verifyFailed != null ? verifyFailed : Set.of();
        Set<String> hit = new LinkedHashSet<>(tf);
        hit.retainAll(vf);
        if (!hit.isEmpty()) {
            return new RootCause.DeviceFailure(hit);
        }
        return new RootCause.PlanOrAnswerError(vf);
    }

    /**
     * Dispatch RootCause → SelfHealAction. Sealed switch — compiler-red on miss.
     */
    public static SelfHealAction dispatch(RootCause cause) {
        return switch (cause) {
            case RootCause.DeviceFailure df -> new SelfHealAction.Degrade(
                    "设备故障（工具失败: " + df.nodes() + "），replan 无效 → 降级");
            case RootCause.PerceptionUnreliable pu -> new SelfHealAction.Degrade(
                    "感知出错（verifier " + (pu.verifierThrew() ? "抛异常" : "返回null")
                            + "），别盲信 FAILED → 降级放行");
            case RootCause.PlanOrAnswerError pe -> {
                String hint = "地面真值反馈：上次验证失败节点 " + pe.nodes()
                        + "，请根据以下反馈修正：内容质量不达标";
                yield new SelfHealAction.Replan(
                        "图-答案出错（失败节点: " + pe.nodes() + "），replan 救得了",
                        pe.nodes(), hint);
            }
        };
    }

    // ========================================================================
    // E1-E4 end-to-end in under 30 lines
    // ========================================================================

    /**
     * Run E1-E4 for a failing tool. Returns the SelfHealAction.
     *
     * <pre>
     * E1: tool throws → "FAILED: ..."
     * E2: ruleVerify detects "FAILED:" prefix
     * E3: diagnoseRootCause(toolFailed ∩ verifyFailed) → DeviceFailure
     * E4: dispatch(DeviceFailure) → Degrade
     * </pre>
     */
    public static SelfHealAction runToolFailurePath(
            String nodeId, String toolName, ToolExecutor tools) {
        // E1: execute tool node
        Set<String> toolFailed = new LinkedHashSet<>();
        Map<String, String> results = new LinkedHashMap<>();
        String result = executeToolNode(nodeId, toolName, Map.of(), tools, toolFailed);
        results.put(nodeId, result);

        // E2: rule verify
        Set<String> verifyFailed = ruleVerify(results);

        // E3: diagnose
        RootCause cause = diagnoseRootCause(false, toolFailed, verifyFailed);

        // E4: dispatch
        return dispatch(cause);
    }

    /**
     * Run E1-E4 for a succeeding tool that fails content verification.
     * Demonstrates the PlanOrAnswerError → Replan path.
     */
    public static SelfHealAction runContentFailurePath(
            String nodeId, String toolName, ToolExecutor tools) {
        // E1: execute tool node (succeeds)
        Set<String> toolFailed = new LinkedHashSet<>();
        Map<String, String> results = new LinkedHashMap<>();
        String result = executeToolNode(nodeId, toolName, Map.of(), tools, toolFailed);
        results.put(nodeId, result);

        // E2: simulated content verification failure (tool succeeded but content wrong)
        //     In production, this comes from LLM-as-judge verify
        Set<String> verifyFailed = Set.of(nodeId);

        // E3: diagnose — toolFailed is empty, verifyFailed is {nodeId} → PlanOrAnswerError
        RootCause cause = diagnoseRootCause(false, toolFailed, verifyFailed);

        // E4: dispatch
        return dispatch(cause);
    }

    // ========================================================================
    // Convenience ToolExecutors for testing
    // ========================================================================

    public static ToolExecutor throwingTool(String errorMessage) {
        return (name, args) -> { throw new RuntimeException(errorMessage); };
    }

    public static ToolExecutor succeedingTool(String output) {
        return (name, args) -> output;
    }
}
