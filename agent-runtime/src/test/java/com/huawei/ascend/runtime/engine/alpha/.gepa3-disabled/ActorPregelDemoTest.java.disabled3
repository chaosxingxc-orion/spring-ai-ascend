package com.huawei.ascend.runtime.engine.alpha.gepa3;

import com.openjiuwen.core.alpha.verifier.RootCause;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;

import java.util.Set;
import java.util.concurrent.BlockingQueue;
import java.util.concurrent.LinkedBlockingQueue;
import java.util.concurrent.TimeUnit;

import static org.assertj.core.api.Assertions.assertThat;

/**
 * ActorPregelDemo tests -- evolved: added E1/E2/E4 scenario tests,
 * BSP boundary test, inbox multiplexing safety, and sealed exhaustiveness.
 */
@DisplayName("ActorPregelDemo - Actor model prototype tests (evolved)")
class ActorPregelDemoTest {

    @Nested
    @DisplayName("E1 Success path")
    class E1Success {

        @Test
        @DisplayName("all tools pass + verify passes -> COMPLETED (not degraded)")
        void allToolsPassAndVerifyPassesShouldReturnCompletedNotDegraded() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor = ActorPregelDemo.runE1Demonstration();
            assertThat(supervisor.finalOutput).isNotNull().startsWith("COMPLETED:").contains("all nodes passed");
            assertThat(supervisor.degraded).isFalse();
            assertThat(supervisor.phase.name()).isEqualTo("DONE");
        }

        @Test
        @DisplayName("E1 success result contains all three nodes")
        void successResultContainsAllThreeNodes() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor = ActorPregelDemo.runE1Demonstration();
            assertThat(supervisor.finalOutput).contains("claim_info").contains("verify_policy").contains("calculate_payout");
        }

        @Test
        @DisplayName("E1 TerminalRecord is safe immutable publication (Bug 9 fix)")
        void terminalRecordIsSafeImmutablePublication() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor = ActorPregelDemo.runE1Demonstration();
            ActorPregelDemo.TerminalRecord t = supervisor.terminal;
            assertThat(t).isNotNull();
            assertThat(t.output()).isEqualTo(supervisor.finalOutput);
            assertThat(t.degraded()).isFalse();
            assertThat(t.phase()).isEqualTo("DONE");
        }
    }

    @Nested
    @DisplayName("E2 Content error")
    class E2ContentError {

        @Test
        @DisplayName("tools OK but content verify fails -> PlanOrAnswerError -> replan -> degraded")
        void contentErrorShouldTriggerReplanThenDegrade() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor = ActorPregelDemo.runE2Demonstration();
            assertThat(supervisor.finalOutput).isNotNull().contains("COMPLETED-degraded").contains("retries exhausted");
            assertThat(supervisor.degraded).isTrue();
        }

        @Test
        @DisplayName("ContentVerifier distinguishes E2 from E3 -- empty intersection = content error")
        void contentVerifierDistinguishesE2FromE3() {
            RootCause cause = ActorPregelDemo.VerifyActor.diagnoseRootCause(
                    Set.of("calculate_payout"), false, Set.of(), Set.of());
            assertThat(cause).isInstanceOf(RootCause.PlanOrAnswerError.class);
            assertThat(((RootCause.PlanOrAnswerError) cause).nodes()).contains("calculate_payout");
        }

        @Test
        @DisplayName("E2 and E3 distinguished by intersection pattern")
        void e2AndE3DistinguishedByIntersectionPattern() {
            RootCause e3cause = ActorPregelDemo.VerifyActor.diagnoseRootCause(
                    Set.of("verify_policy"), false, Set.of("verify_policy"), Set.of());
            assertThat(e3cause).isInstanceOf(RootCause.DeviceFailure.class);
            RootCause e2cause = ActorPregelDemo.VerifyActor.diagnoseRootCause(
                    Set.of("calculate_payout"), false, Set.of("verify_policy"), Set.of());
            assertThat(e2cause).isInstanceOf(RootCause.PlanOrAnswerError.class);
        }
    }

    @Nested
    @DisplayName("E3 Device failure trace")
    class E3Trace {

        @Test
        @DisplayName("tool exception -> DeviceFailure -> AcceptPartial -> COMPLETED-degraded")
        void toolExceptionShouldTriggerDeviceFailureAndDegrade() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor = ActorPregelDemo.runE3Demonstration();
            assertThat(supervisor.degraded).isTrue();
            assertThat(supervisor.finalOutput).isNotNull().contains("COMPLETED-degraded").contains("DeviceFailure");
            assertThat(supervisor.phase.name()).isEqualTo("DONE");
        }

        @Test
        @DisplayName("E3 degraded output contains failed node reference")
        void degradedOutputShouldContainFailedNodeReference() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor = ActorPregelDemo.runE3Demonstration();
            assertThat(supervisor.finalOutput).contains("verify_policy");
        }

        @Test
        @DisplayName("E3: normal tools unaffected by failing tool")
        void normalToolsUnaffectedByFailingTool() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor = ActorPregelDemo.runE3Demonstration();
            assertThat(supervisor.finalOutput).contains("claim_info").contains("calculate_payout");
        }
    }

    @Nested
    @DisplayName("E4 Perception unreliable")
    class E4PerceptionUnreliable {

        @Test
        @DisplayName("ContentVerifier throws -> PerceptionUnreliable -> COMPLETED-degraded")
        void verifierCrashShouldTriggerPerceptionUnreliable() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor = ActorPregelDemo.runE4Demonstration();
            assertThat(supervisor.degraded).isTrue();
            assertThat(supervisor.finalOutput).isNotNull().contains("COMPLETED-degraded").contains("PerceptionUnreliable");
            assertThat(supervisor.phase.name()).isEqualTo("DONE");
        }

        @Test
        @DisplayName("verifyThrew=true -> PerceptionUnreliable (priority 1)")
        void verifyThrewTriggersPerceptionUnreliablePriority1() {
            RootCause cause = ActorPregelDemo.VerifyActor.diagnoseRootCause(Set.of(), true, Set.of(), Set.of());
            assertThat(cause).isInstanceOf(RootCause.PerceptionUnreliable.class);
            assertThat(((RootCause.PerceptionUnreliable) cause).verifierThrew()).isTrue();
        }

        @Test
        @DisplayName("E4 path is now reachable -- try-catch wraps entire verification block")
        void e4PathIsNowReachable() throws Exception {
            BlockingQueue<Object> inbox = new LinkedBlockingQueue<>(1);
            BlockingQueue<Object> supInbox = new LinkedBlockingQueue<>(1);
            ActorPregelDemo.ContentVerifier throwingVerifier = results -> { throw new RuntimeException("verifier crash"); };
            ActorPregelDemo.VerifyActor verifyActor = new ActorPregelDemo.VerifyActor("test-verifier", inbox, supInbox, throwingVerifier);
            Thread vt = new Thread(verifyActor, "test-verify");
            vt.start();
            inbox.put(new ActorPregelDemo.VerifyRequest("t1", java.util.Map.of("n1", "OK: done"), Set.of(), Set.of()));
            ActorPregelDemo.VerifyResponse resp = (ActorPregelDemo.VerifyResponse) supInbox.poll(5, TimeUnit.SECONDS);
            assertThat(resp).isNotNull();
            assertThat(resp.verifyThrew()).isTrue();
            assertThat(resp.rootCause()).isInstanceOf(RootCause.PerceptionUnreliable.class);
            inbox.put(new ActorPregelDemo.PoisonPill());
            vt.join(2_000);
        }
    }

    @Nested
    @DisplayName("BSP superstep boundary")
    class BspBoundary {

        @Test
        @DisplayName("each layer executes independently")
        void eachLayerExecutesIndependently() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor = ActorPregelDemo.runE3Demonstration();
            assertThat(supervisor.finalOutput).contains("DeviceFailure");
        }

        @Test
        @DisplayName("LayerResult contains correct per-layer failure/skip info")
        void layerResultContainsCorrectPerLayerInfo() throws Exception {
            BlockingQueue<Object> supInbox = new LinkedBlockingQueue<>(256);
            BlockingQueue<Object> execInbox = new LinkedBlockingQueue<>(256);
            ActorPregelDemo.ExecuteActor executor = new ActorPregelDemo.ExecuteActor("test-exec", execInbox, supInbox, java.util.Map.of());
            Thread et = new Thread(executor, "test-exec");
            et.start();
            BlockingQueue<ActorPregelDemo.LayerResult> layerChannel = new LinkedBlockingQueue<>(1);
            execInbox.put(new ActorPregelDemo.ExecuteLayer("t1", java.util.List.of(new ActorPregelDemo.DemoNode("n1", "nonexistent", "desc")), java.util.Map.of(), layerChannel));
            ActorPregelDemo.LayerResult result = layerChannel.poll(5, TimeUnit.SECONDS);
            assertThat(result).isNotNull();
            assertThat(result.skippedNodes()).contains("n1");
            assertThat(result.nodeResults().get("n1")).contains("SKIPPED");
            execInbox.put(new ActorPregelDemo.PoisonPill());
            et.join(2_000);
        }
    }

    @Nested
    @DisplayName("Inbox multiplexing safety")
    class InboxMultiplexingSafety {

        @Test
        @DisplayName("per-superstep channel prevents PoisonPill hijacking ToolCallResponse")
        void perSuperstepChannelPreventsPoisonPillHijacking() throws Exception {
            BlockingQueue<Object> execInbox = new LinkedBlockingQueue<>(256);
            BlockingQueue<Object> supInbox = new LinkedBlockingQueue<>(256);
            BlockingQueue<Object> toolInbox = new LinkedBlockingQueue<>(256);
            ActorPregelDemo.ExecuteActor executor = new ActorPregelDemo.ExecuteActor("test-exec", execInbox, supInbox, java.util.Map.of("test_tool", toolInbox));
            Thread et = new Thread(executor, "test-exec");
            et.start();
            Thread toolThread = new Thread(() -> {
                try {
                    Object msg = toolInbox.poll(5, TimeUnit.SECONDS);
                    if (msg instanceof ActorPregelDemo.ToolCallRequest req) {
                        Thread.sleep(100);
                        req.replyTo().put(new ActorPregelDemo.ToolCallResponse(req.nodeId(), "OK: done"));
                    }
                } catch (Exception e) { /* ignore */ }
            }, "mock-tool");
            toolThread.start();
            BlockingQueue<ActorPregelDemo.LayerResult> layerChannel = new LinkedBlockingQueue<>(1);
            execInbox.put(new ActorPregelDemo.ExecuteLayer("t1", java.util.List.of(new ActorPregelDemo.DemoNode("n1", "test_tool", "desc")), java.util.Map.of(), layerChannel));
            execInbox.put(new ActorPregelDemo.PoisonPill());
            ActorPregelDemo.LayerResult result = layerChannel.poll(5, TimeUnit.SECONDS);
            assertThat(result).isNotNull();
            assertThat(result.nodeResults().get("n1")).isEqualTo("OK: done");
            toolThread.join(2_000);
            et.join(2_000);
        }
    }

    @Nested
    @DisplayName("Zero locks proof")
    class ZeroLocks {

        @Test
        @DisplayName("SupervisorActor has no ReentrantLock / AtomicBoolean / ConcurrentHashMap / synchronized")
        void supervisorHasNoSharedMemoryLocks() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor = ActorPregelDemo.runE3Demonstration();
            Class<?> cls = supervisor.getClass();
            for (var field : cls.getDeclaredFields()) {
                String typeName = field.getType().getName();
                assertThat(typeName).as("SupervisorActor field %s should not be a lock type", field.getName())
                        .doesNotContain("ReentrantLock").doesNotContain("AtomicBoolean")
                        .doesNotContain("ConcurrentHashMap").doesNotContain("AtomicInteger");
            }
        }

        @Test
        @DisplayName("PlanActor fields contain no lock types")
        void planActorHasNoLocks() {
            Class<?> cls = ActorPregelDemo.PlanActor.class;
            for (var field : cls.getDeclaredFields()) {
                String typeName = field.getType().getName();
                assertThat(typeName).as("PlanActor field %s should not be a lock", field.getName())
                        .doesNotContain("ReentrantLock").doesNotContain("Atomic").doesNotContain("ConcurrentHashMap");
            }
        }

        @Test
        @DisplayName("ExecuteActor fields contain no lock types")
        void executeActorHasNoLocks() {
            Class<?> cls = ActorPregelDemo.ExecuteActor.class;
            for (var field : cls.getDeclaredFields()) {
                String typeName = field.getType().getName();
                assertThat(typeName).as("ExecuteActor field %s should not be a lock", field.getName())
                        .doesNotContain("ReentrantLock").doesNotContain("Atomic").doesNotContain("ConcurrentHashMap");
            }
        }

        @Test
        @DisplayName("VerifyActor fields contain no lock types")
        void verifyActorHasNoLocks() {
            Class<?> cls = ActorPregelDemo.VerifyActor.class;
            for (var field : cls.getDeclaredFields()) {
                String typeName = field.getType().getName();
                assertThat(typeName).as("VerifyActor field %s should not be a lock", field.getName())
                        .doesNotContain("ReentrantLock").doesNotContain("Atomic").doesNotContain("ConcurrentHashMap");
            }
        }

        @Test
        @DisplayName("all message types are records (compiler-enforced immutability)")
        void allMessagesAreRecords() {
            assertThat(ActorPregelDemo.PlanRequest.class.isRecord()).isTrue();
            assertThat(ActorPregelDemo.PlanResponse.class.isRecord()).isTrue();
            assertThat(ActorPregelDemo.ExecuteLayer.class.isRecord()).isTrue();
            assertThat(ActorPregelDemo.LayerResult.class.isRecord()).isTrue();
            assertThat(ActorPregelDemo.VerifyRequest.class.isRecord()).isTrue();
            assertThat(ActorPregelDemo.VerifyResponse.class.isRecord()).isTrue();
            assertThat(ActorPregelDemo.ToolCallRequest.class.isRecord()).isTrue();
            assertThat(ActorPregelDemo.ToolCallResponse.class.isRecord()).isTrue();
            assertThat(ActorPregelDemo.PoisonPill.class.isRecord()).isTrue();
            assertThat(ActorPregelDemo.TerminalRecord.class.isRecord()).isTrue();
        }
    }

    @Nested
    @DisplayName("Actor model basics")
    class ActorBasics {

        @Test
        @DisplayName("messages pass via BlockingQueue inbox -- not shared memory")
        void messagesPassViaInboxes() throws Exception {
            BlockingQueue<Object> inbox = new LinkedBlockingQueue<>();
            ActorPregelDemo.PlanRequest req = new ActorPregelDemo.PlanRequest("task-1", "test goal", null);
            inbox.put(req);
            Object received = inbox.poll(1, TimeUnit.SECONDS);
            assertThat(received).isInstanceOf(ActorPregelDemo.PlanRequest.class);
            assertThat(((ActorPregelDemo.PlanRequest) received).taskId()).isEqualTo("task-1");
        }

        @Test
        @DisplayName("PoisonPill causes graceful Actor exit")
        void poisonPillStopsActor() throws Exception {
            BlockingQueue<Object> inbox = new LinkedBlockingQueue<>();
            BlockingQueue<Object> dummySupervisorInbox = new LinkedBlockingQueue<>();
            ActorPregelDemo.PlanActor actor = new ActorPregelDemo.PlanActor("test-planner", inbox, dummySupervisorInbox);
            Thread actorThread = new Thread(actor, "test-actor");
            actorThread.start();
            inbox.put(new ActorPregelDemo.PoisonPill());
            actorThread.join(5_000);
            assertThat(actorThread.isAlive()).isFalse();
        }

        @Test
        @DisplayName("diagnoseRootCause matches AlphaStrategy logic")
        void diagnoseRootCauseMatchesAlphaStrategy() {
            RootCause cause1 = ActorPregelDemo.VerifyActor.diagnoseRootCause(Set.of("node-a"), true, Set.of("node-a"), Set.of());
            assertThat(cause1).isInstanceOf(RootCause.PerceptionUnreliable.class);
            assertThat(((RootCause.PerceptionUnreliable) cause1).verifierThrew()).isTrue();

            RootCause cause2 = ActorPregelDemo.VerifyActor.diagnoseRootCause(Set.of("verify_policy", "claim_info"), false, Set.of("verify_policy"), Set.of());
            assertThat(cause2).isInstanceOf(RootCause.DeviceFailure.class);
            assertThat(((RootCause.DeviceFailure) cause2).nodes()).contains("verify_policy");

            RootCause cause3 = ActorPregelDemo.VerifyActor.diagnoseRootCause(Set.of("skipped_node"), false, Set.of(), Set.of("skipped_node"));
            assertThat(cause3).isInstanceOf(RootCause.DeviceFailure.class);

            RootCause cause4 = ActorPregelDemo.VerifyActor.diagnoseRootCause(Set.of("answer_node"), false, Set.of("other_node"), Set.of());
            assertThat(cause4).isInstanceOf(RootCause.PlanOrAnswerError.class);
            assertThat(((RootCause.PlanOrAnswerError) cause4).nodes()).contains("answer_node");
        }

        @Test
        @DisplayName("diagnose function is pure -- same input -> same output")
        void diagnoseRootCauseIsPureFunction() {
            Set<String> failed = Set.of("n1", "n2");
            Set<String> execFailed = Set.of("n1");
            Set<String> execSkipped = Set.of();
            RootCause first = ActorPregelDemo.VerifyActor.diagnoseRootCause(failed, false, execFailed, execSkipped);
            RootCause second = ActorPregelDemo.VerifyActor.diagnoseRootCause(failed, false, execFailed, execSkipped);
            assertThat(first).isEqualTo(second);
            assertThat(first).isInstanceOf(RootCause.DeviceFailure.class);
        }

        @Test
        @DisplayName("three-way exhaustive -- diagnoseRootCause returns only 3 sealed subtypes")
        void diagnoseRootCauseReturnsOnlyThreeSealedSubtypes() {
            var perception = ActorPregelDemo.VerifyActor.diagnoseRootCause(Set.of(), true, Set.of(), Set.of());
            assertThat(perception).isInstanceOfAny(RootCause.PerceptionUnreliable.class, RootCause.DeviceFailure.class, RootCause.PlanOrAnswerError.class);
            var device = ActorPregelDemo.VerifyActor.diagnoseRootCause(Set.of("n1"), false, Set.of("n1"), Set.of());
            assertThat(device).isInstanceOfAny(RootCause.PerceptionUnreliable.class, RootCause.DeviceFailure.class, RootCause.PlanOrAnswerError.class);
            var plan = ActorPregelDemo.VerifyActor.diagnoseRootCause(Set.of("n1"), false, Set.of(), Set.of());
            assertThat(plan).isInstanceOfAny(RootCause.PerceptionUnreliable.class, RootCause.DeviceFailure.class, RootCause.PlanOrAnswerError.class);
        }

        @Test
        @DisplayName("PlanRequest carries failureContext for replan (Bug 7 fix)")
        void planRequestCarriesFailureContextForReplan() {
            ActorPregelDemo.PlanRequest req = new ActorPregelDemo.PlanRequest("t1", "goal", "failed nodes: [verify_policy]");
            assertThat(req.failureContext()).isEqualTo("failed nodes: [verify_policy]");
            ActorPregelDemo.PlanRequest reqNoContext = new ActorPregelDemo.PlanRequest("t2", "goal", null);
            assertThat(reqNoContext.failureContext()).isNull();
        }
    }

    @Nested
    @DisplayName("Timeout degradation")
    class TimeoutDegradation {

        @Test
        @DisplayName("per-superstep channel timeout -> unreceived ToolActor marked FAILED")
        void superstepChannelTimeoutMarksMissingAsFailed() throws Exception {
            BlockingQueue<Object> execInbox = new LinkedBlockingQueue<>(256);
            BlockingQueue<Object> supInbox = new LinkedBlockingQueue<>(256);
            BlockingQueue<Object> hangToolInbox = new LinkedBlockingQueue<>(256);
            Thread hangTool = new Thread(() -> {
                try {
                    Object msg = hangToolInbox.poll(5, TimeUnit.SECONDS);
                    if (msg instanceof ActorPregelDemo.ToolCallRequest req) {
                        // NEVER reply -- simulate hang
                    }
                } catch (Exception e) { /* ignore */ }
            }, "hang-tool");
            hangTool.start();
            ActorPregelDemo.ExecuteActor executor = new ActorPregelDemo.ExecuteActor("test-exec", execInbox, supInbox, java.util.Map.of("hang_tool", hangToolInbox));
            Thread et = new Thread(executor, "test-exec");
            et.start();
            BlockingQueue<ActorPregelDemo.LayerResult> layerChannel = new LinkedBlockingQueue<>(1);
            execInbox.put(new ActorPregelDemo.ExecuteLayer("t1", java.util.List.of(new ActorPregelDemo.DemoNode("n1", "hang_tool", "desc")), java.util.Map.of(), layerChannel));
            ActorPregelDemo.LayerResult result = layerChannel.poll(15, TimeUnit.SECONDS);
            assertThat(result).isNotNull();
            assertThat(result.failedNodes()).contains("n1");
            assertThat(result.nodeResults().get("n1")).contains("FAILED: timeout");
            execInbox.put(new ActorPregelDemo.PoisonPill());
            hangToolInbox.put(new ActorPregelDemo.PoisonPill());
            et.join(3_000);
            hangTool.join(3_000);
        }
    }

    @Nested
    @DisplayName("Shared memory vs Actor model comparison")
    class SharedMemoryVsActor {

        @Test
        @DisplayName("Actor model eliminates three shared-memory concurrency patterns")
        void actorModelEliminatesThreeSharedMemoryPatterns() throws Exception {
            ActorPregelDemo.runE3Demonstration();
            Class<?>[] actorClasses = { ActorPregelDemo.SupervisorActor.class, ActorPregelDemo.PlanActor.class, ActorPregelDemo.ExecuteActor.class, ActorPregelDemo.VerifyActor.class, ActorPregelDemo.ToolActor.class };
            for (Class<?> cls : actorClasses) {
                boolean hasLock = false;
                for (var field : cls.getDeclaredFields()) {
                    String typeName = field.getType().getName();
                    if (typeName.contains("ReentrantLock") || typeName.contains("AtomicBoolean") || typeName.contains("AtomicInteger") || typeName.contains("ConcurrentHashMap") || typeName.contains("CopyOnWrite")) {
                        hasLock = true;
                        break;
                    }
                }
                assertThat(hasLock).as("%s should not contain shared-memory concurrency primitives", cls.getSimpleName()).isFalse();
            }
        }
    }

    @Nested
    @DisplayName("Sealed exhaustiveness compile-time guarantee")
    class SealedExhaustiveness {

        @Test
        @DisplayName("RootCause sealed hierarchy: exactly 3 permitted subtypes")
        void rootCauseHasExactlyThreePermittedSubtypes() {
            Class<?>[] permitted = RootCause.class.getPermittedSubclasses();
            assertThat(permitted).hasSize(3);
            assertThat(permitted).contains(RootCause.DeviceFailure.class, RootCause.PlanOrAnswerError.class, RootCause.PerceptionUnreliable.class);
        }

        @Test
        @DisplayName("each RootCause subtype hits a distinct handler branch")
        void eachRootCauseSubtypeHasCorrespondingHandlerBranch() throws Exception {
            ActorPregelDemo.SupervisorActor e1 = ActorPregelDemo.runE1Demonstration();
            assertThat(e1.finalOutput).startsWith("COMPLETED:");
            assertThat(e1.degraded).isFalse();
            ActorPregelDemo.SupervisorActor e2 = ActorPregelDemo.runE2Demonstration();
            assertThat(e2.finalOutput).contains("COMPLETED-degraded").contains("retries exhausted");
            assertThat(e2.degraded).isTrue();
            ActorPregelDemo.SupervisorActor e3 = ActorPregelDemo.runE3Demonstration();
            assertThat(e3.finalOutput).contains("DeviceFailure");
            assertThat(e3.degraded).isTrue();
            ActorPregelDemo.SupervisorActor e4 = ActorPregelDemo.runE4Demonstration();
            assertThat(e4.finalOutput).contains("PerceptionUnreliable");
            assertThat(e4.degraded).isTrue();
        }

        @Test
        @DisplayName("missing branch would be caught at compile time -- all 3 subtypes handled")
        void missingBranchWouldBeCaughtAtCompileTime() {
            RootCause[] allCases = { new RootCause.DeviceFailure(Set.of("n1")), new RootCause.PlanOrAnswerError(Set.of("n1")), new RootCause.PerceptionUnreliable(true) };
            for (RootCause rc : allCases) {
                boolean handled = rc instanceof RootCause.DeviceFailure || rc instanceof RootCause.PlanOrAnswerError || rc instanceof RootCause.PerceptionUnreliable;
                assertThat(handled).as("RootCause subtype %s must be in dispatch chain", rc.getClass().getSimpleName()).isTrue();
            }
        }

        @Test
        @DisplayName("compile-time mutation-prove: deleting Permit subtype breaks compilation")
        void deletingPermitSubtypeBreaksCompilation() {
            Class<?>[] permits = RootCause.class.getPermittedSubclasses();
            assertThat(permits).isNotNull();
            assertThat(permits.length).isEqualTo(3);
        }
    }
}
