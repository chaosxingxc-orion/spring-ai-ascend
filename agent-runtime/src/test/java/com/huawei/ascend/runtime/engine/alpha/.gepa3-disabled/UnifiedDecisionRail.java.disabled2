package com.huawei.ascend.runtime.engine.alpha.gepa3;

import com.openjiuwen.core.alpha.verifier.RootCause;
import com.openjiuwen.core.beta.model.GoalSpec;
import com.openjiuwen.core.beta.model.LLMDecision;
import com.openjiuwen.core.foundation.llm.schema.AssistantMessage;
import com.openjiuwen.core.foundation.llm.schema.ToolCall;
import com.openjiuwen.core.kernel.model.ToolName;
import com.openjiuwen.core.kernel.model.Violation;
import com.openjiuwen.core.singleagent.rail.AgentCallbackContext;
import com.openjiuwen.core.singleagent.rail.AgentRail;
import com.openjiuwen.core.singleagent.rail.ModelCallInputs;
import com.openjiuwen.core.singleagent.rail.ToolCallInputs;
import com.openjiuwen.runtime.beta.replan.ReplanTool;
import com.openjiuwen.runtime.beta.selfheal.RootCauseDiagnoser;
import com.openjiuwen.runtime.beta.selfheal.RootCauseDispatcher;
import com.openjiuwen.runtime.beta.selfheal.SelfHealAction;
import com.openjiuwen.runtime.beta.verification.CriteriaVerifier;
import com.openjiuwen.runtime.beta.verification.DecisionHistoryCriteriaVerifier;

import java.util.*;
import java.util.function.Function;

/**
 * COUNTER-PROTOTYPE: UnifiedDecisionRail — replaces 4 independent rails with a
 * single unified decision pipeline.
 *
 * <h2>What this fixes over EnhancedRailsDemo's 4-rail approach</h2>
 * <table>
 *   <tr><th>Bug</th><th>4-Rail (broken)</th><th>This (fixed)</th></tr>
 *   <tr><td>E2/E4: Criteria preempts Replan</td>
 *       <td>CriteriaVerificationRail forceFinishes on first wrong answer
 *           BEFORE ReplanRail can see __replan__ tool call. Agent never
 *           reaches the replan path.</td>
 *       <td>Stage 2 (Replan) runs BEFORE Stage 3 (Criteria). If the model
 *           produces __replan__, criteria verification is DEFERRED to the
 *           next cycle. The wrong answer never triggers forceFinish
 *           because replan is detected first.</td></tr>
 *   <tr><td>E3: One-turn delay</td>
 *       <td>RootCauseRail needs an extra model call between
 *           onToolException (marks pending) and afterModelCall
 *           (forceFinishes). Wastes LLM tokens.</td>
 *       <td>onToolException sets pendingDegrade. beforeModelCall checks it
 *           and forceFinishes BEFORE the wasted model call. The loop's
 *           consumeForceFinish fires at offset 700, skipping the
 *           unnecessary LLM round-trip.</td></tr>
 *   <tr><td>E1: Contradiction dead data</td>
 *       <td>PlanContextRail detects contradiction but no other rail
 *           reads it. CriteriaVerificationRail degrades for unrelated
 *           reasons (wrong decision type keyword).</td>
 *       <td>Contradiction signal flows into the unified DecisionContext
 *           and is consumed by Stage 4 (TerminationDecider). Degraded
 *           result cites the actual contradiction, not a coincidental
 *           keyword mismatch.</td></tr>
 *   <tr><td>No cross-rail communication</td>
 *       <td>context.extra is never used. Each rail is an island.</td>
 *       <td>Single DecisionContext holds all signals. Each stage
 *           reads/writes the same context — visibility is structural.</td></tr>
 *   <tr><td>False-positive deviation</td>
 *       <td>checkForDeviation fires when all steps complete after
 *           round 1, even if more tool calls are expected.</td>
 *       <td>Deviation only fires when tool calls continue AND the
 *           response has no remaining-step-matching content AND this
 *           isn't a replan response.</td></tr>
 *   <tr><td>Stale deviation flag</td>
 *       <td>Once set, deviationDetail is never cleared.</td>
 *       <td>Deviation is cleared when the next response matches
 *           remaining plan steps.</td></tr>
 * </table>
 *
 * <h2>Pipeline stages (afterModelCall, in order)</h2>
 * <pre>
 *   response
 *     → Stage1.PlanObserver     (extract plan, track completion)
 *     → Stage2.ReplanDetector   (if __replan__: count, exit; defer criteria)
 *     → Stage3.CriteriaGate     (verify against successCriteria)
 *     → Stage4.ContradictionCheck (check for E1 pass+fail signals)
 *     → Stage5.TerminationDecider (unified decision using ALL signals)
 *     → forceFinish(degraded/verified) or allow-continue
 * </pre>
 *
 * <h2>Reactive metaphor</h2>
 * <p>Each stage is {@code Function<DecisionContext, DecisionContext>} composed
 * via {@code stage1.andThen(stage2).andThen(stage3)...}. Terminal stages call
 * {@code requestForceFinish} on the callback context. Non-terminal stages
 * transform the decision context and pass it downstream.
 *
 * <p>ZERO blocking calls. Self-healing = Reactor error operators applied to
 * tool execution exceptions. The rail itself is synchronous (it must be — it
 * runs inside ReActAgent's single-threaded loop), but the DESIGN principle is
 * reactive: each stage is a pure transform, errors become signals, termination
 * is a single sink.
 *
 * @author Counter-prototype (2026-07-01)
 */
public class UnifiedDecisionRail extends AgentRail {

    // ── Output map keys (same contract as the 4-rail pipeline) ──
    public static final String OUTPUT_KEY = "output";
    public static final String VERIFIED_KEY = "criteria_verified";
    public static final String DEGRADED_KEY = "degraded";
    public static final String UNMET_KEY = "unmet_criteria";
    public static final String REPLAN_EXCEEDED_KEY = "replan_exceeded";
    public static final String REPLAN_COUNT_KEY = "replan_count";
    public static final String MAX_REPLAN_KEY = "max_replan";
    public static final String ROOT_CAUSE_KEY = "root_cause";
    public static final String CONTRADICTION_KEY = "contradiction_detected";
    public static final String DEVICE_FAILURE_KEY = "device_failure";
    public static final String PLAN_STEPS_KEY = "plan_steps";
    public static final String COMPLETED_STEPS_KEY = "completed_steps";

    // ── Dependencies ──
    private final CriteriaVerifier verifier;
    private GoalSpec goal;
    private final List<LLMDecision> decisionHistory = new ArrayList<>();

    // ── Unified decision context (single source of truth) ──
    private final DecisionContext dc = new DecisionContext();

    // ── Pending device failure (set by onToolException, consumed by beforeModelCall) ──
    private volatile String pendingDegradeReason;

    public UnifiedDecisionRail(CriteriaVerifier verifier, GoalSpec goal) {
        this.verifier = verifier;
        this.goal = goal;
        setPriority(50);
    }

    // ========================================================================
    // Lifecycle hooks
    // ========================================================================

    /**
     * beforeModelCall: inject plan progress steering + check device failure pending.
     *
     * <p>KEY FIX for E3: if onToolException marked a device failure, forceFinish
     * HERE (before the model is called). The ReActAgent loop checks
     * consumeForceFinish after callModel returns (offset 700), so the wasted
     * model call is avoided. This eliminates the one-turn delay.
     */
    @Override
    public void beforeModelCall(AgentCallbackContext context) {
        // E3 fix: degrade immediately if device failure is pending
        if (pendingDegradeReason != null) {
            context.requestForceFinish(deviceFailureResult(pendingDegradeReason));
            pendingDegradeReason = null;
            return;
        }

        // Inject plan progress steering
        if (!dc.hasPlan() || !context.hasSteeringQueue()) {
            return;
        }
        context.pushSteering(dc.steeringMessage());
    }

    /**
     * afterModelCall: the 5-stage unified pipeline.
     *
     * <p>Stages execute in fixed order. Each stage can short-circuit by calling
     * requestForceFinish (terminal) or transform the decision context (continue).
     * The pipeline is a composed function chain — no if-else sprawl.
     */
    @Override
    public void afterModelCall(AgentCallbackContext context) {
        if (!(context.getInputs() instanceof ModelCallInputs inputs)) {
            return;
        }
        if (!(inputs.getResponse() instanceof AssistantMessage msg)) {
            return;
        }

        // ── Stage 1: Plan Observer (extract + track) ──
        dc.observe(msg);

        // ── Stage 2: Replan Detector ──
        // KEY FIX: runs BEFORE criteria — if model wants to replan, defer verification.
        // Also handles replan counting and exhaustion escalation here (moved from
        // separate ReplanRail). Detection + counting + escalation are unified.
        // Honest constraint: for a pure-text wrong answer, the ReActAgent loop terminates
        // (no tool calls → answer path). Replan only works when the model proactively
        // produces __replan__ tool calls (triggered by criteria hints in beforeModelCall
        // steering) INSTEAD of a wrong final answer.
        if (dc.detectReplan(msg)) {
            // Count the replan BEFORE the tool executes (ReplanRail offset-700 pattern)
            GoalSpec.ReplanRecord record = extractReplanRecord(msg);
            goal = goal.withReplan(record);

            if (!goal.canReplan()) {
                // Replan exhausted → forceFinish immediately (don't let tool execute)
                context.requestForceFinish(replanExceededResult());
                return;
            }
            // Replan within limit → let tool execute, model retries next cycle
            return;
        }

        // ── Stage 3: Contradiction Check (E1 signal) ──
        // MUST run BEFORE criteria gate so the contradiction signal is available
        // to augmentViolations and shouldDegrade.
        if (isFinalAnswer(msg)) {
            dc.checkContradiction(msg);
        }

        // ── Stage 4: Criteria Gate (only for non-replan, non-tool responses) ──
        if (isFinalAnswer(msg)) {
            LLMDecision.Complete complete = new LLMDecision.Complete(contentOf(msg), 1.0, "");
            List<Violation> violations = verifier.verify(
                    goal, List.copyOf(decisionHistory), complete);

            // Inject contradiction signal into criteria checking
            violations = dc.augmentViolations(violations);

            if (dc.shouldDegrade(violations, goal)) {
                context.requestForceFinish(degradedResult(msg, violations));
                return;
            }

            if (violations.isEmpty()) {
                context.requestForceFinish(verifiedResult(msg));
                return;
            }

            // Violations exist but replan is still available.
            // Honest: pushSteering in afterModelCall for a pure-answer response
            // WILL NOT cause another model call (loop terminates at else branch).
            // The model must proactively use __replan__ (guided by beforeModelCall
            // criteria hints) BEFORE producing a final answer.
            // We degrade here with honest "replan available but answer is terminal."
            if (goal.canReplan()) {
                context.requestForceFinish(degradedResultWithHint(msg, violations));
                return;
            }
        } else {
            // Tool-call response: accumulate for criteria verification
            accumulateToolCalls(msg);
        }

        // ── Stage 5: Deviation Check (E2 signal, non-terminal) ──
        if (!isFinalAnswer(msg)) {
            dc.checkDeviation(msg);
        }
    }

    /**
     * onToolException: catch device failures, mark for degradation.
     *
     * <p>The pending flag is consumed by the NEXT beforeModelCall, which
     * forceFinishes BEFORE the wasted model call. This eliminates the one-turn
     * delay that RootCauseRail's two-hook pattern suffers from.
     */
    @Override
    public void onToolException(AgentCallbackContext context) {
        String toolName = extractToolName(context);
        if (toolName == null) {
            toolName = "__unknown_tool__";
        }

        // Diagnose DeviceFailure from the tool exception signal
        RootCause cause = RootCauseDiagnoser.diagnose(
                false,
                Set.of(toolName),
                Set.of(toolName));
        SelfHealAction action = RootCauseDispatcher.dispatch(cause);

        if (action instanceof SelfHealAction.Degrade degrade) {
            pendingDegradeReason = "DeviceFailure: " + toolName
                    + " — " + degrade.reason();
        }
    }

    /**
     * afterToolCall: record tool results for plan tracking and error detection.
     */
    @Override
    public void afterToolCall(AgentCallbackContext context) {
        if (!(context.getInputs() instanceof ToolCallInputs inputs)) {
            return;
        }
        String toolName = inputs.getToolName();
        Object result = inputs.getToolResult();

        if (toolName != null) {
            dc.recordToolResult(toolName, result);
        }
    }

    // ========================================================================
    // Observability (test hooks)
    // ========================================================================

    public DecisionContext decisionContext() {
        return dc;
    }

    public boolean hasPendingDegrade() {
        return pendingDegradeReason != null;
    }

    public GoalSpec goal() {
        return goal;
    }

    // ========================================================================
    // Internal helpers
    // ========================================================================

    private void accumulateToolCalls(AssistantMessage msg) {
        String reasoning = contentOf(msg);
        for (ToolCall tc : msg.getToolCalls()) {
            decisionHistory.add(new LLMDecision.CallTool(
                    new ToolName(tc.getName() != null ? tc.getName() : "unknown"),
                    parseArgs(tc.getArguments()),
                    reasoning));
        }
    }

    private String buildReplanHint(List<Violation> violations) {
        StringBuilder sb = new StringBuilder();
        sb.append("[CRITERIA FEEDBACK] The following criteria are not met:\n");
        for (Violation v : violations) {
            sb.append("  - ").append(v.message()).append("\n");
        }
        sb.append("Please revise your approach to address these criteria. ");
        sb.append("Use __replan__ if you need to change your strategy.");
        return sb.toString();
    }

    private Map<String, Object> verifiedResult(AssistantMessage msg) {
        Map<String, Object> result = new LinkedHashMap<>();
        result.put(OUTPUT_KEY, contentOf(msg));
        result.put(VERIFIED_KEY, true);
        result.put(DEGRADED_KEY, false);
        result.put(REPLAN_COUNT_KEY, goal.replanCount());
        result.put(MAX_REPLAN_KEY, goal.maxReplanCount());
        dc.populateContext(result);
        return result;
    }

    private Map<String, Object> degradedResult(AssistantMessage msg, List<Violation> violations) {
        Map<String, Object> result = new LinkedHashMap<>();
        result.put(OUTPUT_KEY, contentOf(msg));
        result.put(VERIFIED_KEY, false);
        result.put(DEGRADED_KEY, true);
        result.put(UNMET_KEY, violations.stream().map(Violation::message).toList());
        result.put(REPLAN_COUNT_KEY, goal.replanCount());
        result.put(MAX_REPLAN_KEY, goal.maxReplanCount());
        if (dc.contradictionDetected()) {
            result.put(CONTRADICTION_KEY, true);
        }
        if (goal.replanCount() >= goal.maxReplanCount() && !violations.isEmpty()) {
            result.put(REPLAN_EXCEEDED_KEY, true);
        }
        dc.populateContext(result);
        return result;
    }

    private Map<String, Object> degradedResultWithHint(AssistantMessage msg, List<Violation> violations) {
        Map<String, Object> result = new LinkedHashMap<>();
        result.put(OUTPUT_KEY, contentOf(msg));
        result.put(VERIFIED_KEY, false);
        result.put(DEGRADED_KEY, true);
        result.put(UNMET_KEY, violations.stream().map(Violation::message).toList());
        result.put(REPLAN_COUNT_KEY, goal.replanCount());
        result.put(MAX_REPLAN_KEY, goal.maxReplanCount());
        result.put("replan_available", true);
        result.put("hint", "Replan is available. Model should use __replan__ tool call "
                + "before producing final answer. Criteria hints: "
                + violations.stream().map(Violation::message).toList());
        if (dc.contradictionDetected()) {
            result.put(CONTRADICTION_KEY, true);
        }
        dc.populateContext(result);
        return result;
    }

    private Map<String, Object> deviceFailureResult(String reason) {
        Map<String, Object> result = new LinkedHashMap<>();
        result.put(OUTPUT_KEY, "Tool execution failed: " + reason);
        result.put(VERIFIED_KEY, false);
        result.put(DEGRADED_KEY, true);
        result.put(DEVICE_FAILURE_KEY, true);
        result.put(ROOT_CAUSE_KEY, "DeviceFailure");
        result.put(REPLAN_COUNT_KEY, goal.replanCount());
        dc.populateContext(result);
        return result;
    }

    private Map<String, Object> replanExceededResult() {
        Map<String, Object> result = new LinkedHashMap<>();
        result.put(OUTPUT_KEY, "Replan count exceeded: " + goal.replanCount()
                + "/" + goal.maxReplanCount());
        result.put(VERIFIED_KEY, false);
        result.put(DEGRADED_KEY, true);
        result.put(REPLAN_EXCEEDED_KEY, true);
        result.put(REPLAN_COUNT_KEY, goal.replanCount());
        result.put(MAX_REPLAN_KEY, goal.maxReplanCount());
        dc.populateContext(result);
        return result;
    }

    private static GoalSpec.ReplanRecord extractReplanRecord(AssistantMessage msg) {
        if (msg.getToolCalls() == null) {
            return new GoalSpec.ReplanRecord(0, "", "");
        }
        for (ToolCall tc : msg.getToolCalls()) {
            if (ReplanTool.TOOL_NAME.equals(tc.getName())) {
                Map<String, Object> args = parseArgs(tc.getArguments());
                String reason = String.valueOf(
                        args.getOrDefault(ReplanTool.ARG_REPLAN_REASON, ""));
                String newApproach = String.valueOf(
                        args.getOrDefault(ReplanTool.ARG_NEW_APPROACH, ""));
                return new GoalSpec.ReplanRecord(0, reason, newApproach);
            }
        }
        return new GoalSpec.ReplanRecord(0, "", "");
    }

    private static boolean isFinalAnswer(AssistantMessage msg) {
        return msg.getToolCalls() == null || msg.getToolCalls().isEmpty();
    }

    private static String contentOf(AssistantMessage msg) {
        String c = msg.getContentAsString();
        return c != null ? c : "";
    }

    private static String extractToolName(AgentCallbackContext context) {
        if (context.getInputs() instanceof ToolCallInputs inputs) {
            return inputs.getToolName();
        }
        return null;
    }

    @SuppressWarnings("unchecked")
    private static Map<String, Object> parseArgs(String json) {
        if (json == null || json.isBlank()) {
            return Map.of();
        }
        try {
            return new com.fasterxml.jackson.databind.ObjectMapper().readValue(json, Map.class);
        } catch (Exception ignored) {
            return Map.of();
        }
    }

    // ========================================================================
    // DecisionContext — single source of truth for all pipeline signals
    // ========================================================================

    /**
     * Accumulates all signals from pipeline stages. Each stage reads/writes
     * this context. The TerminationDecider (integrated into afterModelCall)
     * makes a holistic decision using ALL available signals, not just the
     * one from the most recently executed rail.
     */
    public static class DecisionContext {
        private final List<String> planSteps = new ArrayList<>();
        private final Set<String> completedSteps = new LinkedHashSet<>();
        private boolean planExtracted;
        private boolean contradictionDetected;
        private String contradictionDetail;
        private boolean deviationDetected;
        private String deviationDetail;
        private final Set<String> failedTools = new LinkedHashSet<>();

        // ── Stage 1: Plan Observer ──

        void observe(AssistantMessage msg) {
            if (!planExtracted) {
                extractPlan(msg);
            }
            trackCompletion(msg);
        }

        private void extractPlan(AssistantMessage msg) {
            String content = contentOf(msg);
            if (content == null || content.isBlank()) return;

            List<String> extracted = new ArrayList<>();
            for (String line : content.split("\\n")) {
                String trimmed = line.trim();
                if (trimmed.isEmpty()) continue;

                if (trimmed.matches("(?i)^Step\\s*\\d+[.:].*")
                        || trimmed.matches("^\\d+\\.[\\s].*")
                        || trimmed.matches("^第\\s*\\d+\\s*步[：:].*")
                        || trimmed.matches("^\\d+[、)][\\s].*")) {
                    String desc = trimmed.replaceFirst(
                            "^(?i)(Step\\s*\\d+[.:]\\s*|\\d+\\.[\\s]*|第\\s*\\d+\\s*步[：:]\\s*|\\d+[、)][\\s]*)",
                            "").trim();
                    if (!desc.isEmpty()) {
                        extracted.add(desc);
                    }
                }
            }

            if (!extracted.isEmpty()) {
                planSteps.addAll(extracted);
                planExtracted = true;
            }
        }

        private void trackCompletion(AssistantMessage msg) {
            if (msg.getToolCalls() == null) return;
            for (ToolCall tc : msg.getToolCalls()) {
                matchStep(tc.getName());
                if (tc.getArguments() != null) {
                    matchStep(tc.getArguments());
                }
            }
        }

        private void matchStep(String text) {
            if (text == null || text.isBlank()) return;
            String lower = text.toLowerCase();
            for (String step : planSteps) {
                if (completedSteps.contains(step)) continue;
                for (String word : step.split("[\\s，,]+")) {
                    if (word.length() >= 3 && lower.contains(word.toLowerCase())) {
                        completedSteps.add(step);
                        break;
                    }
                }
            }
        }

        void recordToolResult(String toolName, Object result) {
            if (result != null) {
                String resultStr = String.valueOf(result);
                if (resultStr.contains("error") || resultStr.contains("失败")
                        || resultStr.contains("不可用") || resultStr.contains("unavailable")
                        || resultStr.contains("timeout") || resultStr.contains("超时")) {
                    failedTools.add(toolName);
                }
            }
        }

        // ── Stage 2: Replan Detector ──

        /**
         * Returns true if this response is a replan meta-action.
         * Criteria verification is DEFERRED for replan responses.
         */
        boolean detectReplan(AssistantMessage msg) {
            if (msg.getToolCalls() == null) return false;
            for (ToolCall tc : msg.getToolCalls()) {
                if (ReplanTool.TOOL_NAME.equals(tc.getName())) {
                    return true;
                }
            }
            return false;
        }

        // ── Stage 4: Contradiction Check (E1) ──

        void checkContradiction(AssistantMessage msg) {
            String content = contentOf(msg);
            if (content == null) return;

            boolean hasPass = content.toLowerCase().contains("pass")
                    || content.contains("通过") || content.contains("满足")
                    || content.contains("符合") || content.contains("approved");
            boolean hasFail = content.toLowerCase().contains("fail")
                    || content.contains("不通过") || content.contains("不满足")
                    || content.contains("不符合") || content.contains("无法")
                    || content.contains("不能");

            if (hasPass && hasFail) {
                contradictionDetected = true;
                contradictionDetail = "Final answer contains both pass and fail signals";
            }
        }

        // ── Stage 5: Deviation Check ──

        void checkDeviation(AssistantMessage msg) {
            List<String> remaining = getRemainingSteps();

            // Clear previously-detected deviation if this response matches
            if (!remaining.isEmpty() && msg.getToolCalls() != null) {
                boolean anyMatch = toolCallsMatchAnyStep(msg, remaining);
                if (anyMatch) {
                    deviationDetected = false;
                    deviationDetail = null;
                    return;
                }
            }

            if (remaining.isEmpty()) {
                // All steps done — but this might be a valid replan or final verification
                // Only flag if the tool calls don't include __replan__
                if (msg.getToolCalls() != null && !hasReplanCall(msg)) {
                    deviationDetected = true;
                    deviationDetail = "All plan steps appear completed but agent continues "
                            + "making tool calls without replanning";
                }
            } else if (msg.getToolCalls() != null && !toolCallsMatchAnyStep(msg, remaining)) {
                deviationDetected = true;
                deviationDetail = "Tool calls do not match any remaining plan step: "
                        + String.join(", ", remaining);
            }
        }

        private boolean toolCallsMatchAnyStep(AssistantMessage msg, List<String> remaining) {
            for (ToolCall tc : msg.getToolCalls()) {
                String combined = (tc.getName() != null ? tc.getName() : "")
                        + " " + (tc.getArguments() != null ? tc.getArguments() : "");
                String lower = combined.toLowerCase();
                for (String step : remaining) {
                    for (String word : step.split("[\\s，,]+")) {
                        if (word.length() >= 3 && lower.contains(word.toLowerCase())) {
                            return true;
                        }
                    }
                }
            }
            return false;
        }

        private boolean hasReplanCall(AssistantMessage msg) {
            if (msg.getToolCalls() == null) return false;
            return msg.getToolCalls().stream()
                    .anyMatch(tc -> ReplanTool.TOOL_NAME.equals(tc.getName()));
        }

        // ── Termination helpers ──

        /**
         * Augment criteria violations with contradiction signal.
         * KEY FIX for E1: contradiction makes the degraded result cite the
         * actual problem, not a coincidental keyword mismatch.
         */
        List<Violation> augmentViolations(List<Violation> violations) {
            if (contradictionDetected && violations.isEmpty()) {
                // Criteria passed BUT contradiction detected — add a synthetic violation
                List<Violation> augmented = new ArrayList<>(violations);
                augmented.add(new Violation.CriteriaNotCovered(
                        "answer_consistency",
                        "Contradiction: " + (contradictionDetail != null
                                ? contradictionDetail : "pass+fail signals")));
                return augmented;
            }
            return violations;
        }

        /**
         * Unified degradation decision. Considers:
         * 1. Device failure (from onToolException)
         * 2. Criteria violations
         * 3. Replan exhaustion
         * 4. Contradiction (E1 signal)
         */
        boolean shouldDegrade(List<Violation> violations, GoalSpec goal) {
            if (violations.isEmpty() && !contradictionDetected) {
                return false;
            }
            // Degrade if: replan exhausted OR device failure OR unrecoverable
            boolean replanExhausted = goal.replanCount() >= goal.maxReplanCount();
            boolean hasDeviceFailure = !failedTools.isEmpty();
            boolean hasUnrecoverable = contradictionDetected;

            return replanExhausted || hasDeviceFailure || hasUnrecoverable;
        }

        // ── Queries ──

        boolean hasPlan() {
            return planExtracted && !planSteps.isEmpty();
        }

        List<String> getRemainingSteps() {
            List<String> remaining = new ArrayList<>();
            for (String step : planSteps) {
                if (!completedSteps.contains(step)) {
                    remaining.add(step);
                }
            }
            return remaining;
        }

        String steeringMessage() {
            StringBuilder sb = new StringBuilder();
            sb.append("[PLAN PROGRESS] Completed: ");
            sb.append(completedSteps.isEmpty() ? "none" : String.join(", ", completedSteps));
            sb.append(" | Remaining: ");
            List<String> remaining = getRemainingSteps();
            sb.append(remaining.isEmpty() ? "none" : String.join(", ", remaining));
            if (contradictionDetected) {
                sb.append(" | WARNING: ").append(contradictionDetail);
            }
            if (deviationDetected) {
                sb.append(" | WARNING: ").append(deviationDetail);
            }
            return sb.toString();
        }

        public boolean contradictionDetected() {
            return contradictionDetected;
        }

        public boolean deviationDetected() {
            return deviationDetected;
        }

        void populateContext(Map<String, Object> result) {
            result.put(PLAN_STEPS_KEY, List.copyOf(planSteps));
            result.put(COMPLETED_STEPS_KEY, List.copyOf(completedSteps));
            if (contradictionDetected) {
                result.put(CONTRADICTION_KEY, true);
            }
        }
    }
}
