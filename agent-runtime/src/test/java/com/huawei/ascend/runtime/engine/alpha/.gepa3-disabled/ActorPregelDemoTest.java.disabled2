package com.huawei.ascend.runtime.engine.alpha.gepa3;

import com.openjiuwen.core.alpha.verifier.RootCause;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;

import java.util.Map;
import java.util.Set;
import java.util.concurrent.BlockingQueue;
import java.util.concurrent.LinkedBlockingQueue;

import static org.assertj.core.api.Assertions.assertThat;

/**
 * ActorPregelDemo 测试——验证所有 E1-E4 + Success 路径 和 review-suggested 边界情况。
 *
 * <p>测试组：
 * <ol>
 *   <li><b>E1 (Success)</b>: 所有工具通过 + 无内容错误 → COMPLETED（非 degraded）</li>
 *   <li><b>E2 (PlanOrAnswerError)</b>: 内容错误 → replan → 最终成功或 degrade</li>
 *   <li><b>E3 (DeviceFailure)</b>: 工具 FAILED → DeviceFailure → COMPLETED-degraded</li>
 *   <li><b>E4 (PerceptionUnreliable)</b>: ContentVerifier 抛异常 → verifierThrew → degrade</li>
 *   <li><b>E5 (ReplanExhausted)</b>: E2 路径 + retries 耗尽 → degrade</li>
 *   <li><b>Diagnosis 诊断纯函数</b>: 三态穷尽、纯函数性、优先级正确</li>
 *   <li><b>零锁证明</b>: Actor 用户代码零显式锁</li>
 *   <li><b>Actor 基础</b>: 消息传递、PoisonPill、BSP 屏障、phase guard</li>
 * </ol>
 */
@DisplayName("ActorPregelDemo — Actor模型全路径测试（P3+P6 review fixed）")
class ActorPregelDemoTest {

    // ========================================================================
    // 辅助
    // ========================================================================

    private static Map<String, Boolean> noFailures() {
        return Map.of("fetch_claim", false, "verify_coverage", false, "calc_payment", false);
    }

    private static Map<String, Boolean> verifyCoverageFails() {
        return Map.of("fetch_claim", false, "verify_coverage", true, "calc_payment", false);
    }

    // ========================================================================
    // E1 (Success) — all tools pass + no content errors
    // ========================================================================

    @Nested
    @DisplayName("E1 Success — 全节点通过 → COMPLETED（非降级）")
    class E1Success {

        @Test
        @DisplayName("所有工具 OK + 无内容错误 → COMPLETED 且 degraded=false")
        void allToolsPassShouldReturnCompletedNotDegraded() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor =
                    ActorPregelDemo.runE1Demonstration();

            assertThat(supervisor.degraded).isFalse();
            assertThat(supervisor.finalOutput)
                    .isNotNull()
                    .startsWith("COMPLETED:")
                    .doesNotContain("degraded");
            assertThat(supervisor.phase.name()).isEqualTo("DONE");
        }

        @Test
        @DisplayName("Success 终态包含所有结果键")
        void successTerminalContainsAllResultKeys() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor =
                    ActorPregelDemo.runE1Demonstration();

            assertThat(supervisor.finalOutput)
                    .contains("claim_info")
                    .contains("verify_policy")
                    .contains("calculate_payout");
        }

        @Test
        @DisplayName("Success 路径不触发 replan")
        void successPathShouldNotTriggerReplan() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor =
                    ActorPregelDemo.runE1Demonstration();

            assertThat(supervisor.finalOutput)
                    .doesNotContain("replan")
                    .doesNotContain("Replan")
                    .doesNotContain("retry");
        }

        @Test
        @DisplayName("TerminalRecord 正确记录非降级成功状态")
        void terminalRecordReflectsSuccess() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor =
                    ActorPregelDemo.runE1Demonstration();

            assertThat(supervisor.terminal).isNotNull();
            assertThat(supervisor.terminal.degraded()).isFalse();
            assertThat(supervisor.terminal.output()).startsWith("COMPLETED:");
            assertThat(supervisor.terminal.phase()).isEqualTo("DONE");
        }
    }

    // ========================================================================
    // E2 (PlanOrAnswerError) — content error → replan
    // ========================================================================

    @Nested
    @DisplayName("E2 PlanOrAnswerError — 内容错误 → Replan")
    class E2PlanOrAnswerError {

        @Test
        @DisplayName("ContentVerifier 返回错误节点 → PlanOrAnswerError → replan → 最终成功")
        void contentErrorShouldTriggerReplanThenSuccess() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor =
                    ActorPregelDemo.runE2Demonstration();

            assertThat(supervisor.finalOutput).isNotNull();
            // After replan, content verifier reports success (second call passes) → COMPLETED
            boolean reattempted = supervisor.finalOutput.startsWith("COMPLETED:")
                    || (supervisor.finalOutput.contains("COMPLETED-degraded")
                        && supervisor.finalOutput.contains("PlanOrAnswerError"));
            assertThat(reattempted).isTrue();
        }

        @Test
        @DisplayName("ContentVerifier 区分 E2（内容错误）与 E3（工具故障）")
        void contentErrorIsDistinctFromDeviceFailure() throws Exception {
            // Tools all pass (no FAILED: prefix), but content verifier flags calculate_payout
            ActorPregelDemo.SupervisorActor supervisor = ActorPregelDemo.runScenario(
                    "task-e2-distinct", "E2 distinct test", 2,
                    noFailures(),
                    results -> Set.of("calculate_payout"));

            // Should NOT be DeviceFailure (no FAILED: prefix in tool results)
            assertThat(supervisor.finalOutput).isNotNull();
            assertThat(supervisor.finalOutput).doesNotContain("DeviceFailure");
            assertThat(supervisor.finalOutput).contains("COMPLETED");
        }
    }

    // ========================================================================
    // E3 (DeviceFailure) — tool fails
    // ========================================================================

    @Nested
    @DisplayName("E3 DeviceFailure — 工具故障")
    class E3DeviceFailure {

        @Test
        @DisplayName("verify_coverage 返回 FAILED → DeviceFailure → COMPLETED-degraded")
        void toolReturnsFailedShouldTriggerDeviceFailureAndDegrade() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor =
                    ActorPregelDemo.runE3Demonstration();

            assertThat(supervisor.degraded).isTrue();
            assertThat(supervisor.finalOutput)
                    .isNotNull()
                    .contains("COMPLETED-degraded")
                    .contains("DeviceFailure")
                    .contains("verify_policy");
        }

        @Test
        @DisplayName("E3 降级输出包含失败节点标识")
        void degradedOutputShouldContainFailedNodeReference() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor =
                    ActorPregelDemo.runE3Demonstration();

            assertThat(supervisor.finalOutput)
                    .contains("verify_policy");
        }

        @Test
        @DisplayName("E3 不触发 replan — 设备故障 replan 无效")
        void deviceFailureShouldNotTriggerReplan() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor =
                    ActorPregelDemo.runE3Demonstration();

            assertThat(supervisor.finalOutput).doesNotContain("replan");
            assertThat(supervisor.finalOutput).doesNotContain("Replan");
        }

        @Test
        @DisplayName("TerminalRecord 正确记录降级状态")
        void terminalRecordReflectsDegradation() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor =
                    ActorPregelDemo.runE3Demonstration();

            assertThat(supervisor.terminal).isNotNull();
            assertThat(supervisor.terminal.degraded()).isTrue();
            assertThat(supervisor.terminal.phase()).isEqualTo("DONE");
        }
    }

    // ========================================================================
    // E4 (PerceptionUnreliable) — ContentVerifier throws
    // ========================================================================

    @Nested
    @DisplayName("E4 PerceptionUnreliable — Verifier 自身异常")
    class E4PerceptionUnreliable {

        @Test
        @DisplayName("ContentVerifier 抛异常 → PerceptionUnreliable → COMPLETED-degraded")
        void contentVerifierThrowsShouldTriggerPerceptionUnreliableAndDegrade() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor =
                    ActorPregelDemo.runE4Demonstration();

            assertThat(supervisor.degraded).isTrue();
            assertThat(supervisor.finalOutput)
                    .isNotNull()
                    .contains("COMPLETED-degraded")
                    .contains("PerceptionUnreliable");
        }

        @Test
        @DisplayName("E4 不触发 replan——verifier 不可信时不应重试")
        void perceptionUnreliableShouldNotTriggerReplan() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor =
                    ActorPregelDemo.runE4Demonstration();

            assertThat(supervisor.finalOutput)
                    .doesNotContain("replan")
                    .doesNotContain("Replan");
        }

        @Test
        @DisplayName("E4 降级——即使 maxRetries > 0 也直接降级")
        void perceptionUnreliableDegradesRegardlessOfBudget() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor = ActorPregelDemo.runScenario(
                    "task-e4-budget", "E4 budget test", 5,
                    noFailures(),
                    results -> { throw new RuntimeException("verifier crash"); });

            assertThat(supervisor.degraded).isTrue();
            assertThat(supervisor.finalOutput).contains("PerceptionUnreliable");
            assertThat(supervisor.finalOutput).doesNotContain("retries exhausted");
        }
    }

    // ========================================================================
    // E5 (ReplanExhausted) — retries exhausted after E2
    // ========================================================================

    @Nested
    @DisplayName("E5 ReplanExhausted — 重试预算耗尽")
    class E5ReplanExhausted {

        @Test
        @DisplayName("ContentVerifier 持续返回错误 + maxRetries=0 → retries exhausted")
        void contentAlwaysWrongWithZeroBudgetShouldExhaustRetries() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor = ActorPregelDemo.runScenario(
                    "task-e5-zero", "E5 zero budget", 0,
                    noFailures(),
                    results -> Set.of("calculate_payout"));

            assertThat(supervisor.degraded).isTrue();
            assertThat(supervisor.finalOutput)
                    .contains("COMPLETED-degraded")
                    .contains("retries exhausted");
        }

        @Test
        @DisplayName("ContentVerifier 持续返回错误 + maxRetries=1 → first retry exhausts")
        void contentAlwaysWrongWithBudgetOneExhausts() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor = ActorPregelDemo.runScenario(
                    "task-e5-one", "E5 budget 1", 1,
                    noFailures(),
                    results -> Set.of("calculate_payout")); // always wrong

            assertThat(supervisor.degraded).isTrue();
            assertThat(supervisor.finalOutput)
                    .contains("retries exhausted");
        }

        @Test
        @DisplayName("E5 降级输出包含失败节点引用")
        void exhaustedOutputContainsFailedNodeReference() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor = ActorPregelDemo.runScenario(
                    "task-e5-ref", "E5 ref", 0,
                    noFailures(),
                    results -> Set.of("calculate_payout"));

            assertThat(supervisor.finalOutput).contains("calculate_payout");
        }
    }

    // ========================================================================
    // 跨路径对比
    // ========================================================================

    @Nested
    @DisplayName("跨路径对比 — 不同根因 = 不同终端行为")
    class CrossScenarioComparison {

        @Test
        @DisplayName("E3 (DeviceFailure) 与 E4 (PerceptionUnreliable) 都不触发 replan")
        void deviceFailureAndPerceptionUnreliableBothDegradeWithoutReplan() throws Exception {
            ActorPregelDemo.SupervisorActor e3 = ActorPregelDemo.runE3Demonstration();
            ActorPregelDemo.SupervisorActor e4 = ActorPregelDemo.runE4Demonstration();

            assertThat(e3.finalOutput).contains("DeviceFailure");
            assertThat(e4.finalOutput).contains("PerceptionUnreliable");

            assertThat(e3.finalOutput).doesNotContain("replan");
            assertThat(e4.finalOutput).doesNotContain("replan");

            assertThat(e3.degraded).isTrue();
            assertThat(e4.degraded).isTrue();
        }

        @Test
        @DisplayName("Success 是唯一非降级的终止状态")
        void successIsTheOnlyNonDegradedTerminal() throws Exception {
            ActorPregelDemo.SupervisorActor e1 = ActorPregelDemo.runE1Demonstration();
            ActorPregelDemo.SupervisorActor e2 = ActorPregelDemo.runE2Demonstration();
            ActorPregelDemo.SupervisorActor e3 = ActorPregelDemo.runE3Demonstration();
            ActorPregelDemo.SupervisorActor e4 = ActorPregelDemo.runE4Demonstration();

            assertThat(e1.degraded).isFalse();
            // E3 and E4 always degrade; E2 may succeed after replan
            assertThat(e3.degraded).isTrue();
            assertThat(e4.degraded).isTrue();
        }
    }

    // ========================================================================
    // DiagnoseRootCause — 诊断纯函数
    // ========================================================================

    @Nested
    @DisplayName("DiagnoseRootCause — 诊断纯函数")
    class DiagnoseRootCause {

        @Test
        @DisplayName("Priority 1: verifyThrew → PerceptionUnreliable（覆盖所有其他信号）")
        void verifyThrewShouldOverrideEverything() {
            RootCause cause = ActorPregelDemo.VerifyActor.diagnoseRootCause(
                    Set.of("node-a"), true, Set.of("node-a"), Set.of());
            assertThat(cause).isInstanceOf(RootCause.PerceptionUnreliable.class);
            assertThat(((RootCause.PerceptionUnreliable) cause).verifierThrew()).isTrue();
        }

        @Test
        @DisplayName("Priority 2: verifyFailed ∩ execFailed ≠ ∅ → DeviceFailure")
        void intersectionWithExecFailedShouldBeDeviceFailure() {
            RootCause cause = ActorPregelDemo.VerifyActor.diagnoseRootCause(
                    Set.of("verify_policy", "claim_info"), false,
                    Set.of("verify_policy"), Set.of());
            assertThat(cause).isInstanceOf(RootCause.DeviceFailure.class);
            assertThat(((RootCause.DeviceFailure) cause).nodes())
                    .contains("verify_policy")
                    .doesNotContain("claim_info"); // claim_info NOT in execFailed, excluded from intersection
        }

        @Test
        @DisplayName("Priority 2: execSkipped 交集也算 DeviceFailure")
        void intersectionWithSkippedAlsoDeviceFailure() {
            RootCause cause = ActorPregelDemo.VerifyActor.diagnoseRootCause(
                    Set.of("skipped_node"), false, Set.of(), Set.of("skipped_node"));
            assertThat(cause).isInstanceOf(RootCause.DeviceFailure.class);
        }

        @Test
        @DisplayName("Priority 3 (fallback): 无 verifyThrew 且无设备交集 → PlanOrAnswerError")
        void noDeviceSignalAndNoThrowShouldBePlanOrAnswerError() {
            RootCause cause = ActorPregelDemo.VerifyActor.diagnoseRootCause(
                    Set.of("answer_node"), false, Set.of("other_node"), Set.of());
            assertThat(cause).isInstanceOf(RootCause.PlanOrAnswerError.class);
            assertThat(((RootCause.PlanOrAnswerError) cause).nodes())
                    .contains("answer_node");
        }

        @Test
        @DisplayName("诊断函数是纯函数——相同输入 → 相同输出")
        void diagnoseRootCauseIsPureFunction() {
            Set<String> failed = Set.of("n1", "n2");
            Set<String> execFailed = Set.of("n1");
            Set<String> execSkipped = Set.of();

            RootCause first = ActorPregelDemo.VerifyActor.diagnoseRootCause(
                    failed, false, execFailed, execSkipped);
            RootCause second = ActorPregelDemo.VerifyActor.diagnoseRootCause(
                    failed, false, execFailed, execSkipped);

            assertThat(first).isEqualTo(second);
            assertThat(first).isInstanceOf(RootCause.DeviceFailure.class);
        }

        @Test
        @DisplayName("三态穷尽——只返回三种 sealed 子类型")
        void diagnoseRootCauseReturnsOnlyThreeSealedSubtypes() {
            var p1 = ActorPregelDemo.VerifyActor.diagnoseRootCause(
                    Set.of(), true, Set.of(), Set.of());
            assertThat(p1).isInstanceOf(RootCause.PerceptionUnreliable.class);

            var p2 = ActorPregelDemo.VerifyActor.diagnoseRootCause(
                    Set.of("n1"), false, Set.of("n1"), Set.of());
            assertThat(p2).isInstanceOf(RootCause.DeviceFailure.class);

            var p3 = ActorPregelDemo.VerifyActor.diagnoseRootCause(
                    Set.of("n1"), false, Set.of(), Set.of());
            assertThat(p3).isInstanceOf(RootCause.PlanOrAnswerError.class);
        }

        @Test
        @DisplayName("空 verifyFailed + 无 verifyThrew → PlanOrAnswerError(empty)")
        void emptyVerifyFailedNoThrowReturnsPlanOrAnswerErrorEmpty() {
            RootCause cause = ActorPregelDemo.VerifyActor.diagnoseRootCause(
                    Set.of(), false, Set.of(), Set.of());
            assertThat(cause).isInstanceOf(RootCause.PlanOrAnswerError.class);
            assertThat(((RootCause.PlanOrAnswerError) cause).nodes()).isEmpty();
        }
    }

    // ========================================================================
    // ContentVerifier 功能验证
    // ========================================================================

    @Nested
    @DisplayName("ContentVerifier SPI")
    class ContentVerifierTests {

        @Test
        @DisplayName("NO_CONTENT_CHECK 是空实现（恒返回空集）")
        void noContentCheckReturnsEmptySet() {
            Set<String> result = ActorPregelDemo.NO_CONTENT_CHECK
                    .verifyContent(Map.of("a", "OK", "b", "FAILED: something"));
            assertThat(result).isEmpty();
        }

        @Test
        @DisplayName("ContentVerifier 可访问所有节点结果")
        void contentVerifierReceivesAllNodeResults() {
            Map<String, String> expected = Map.of("a", "OK", "b", "OK", "c", "OK");
            ActorPregelDemo.ContentVerifier verifier = results -> {
                assertThat(results).containsAllEntriesOf(expected);
                return Set.of();
            };
            verifier.verifyContent(expected);
        }

        @Test
        @DisplayName("ContentVerifier 返回非空 → 内容错误存在")
        void nonEmptyReturnMeansContentErrors() {
            ActorPregelDemo.ContentVerifier verifier = results -> Set.of("bad_a", "bad_b");
            assertThat(verifier.verifyContent(Map.of())).containsExactlyInAnyOrder("bad_a", "bad_b");
        }
    }

    // ========================================================================
    // 零锁证明
    // ========================================================================

    @Nested
    @DisplayName("零锁证明")
    class ZeroLocks {

        @Test
        @DisplayName("SupervisorActor 字段无 ReentrantLock/AtomicBoolean/ConcurrentHashMap")
        void supervisorHasNoSharedMemoryLocks() {
            Class<?> cls = ActorPregelDemo.SupervisorActor.class;
            for (var field : cls.getDeclaredFields()) {
                String typeName = field.getType().getName();
                assertThat(typeName)
                        .as("SupervisorActor 字段 %s 不应是锁类型", field.getName())
                        .doesNotContain("ReentrantLock")
                        .doesNotContain("AtomicBoolean")
                        .doesNotContain("AtomicInteger")
                        .doesNotContain("ConcurrentHashMap")
                        .doesNotContain("CopyOnWrite");
            }
        }

        @Test
        @DisplayName("PlanActor 字段不包含锁类型")
        void planActorHasNoLocks() {
            Class<?> cls = ActorPregelDemo.PlanActor.class;
            for (var field : cls.getDeclaredFields()) {
                String typeName = field.getType().getName();
                assertThat(typeName)
                        .as("PlanActor 字段 %s 不应是锁", field.getName())
                        .doesNotContain("ReentrantLock")
                        .doesNotContain("Atomic")
                        .doesNotContain("ConcurrentHashMap");
            }
        }

        @Test
        @DisplayName("ExecuteActor 字段不包含锁类型")
        void executeActorHasNoLocks() {
            Class<?> cls = ActorPregelDemo.ExecuteActor.class;
            for (var field : cls.getDeclaredFields()) {
                String typeName = field.getType().getName();
                assertThat(typeName)
                        .as("ExecuteActor 字段 %s 不应是锁", field.getName())
                        .doesNotContain("ReentrantLock")
                        .doesNotContain("Atomic")
                        .doesNotContain("ConcurrentHashMap");
            }
        }

        @Test
        @DisplayName("VerifyActor 字段不包含锁类型")
        void verifyActorHasNoLocks() {
            Class<?> cls = ActorPregelDemo.VerifyActor.class;
            for (var field : cls.getDeclaredFields()) {
                String typeName = field.getType().getName();
                assertThat(typeName)
                        .as("VerifyActor 字段 %s 不应是锁", field.getName())
                        .doesNotContain("ReentrantLock")
                        .doesNotContain("Atomic")
                        .doesNotContain("ConcurrentHashMap");
            }
        }

        @Test
        @DisplayName("所有不可变消息类型都是 record")
        void allMessagesAreRecords() {
            assertThat(ActorPregelDemo.PlanRequest.class.isRecord()).isTrue();
            assertThat(ActorPregelDemo.PlanResponse.class.isRecord()).isTrue();
            assertThat(ActorPregelDemo.ExecuteLayer.class.isRecord()).isTrue();
            assertThat(ActorPregelDemo.LayerResult.class.isRecord()).isTrue();
            assertThat(ActorPregelDemo.VerifyRequest.class.isRecord()).isTrue();
            assertThat(ActorPregelDemo.VerifyResponse.class.isRecord()).isTrue();
            assertThat(ActorPregelDemo.ToolCallRequest.class.isRecord()).isTrue();
            assertThat(ActorPregelDemo.ToolCallResponse.class.isRecord()).isTrue();
            assertThat(ActorPregelDemo.PoisonPill.class.isRecord()).isTrue();
        }

        @Test
        @DisplayName("Actor 模型消除共享内存三并发结构")
        void actorModelEliminatesThreeSharedMemoryPatterns() throws Exception {
            // Load classes by running a scenario
            ActorPregelDemo.runE1Demonstration();

            Class<?>[] actorClasses = {
                    ActorPregelDemo.SupervisorActor.class,
                    ActorPregelDemo.PlanActor.class,
                    ActorPregelDemo.ExecuteActor.class,
                    ActorPregelDemo.VerifyActor.class
            };

            for (Class<?> cls : actorClasses) {
                boolean hasLock = false;
                for (var field : cls.getDeclaredFields()) {
                    String typeName = field.getType().getName();
                    if (typeName.contains("ReentrantLock")
                            || typeName.contains("AtomicBoolean")
                            || typeName.contains("AtomicInteger")
                            || typeName.contains("ConcurrentHashMap")
                            || typeName.contains("CopyOnWrite")) {
                        hasLock = true;
                        break;
                    }
                }
                assertThat(hasLock)
                        .as("%s 不应包含共享内存并发原语", cls.getSimpleName())
                        .isFalse();
            }
        }
    }

    // ========================================================================
    // Actor 模型基础行为
    // ========================================================================

    @Nested
    @DisplayName("Actor 模型基础")
    class ActorBasics {

        @Test
        @DisplayName("消息通过 BlockingQueue inbox 传递——非共享内存")
        void messagesPassViaInboxes() throws Exception {
            BlockingQueue<Object> inbox = new LinkedBlockingQueue<>();
            // PlanRequest now takes 3 args (taskId, goal, failureContext)
            ActorPregelDemo.PlanRequest req = new ActorPregelDemo.PlanRequest(
                    "task-1", "test goal", null);
            inbox.put(req);

            Object received = inbox.poll(1, java.util.concurrent.TimeUnit.SECONDS);
            assertThat(received).isInstanceOf(ActorPregelDemo.PlanRequest.class);
            assertThat(((ActorPregelDemo.PlanRequest) received).taskId()).isEqualTo("task-1");
            assertThat(((ActorPregelDemo.PlanRequest) received).failureContext()).isNull();
        }

        @Test
        @DisplayName("PlanRequest 携带 failureContext 用于 replan 提示")
        void planRequestCarriesFailureContextForReplanHints() {
            ActorPregelDemo.PlanRequest req = new ActorPregelDemo.PlanRequest(
                    "task-1", "goal", "上次失败: [node-a]");
            assertThat(req.failureContext()).isEqualTo("上次失败: [node-a]");
        }

        @Test
        @DisplayName("PoisonPill 使 Actor 优雅退出")
        void poisonPillStopsActor() throws Exception {
            BlockingQueue<Object> inbox = new LinkedBlockingQueue<>();
            BlockingQueue<Object> dummySupervisorInbox = new LinkedBlockingQueue<>();
            ActorPregelDemo.PlanActor actor = new ActorPregelDemo.PlanActor(
                    "test-planner", inbox, dummySupervisorInbox);

            Thread actorThread = new Thread(actor, "test-actor");
            actorThread.start();

            inbox.put(new ActorPregelDemo.PoisonPill());

            actorThread.join(5_000);
            assertThat(actorThread.isAlive()).isFalse();
        }

        @Test
        @DisplayName("BSP 屏障 — 层按顺序执行，不合并")
        void bspBarrierLayersExecuteSequentially() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor =
                    ActorPregelDemo.runE1Demonstration();

            // All 3 layers complete independently (BSP barrier enforced)
            assertThat(supervisor.finalOutput)
                    .contains("claim_info")
                    .contains("verify_policy")
                    .contains("calculate_payout");
        }

        @Test
        @DisplayName("Supervisor phase guard 阻止非 PLAN 阶段的 PlanResponse")
        void phaseGuardRejectsPlanResponseInWrongPhase() throws Exception {
            // The Supervisor's handlePlanResponse checks phase == Phase.PLAN.
            // After a normal run, phase is DONE, so a late PlanResponse would be ignored.
            ActorPregelDemo.runE1Demonstration();
            // Test passes if phase guard doesn't crash — it's a structural invariant
        }
    }

    // ========================================================================
    // runScenario() 参数化测试
    // ========================================================================

    @Nested
    @DisplayName("runScenario — 通用运行器")
    class RunScenario {

        @Test
        @DisplayName("runScenario 所有参数可配置")
        void runScenarioAllParametersConfigurable() throws Exception {
            ActorPregelDemo.SupervisorActor supervisor = ActorPregelDemo.runScenario(
                    "custom-task", "custom goal", 3,
                    Map.of("fetch_claim", false, "verify_coverage", false, "calc_payment", false),
                    ActorPregelDemo.NO_CONTENT_CHECK);

            assertThat(supervisor.degraded).isFalse();
            assertThat(supervisor.finalOutput).startsWith("COMPLETED:");
            assertThat(supervisor.phase.name()).isEqualTo("DONE");
        }

        @Test
        @DisplayName("maxRetries=5 时 E2 可多次 replan")
        void highRetryBudgetAllowsMultipleReplans() throws Exception {
            java.util.concurrent.atomic.AtomicInteger calls = new java.util.concurrent.atomic.AtomicInteger(0);
            ActorPregelDemo.SupervisorActor supervisor = ActorPregelDemo.runScenario(
                    "high-retry", "high retry test", 5,
                    noFailures(),
                    results -> {
                        int c = calls.incrementAndGet();
                        if (c <= 3) return Set.of("calculate_payout");
                        return Set.of(); // success on 4th try
                    });

            assertThat(supervisor.finalOutput).startsWith("COMPLETED:");
            assertThat(supervisor.degraded).isFalse();
        }

        @Test
        @DisplayName("Bounded inboxes 容量 256 不导致消息丢失")
        void boundedInboxesDoNotLoseMessages() throws Exception {
            // Running E1 (most messages) with 3 layers × 3 nodes = reasonable load
            ActorPregelDemo.SupervisorActor supervisor =
                    ActorPregelDemo.runE1Demonstration();

            assertThat(supervisor.degraded).isFalse();
            assertThat(supervisor.finalOutput).doesNotContain("TIMEOUT");
        }
    }
}
