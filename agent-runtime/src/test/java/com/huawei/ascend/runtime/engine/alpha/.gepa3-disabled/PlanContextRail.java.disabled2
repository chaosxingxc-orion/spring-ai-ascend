package com.huawei.ascend.runtime.engine.alpha.gepa3;

import com.openjiuwen.core.foundation.llm.schema.AssistantMessage;
import com.openjiuwen.core.foundation.llm.schema.ToolCall;
import com.openjiuwen.core.singleagent.rail.AgentCallbackContext;
import com.openjiuwen.core.singleagent.rail.AgentRail;
import com.openjiuwen.core.singleagent.rail.ModelCallInputs;
import com.openjiuwen.core.singleagent.rail.ToolCallInputs;

import java.util.ArrayList;
import java.util.LinkedHashMap;
import java.util.LinkedHashSet;
import java.util.List;
import java.util.Map;
import java.util.Set;
import java.util.regex.Pattern;

/**
 * P2 PROTOTYPE: PlanContextRail -- maintains plan step context for single-track ReActAgent.
 *
 * <p>This rail tracks a human-readable plan (list of step descriptions) and which
 * steps have been completed, injecting progress context into each model call via
 * {@code pushSteering}.  It does NOT generate plans; it observes and reports.
 *
 * <h3>What this rail CAN do</h3>
 * <ul>
 *   <li><b>Extract plan</b>: parse step-like lines from agent model responses
 *       (heuristic: lines matching "Step N:" / "1." / numbered patterns).</li>
 *   <li><b>Track progress</b>: when a tool call name or arguments match a plan step
 *       keyword, mark that step as completed.</li>
 *   <li><b>Inject context</b>: before each model call, push a steering message
 *       showing completed/remaining steps.</li>
 *   <li><b>Detect contradictions</b> (E1 signal): when final answer contains both
 *       pass and fail signals simultaneously.</li>
 *   <li><b>Detect plan deviation</b> (E2 signal): when agent tool calls
 *       don't match any plan step.</li>
 *   <li><b>Record failures</b> (E3 signal): mark steps failed when tool results
 *       contain error signals.</li>
 * </ul>
 *
 * <h3>Honest admission -- what this rail CANNOT do</h3>
 * <ul>
 *   <li><b>Verify answer correctness</b> -- CriteriaVerificationRail's job.</li>
 *   <li><b>Handle device failures</b> -- RootCauseRail's job (this rail only records).</li>
 *   <li><b>Trigger replan</b> -- ReplanRail's job.</li>
 *   <li><b>Semantic plan understanding</b> -- extraction is regex/heuristic.</li>
 *   <li><b>Chinese-to-English semantic matching</b> -- keyword overlap works for
 *       Latin-alphabet tool names but CJK plan steps require embedded Latin keywords
 *       or Chinese tool names. Pure-CJK plan steps with English tool names are
 *       structurally unmatchable via keyword heuristics.</li>
 *   <li><b>Multi-agent coordination</b> -- single-kernel limitation (defer P3).</li>
 *   <li><b>Ground truth verification</b> -- needs external GroundTruthVerifier.</li>
 * </ul>
 *
 * <h3>E1-E4 mapping in this rail</h3>
 * <table>
 *   <tr><th>Error</th><th>Rail role</th><th>Other rails involved</th></tr>
 *   <tr><td>E1 PerceptionUnreliable</td><td>Detects context contradiction</td>
 *       <td>CriteriaVerificationRail (verify gate)</td></tr>
 *   <tr><td>E2 PlanOrAnswerError</td><td>Detects plan deviation</td>
 *       <td>ReplanRail + CriteriaVerificationRail</td></tr>
 *   <tr><td>E3 DeviceFailure</td><td>Records tool failure in step tracking</td>
 *       <td>RootCauseRail (primary handler)</td></tr>
 *   <tr><td>E4 ReplanExhausted</td><td>Reports last-known plan state</td>
 *       <td>ReplanRail + CriteriaVerificationRail</td></tr>
 * </table>
 *
 * <p><b>Bug fixes applied (2026-07-01):</b>
 * <ul>
 *   <li>B2: Chinese substring false positive -- check negative patterns before
 *       removing negative-prefixed phrases from positive check.</li>
 *   <li>B3: Deviation fires on legitimate tool calls -- check against ALL plan
 *       steps (not just remaining) and check BEFORE matchAndCompleteStep.</li>
 *   <li>B4: Short-word false matches -- raised min word length from 3 to 4,
 *       filtering common 3-char noise words.</li>
 *   <li>B5: Chinese step matching broken -- added CJK character bigram matching
 *       as fallback for steps with no Latin keywords.</li>
 *   <li>Bug 5: deviationDetail never cleared -- cleared when next response
 *       matches plan steps.</li>
 *   <li>Bug 6: extractPlanSteps single-shot -- re-extraction allowed when
 *       __replan__ signal detected.</li>
 *   <li>B1/Bug 8: markStepFailed no-op -- now records failed steps in a
 *       tracked set, exposed via planContextMap().</li>
 *   <li>Bug 10: CopyOnWriteArrayList overhead -- replaced with ArrayList
 *       (single-threaded ReActAgent loop).</li>
 * </ul>
 *
 * @author P2 ReAct single-track prototype (2026-07-01)
 */
public class PlanContextRail extends AgentRail {

    public static final String PLAN_CONTEXT_KEY = "plan_context";
    public static final String PLAN_STEPS_KEY = "plan_steps";
    public static final String COMPLETED_STEPS_KEY = "completed_steps";
    public static final String REMAINING_STEPS_KEY = "remaining_steps";
    public static final String FAILED_STEPS_KEY = "failed_steps";
    public static final String PLAN_DEVIATION_KEY = "plan_deviation_detected";
    public static final String PERCEPTION_UNRELIABLE_KEY = "perception_unreliable_signal";

    // Word-boundary patterns for English contradiction detection.
    // \bpass matches "pass"/"passes"/"passed" but not "bypass"/"compass".
    // \bfail matches "fail"/"fails"/"failed"/"failure" but not "unfailing".
    private static final Pattern PASS_PATTERN =
            Pattern.compile("\\bpass", Pattern.CASE_INSENSITIVE);
    private static final Pattern FAIL_PATTERN =
            Pattern.compile("\\bfail", Pattern.CASE_INSENSITIVE);

    /** Minimum English word length for step-keyword matching.
     *  Raised from 3 (original) to 4 to filter most stopwords
     *  ("the"/"and"/"for") while keeping meaningful short words
     *  ("data"/"risk"/"user"/"file"/"code"/"test"/"name"/"type"). */
    private static final int MIN_WORD_LENGTH = 4;

    // --------------- state ---------------

    /** All plan steps extracted from model responses (ArrayList for single-threaded loop). */
    private final List<String> planSteps = new ArrayList<>();

    /** Steps marked as completed via tool-call keyword matching. */
    private final List<String> completedSteps = new ArrayList<>();

    /** Steps that failed (from afterToolCall error-result detection). */
    private final Set<String> failedSteps = new LinkedHashSet<>();

    private boolean planExtracted;
    private String contradictionDetail;
    private String deviationDetail;

    // --------------- accessors ---------------

    public List<String> planSteps() {
        return List.copyOf(planSteps);
    }

    public List<String> completedSteps() {
        return List.copyOf(completedSteps);
    }

    public Set<String> failedSteps() {
        return Set.copyOf(failedSteps);
    }

    public boolean isPlanExtracted() {
        return planExtracted;
    }

    public String contradictionDetail() {
        return contradictionDetail;
    }

    public String deviationDetail() {
        return deviationDetail;
    }

    // --------------- rail hooks ---------------

    @Override
    public void afterModelCall(AgentCallbackContext context) {
        if (!(context.getInputs() instanceof ModelCallInputs inputs)) {
            return;
        }
        if (!(inputs.getResponse() instanceof AssistantMessage msg)) {
            return;
        }

        // Allow re-extraction when replanning (fixes Bug 6: single-shot extraction)
        if (planExtracted && hasReplanSignal(msg)) {
            planExtracted = false;
            planSteps.clear();
            completedSteps.clear();
            failedSteps.clear();
            deviationDetail = null;
        }

        if (!planExtracted) {
            extractPlanSteps(msg);
        }

        // Check deviation BEFORE matching (fixes B3: now checks against ALL plan steps,
        // not just remaining -- a tool call matching any step, even a completed one,
        // is not deviation. Repetition is a separate concern.)
        if (msg.getToolCalls() != null && !msg.getToolCalls().isEmpty()) {
            checkForDeviation(msg);
            // Clear stale deviation when next response recovers (fixes Bug 5)
            if (deviationDetail != null && anyToolCallMatchesAnyPlanStep(msg)) {
                deviationDetail = null;
            }
        }

        // Match and complete steps (skip meta-tools like __replan__)
        if (msg.getToolCalls() != null) {
            for (ToolCall tc : msg.getToolCalls()) {
                if (isReplanTool(tc)) continue;
                matchAndCompleteStep(tc.getName());
                if (tc.getArguments() != null) {
                    matchAndCompleteStep(tc.getArguments());
                }
            }
        }

        // Contradiction detection on final answers (E1 signal)
        if (isFinalAnswer(msg)) {
            checkForContradiction(msg);
        }
    }

    @Override
    public void afterToolCall(AgentCallbackContext context) {
        if (!(context.getInputs() instanceof ToolCallInputs inputs)) {
            return;
        }
        String toolName = inputs.getToolName();
        Object result = inputs.getToolResult();
        if (result != null && toolName != null) {
            String resultStr = String.valueOf(result);
            if (resultStr.contains("error") || resultStr.contains("失败")
                    || resultStr.contains("不可用") || resultStr.contains("unavailable")
                    || resultStr.contains("timeout") || resultStr.contains("超时")) {
                markStepFailed(toolName);
            }
        }
    }

    @Override
    public void beforeModelCall(AgentCallbackContext context) {
        if (!planExtracted || planSteps.isEmpty()) {
            return;
        }
        if (!context.hasSteeringQueue()) {
            return;
        }

        StringBuilder steering = new StringBuilder();
        steering.append("[PLAN PROGRESS] ");
        steering.append("Completed: ");
        steering.append(completedSteps.isEmpty() ? "none" : String.join(", ", completedSteps));
        steering.append(" | Remaining: ");
        List<String> remaining = getRemainingSteps();
        steering.append(remaining.isEmpty() ? "none" : String.join(", ", remaining));

        if (!failedSteps.isEmpty()) {
            steering.append(" | FAILED: ").append(String.join(", ", failedSteps));
        }
        if (contradictionDetail != null) {
            steering.append(" | WARNING: contradiction -- ").append(contradictionDetail);
        }
        if (deviationDetail != null) {
            steering.append(" | WARNING: deviation -- ").append(deviationDetail);
        }

        context.pushSteering(steering.toString());
    }

    // --------------- public introspection (for tests / cross-rail) ---------------

    public Map<String, Object> planContextMap() {
        Map<String, Object> map = new LinkedHashMap<>();
        map.put("plan_steps", List.copyOf(planSteps));
        map.put("completed_steps", List.copyOf(completedSteps));
        map.put("failed_steps", Set.copyOf(failedSteps));
        map.put("remaining_steps", getRemainingSteps());
        map.put("plan_extracted", planExtracted);
        if (contradictionDetail != null) {
            map.put(PERCEPTION_UNRELIABLE_KEY, true);
            map.put("contradiction_detail", contradictionDetail);
        }
        if (deviationDetail != null) {
            map.put(PLAN_DEVIATION_KEY, true);
            map.put("deviation_detail", deviationDetail);
        }
        return map;
    }

    // =============== private internals ===============

    // --------------- plan extraction ---------------

    /**
     * Parse step-like lines from the model response.
     * Recognises: "Step N: ...", "N. ...", "&#x7B2C;N&#x6B65;&#xFF1A;...", "N&#x3001;...", "N) ..."
     */
    private void extractPlanSteps(AssistantMessage msg) {
        String content = contentOf(msg);
        if (content == null || content.isBlank()) {
            return;
        }

        List<String> extracted = new ArrayList<>();
        for (String line : content.split("\\n")) {
            String trimmed = line.trim();
            if (trimmed.isEmpty()) continue;

            if (trimmed.matches("(?i)^Step\\s*\\d+[.:].*")
                    || trimmed.matches("^\\d+\\.[\\s].*")
                    || trimmed.matches("^第\\s*\\d+\\s*步[：:].*")
                    || trimmed.matches("^\\d+[、)][\\s].*")) {
                String stepDesc = trimmed.replaceFirst(
                        "^(?i)(Step\\s*\\d+[.:]\\s*|\\d+\\.[\\s]*|第\\s*\\d+\\s*步[：:]\\s*|\\d+[、)][\\s]*)",
                        "").trim();
                if (!stepDesc.isEmpty()) {
                    extracted.add(stepDesc);
                }
            }
        }

        if (!extracted.isEmpty()) {
            planSteps.addAll(extracted);
            planExtracted = true;
        }
    }

    // --------------- step completion matching ---------------

    /**
     * Attempt to match tool-name or tool-arguments text against an incomplete
     * plan step.  Uses keyword overlap with MIN_WORD_LENGTH threshold for
     * Latin text; falls back to CJK character bigram matching for steps
     * containing Chinese characters.
     *
     * <p>Fix B4: raised threshold from 3 to 4.
     * Fix B5: added CJK bigram fallback.
     */
    private void matchAndCompleteStep(String text) {
        if (text == null || text.isBlank()) return;
        String lower = text.toLowerCase();
        for (String step : planSteps) {
            if (completedSteps.contains(step) || failedSteps.contains(step)) continue;
            if (stepMatchesText(step, lower)) {
                completedSteps.add(step);
                break;  // one step per match call
            }
        }
    }

    /** Returns true if {@code textLower} contains keywords from {@code step}. */
    private boolean stepMatchesText(String step, String textLower) {
        // Try Latin keyword matching first (works for both English steps
        // and Chinese steps that embed Latin terms like "API" / "SQL")
        String[] words = step.split("[\\s，,]+");
        boolean hasLatinMatch = false;
        for (String word : words) {
            if (word.length() >= MIN_WORD_LENGTH
                    && textLower.contains(word.toLowerCase())) {
                hasLatinMatch = true;
                break;
            }
        }
        if (hasLatinMatch) return true;

        // If step contains CJK characters AND textLower also contains CJK,
        // try bigram overlap as fallback (fixes B5)
        if (containsCJK(step) && containsCJK(textLower)) {
            return cjkBigramOverlap(step, textLower) >= 0.4;
        }

        return false;
    }

    // --------------- failure tracking ---------------

    /**
     * Record which plan step this failing tool was attempting.
     * Fixes B1/Bug 8: previously a no-op comment.
     */
    private void markStepFailed(String toolName) {
        String lower = toolName.toLowerCase();
        for (String step : planSteps) {
            if (completedSteps.contains(step) || failedSteps.contains(step)) continue;
            if (stepMatchesText(step, lower)) {
                failedSteps.add(step);
                return;
            }
        }
        // No specific step matched -- record tool name as fallback
        failedSteps.add("tool:" + toolName);
    }

    // --------------- contradiction detection (E1) ---------------

    /**
     * Detect when a final answer contains both pass and fail signals.
     *
     * <p>Fix B2: Chinese negative-prefixed phrases ("不满足"/"不符合"/"不通过")
     * previously triggered both hasPass (substring "满足") AND hasFail.
     * Now: negative patterns checked first; then negative-prefixed phrases are
     * scrubbed before positive-pattern check.
     */
    private void checkForContradiction(AssistantMessage msg) {
        String content = contentOf(msg);
        if (content == null) return;
        String lower = content.toLowerCase();

        // Negative signals (check original text -- these are unambiguous)
        boolean hasNegative = FAIL_PATTERN.matcher(lower).find()
                || lower.contains("不满足") || lower.contains("不符合")
                || lower.contains("不通过") || lower.contains("无法")
                || lower.contains("不能");

        // Positive signals (check text with negative-prefixed phrases removed
        // to avoid "不满足" matching as "满足")
        String cleaned = lower
                .replace("不满足", "___NEG___")
                .replace("不符合", "___NEG___")
                .replace("不通过", "___NEG___");
        boolean hasPositive = PASS_PATTERN.matcher(cleaned).find()
                || cleaned.contains("通过") || cleaned.contains("满足")
                || cleaned.contains("符合");

        if (hasPositive && hasNegative) {
            contradictionDetail = "Final answer contains both pass and fail signals -- "
                    + "possible perception ambiguity";
        }
    }

    // --------------- deviation detection (E2) ---------------

    /**
     * Detect when tool calls don't match any plan step.
     *
     * <p>Fix B3: checks against ALL plan steps (not just remaining),
     * so a correctly sequenced tool call matching any step is never
     * flagged.  Also runs BEFORE matchAndCompleteStep so the check
     * sees the tool call against the full plan.
     *
     * <p>Edge case handled: if no plan was ever extracted, deviation
     * is not checked (can't deviate from nothing).
     */
    private void checkForDeviation(AssistantMessage msg) {
        if (planSteps.isEmpty()) {
            return;  // no plan extracted → deviation N/A
        }

        List<String> remaining = getRemainingSteps();
        boolean allStepsDone = remaining.isEmpty();

        if (msg.getToolCalls() != null) {
            boolean anyMatch = false;
            for (ToolCall tc : msg.getToolCalls()) {
                if (toolCallMatchesAnyStep(tc, planSteps)) {  // ALL steps, not remaining
                    anyMatch = true;
                    break;
                }
            }
            if (!anyMatch) {
                if (allStepsDone) {
                    deviationDetail = "All plan steps appear completed but agent continues "
                            + "making tool calls that do not match any plan step -- possible drift";
                } else {
                    deviationDetail = "Tool calls do not match any plan step -- "
                            + "remaining: " + String.join(", ", remaining);
                }
            }
        }
    }

    // --------------- helpers ---------------

    private List<String> getRemainingSteps() {
        List<String> remaining = new ArrayList<>();
        for (String step : planSteps) {
            if (!completedSteps.contains(step) && !failedSteps.contains(step)) {
                remaining.add(step);
            }
        }
        return remaining;
    }

    private boolean anyToolCallMatchesAnyPlanStep(AssistantMessage msg) {
        if (msg.getToolCalls() == null || planSteps.isEmpty()) return false;
        for (ToolCall tc : msg.getToolCalls()) {
            if (toolCallMatchesAnyStep(tc, planSteps)) return true;
        }
        return false;
    }

    private boolean toolCallMatchesAnyStep(ToolCall tc, List<String> steps) {
        String combined = (tc.getName() != null ? tc.getName() : "")
                + " " + (tc.getArguments() != null ? tc.getArguments() : "");
        String lower = combined.toLowerCase();
        for (String step : steps) {
            if (stepMatchesText(step, lower)) return true;
        }
        return false;
    }

    private static boolean isFinalAnswer(AssistantMessage msg) {
        return msg.getToolCalls() == null || msg.getToolCalls().isEmpty();
    }

    private boolean hasReplanSignal(AssistantMessage msg) {
        if (msg.getToolCalls() == null) return false;
        return msg.getToolCalls().stream()
                .anyMatch(tc -> "__replan__".equals(tc.getName()));
    }

    private static String contentOf(AssistantMessage msg) {
        String c = msg.getContentAsString();
        return c != null ? c : "";
    }

    // --------------- CJK utilities ---------------

    /** True if the string contains any CJK Unified Ideograph. */
    private static boolean containsCJK(String s) {
        return s.codePoints().anyMatch(PlanContextRail::isCJK);
    }

    private static boolean isCJK(int codePoint) {
        return (codePoint >= 0x4E00 && codePoint <= 0x9FFF)   // CJK Unified Ideographs
                || (codePoint >= 0x3400 && codePoint <= 0x4DBF) // CJK Ext-A
                || (codePoint >= 0xF900 && codePoint <= 0xFAFF); // CJK Compat
    }

    /**
     * Character-bigram overlap between step and tool-call text.
     * Extracts CJK characters from both strings, computes bigram set from
     * the step, and returns the fraction of step bigrams found in the text.
     *
     * <p>Fix B5: this is the fallback when a Chinese plan step has zero
     * Latin keywords and the tool call text also contains Chinese.
     */
    private static double cjkBigramOverlap(String step, String text) {
        String stepCJK = extractCJK(step);
        String textCJK = extractCJK(text);
        if (stepCJK.length() < 2 || textCJK.length() < 2) return 0.0;

        Set<String> stepBigrams = new LinkedHashSet<>();
        for (int i = 0; i < stepCJK.length() - 1; i++) {
            stepBigrams.add(stepCJK.substring(i, i + 2));
        }

        int matches = 0;
        for (int i = 0; i < textCJK.length() - 1; i++) {
            if (stepBigrams.contains(textCJK.substring(i, i + 2))) {
                matches++;
            }
        }
        return (double) matches / stepBigrams.size();
    }

    private static String extractCJK(String s) {
        StringBuilder sb = new StringBuilder();
        s.codePoints().forEachOrdered(cp -> {
            if (isCJK(cp)) sb.appendCodePoint(cp);
        });
        return sb.toString();
    }
}
