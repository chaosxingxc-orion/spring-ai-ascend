package com.huawei.ascend.runtime.engine.alpha.gepa3;

import static org.assertj.core.api.Assertions.assertThat;
import static org.junit.jupiter.api.Assertions.*;

import com.openjiuwen.core.foundation.llm.schema.AssistantMessage;
import com.openjiuwen.core.foundation.llm.schema.ToolCall;
import com.openjiuwen.core.singleagent.rail.AgentCallbackContext;
import com.openjiuwen.core.singleagent.rail.ModelCallInputs;
import com.openjiuwen.core.singleagent.rail.ToolCallInputs;

import java.util.List;
import java.util.Map;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;

/**
 * Unit tests for PlanContextRail -- verifying step extraction, completion
 * tracking, contradiction detection, and deviation detection.
 *
 * <p>These tests operate on the PlanContextRail in isolation (no ReActAgent
 * loop) by directly calling rail hooks with constructed callback contexts.
 *
 * <p>Test categories:
 * <ol>
 *   <li>Step extraction (English / Chinese / numbered / non-plan)</li>
 *   <li>Step completion tracking (tool name / arguments / CJK bigram)</li>
 *   <li>Contradiction detection (English / Chinese / B2 fix verification)</li>
 *   <li>Deviation detection (all done / mismatched / B3 fix verification)</li>
 *   <li>Failure recording (B1 fix)</li>
 *   <li>Edge cases (null safety / re-extraction / deviation cleared)</li>
 * </ol>
 *
 * @author P2 ReAct single-track prototype (2026-07-01)
 */
@DisplayName("PlanContextRail: step extraction, completion, contradiction, deviation")
class EnhancedRailsDemoTest {

    private PlanContextRail rail;

    @BeforeEach
    void setUp() {
        rail = new PlanContextRail();
    }

    // ==================== Step extraction ====================

    @Test
    @DisplayName("Extract plan steps from English Step N: pattern")
    void extractEnglishStepPattern() {
        AssistantMessage msg = new AssistantMessage(
                "I will proceed as follows:\n"
                + "Step 1: Fetch claim data from database\n"
                + "Step 2: Analyze fraud risk score\n"
                + "Step 3: Calculate correct payout\n"
                + "Step 4: Generate final adjudication report");

        rail.afterModelCall(ctxForModel(msg, List.of()));

        assertThat(rail.isPlanExtracted()).isTrue();
        assertThat(rail.planSteps()).containsExactly(
                "Fetch claim data from database",
                "Analyze fraud risk score",
                "Calculate correct payout",
                "Generate final adjudication report");
    }

    @Test
    @DisplayName("Extract plan steps from Chinese step pattern")
    void extractChineseStepPattern() {
        AssistantMessage msg = new AssistantMessage(
                "I will proceed as follows:\n"
                + "Step 1: Get case status\n"
                + "Step 2: Assess fraud risk\n"
                + "Step 3: Calculate correct payout");

        rail.afterModelCall(ctxForModel(msg, List.of()));

        assertThat(rail.isPlanExtracted()).isTrue();
        assertThat(rail.planSteps()).hasSize(3);
    }

    @Test
    @DisplayName("Extract plan steps from numbered list N. pattern")
    void extractNumberedListPattern() {
        AssistantMessage msg = new AssistantMessage(
                "Plan:\n"
                + "1. Fetch portfolio data\n"
                + "2. Research market conditions\n"
                + "3. Provide investment recommendation");

        rail.afterModelCall(ctxForModel(msg, List.of()));

        assertThat(rail.isPlanExtracted()).isTrue();
        assertThat(rail.planSteps()).hasSize(3);
        assertThat(rail.planSteps().get(0)).isEqualTo("Fetch portfolio data");
    }

    @Test
    @DisplayName("No plan extracted from non-plan content")
    void noPlanFromNonPlanContent() {
        AssistantMessage msg = new AssistantMessage(
                "The sky is blue and the data looks good. Let me think about this.");

        rail.afterModelCall(ctxForModel(msg, List.of()));

        assertThat(rail.isPlanExtracted()).isFalse();
        assertThat(rail.planSteps()).isEmpty();
    }

    // ==================== Step completion tracking ====================

    @Test
    @DisplayName("Track step completion via tool call name keyword match")
    void trackCompletionByToolCallName() {
        AssistantMessage planMsg = new AssistantMessage(
                "Step 1: Fetch claim data\nStep 2: Calculate payout");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        ToolCall fetchClaim = ToolCall.builder()
                .id("t1").type("function").name("fetchClaimData").arguments("{}").build();
        AssistantMessage toolMsg = AssistantMessage.builder()
                .content("Fetching claim data")
                .toolCalls(List.of(fetchClaim))
                .finishReason("tool_calls")
                .build();

        rail.afterModelCall(ctxForModel(toolMsg, List.of(fetchClaim)));

        assertThat(rail.completedSteps()).contains("Fetch claim data");
        assertThat(rail.completedSteps()).doesNotContain("Calculate payout");
    }

    @Test
    @DisplayName("Track step completion via tool call arguments keyword match")
    void trackCompletionByArguments() {
        AssistantMessage planMsg = new AssistantMessage(
                "Step 1: Analyze portfolio allocation\n"
                + "Step 2: Research technology sector");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        ToolCall tc = ToolCall.builder()
                .id("t1").type("function").name("analyzePortfolio")
                .arguments("{\"portfolioId\":\"P1001\",\"sector\":\"technology\"}")
                .build();
        AssistantMessage toolMsg = AssistantMessage.builder()
                .content("Analyzing")
                .toolCalls(List.of(tc))
                .finishReason("tool_calls")
                .build();

        rail.afterModelCall(ctxForModel(toolMsg, List.of(tc)));

        assertThat(rail.completedSteps()).contains("Analyze portfolio allocation");
        assertThat(rail.completedSteps()).contains("Research technology sector");
    }

    @Test
    @DisplayName("All steps completed when all tool calls match")
    void allStepsCompleted() {
        AssistantMessage planMsg = new AssistantMessage(
                "Step 1: Fetch data file\nStep 2: Analyze data pattern\nStep 3: Report results");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        ToolCall tc1 = ToolCall.builder().id("1").type("function")
                .name("fetchData").arguments("{}").build();
        AssistantMessage msg1 = AssistantMessage.builder()
                .content("").toolCalls(List.of(tc1)).finishReason("tool_calls").build();
        rail.afterModelCall(ctxForModel(msg1, List.of(tc1)));

        ToolCall tc2 = ToolCall.builder().id("2").type("function")
                .name("analyzeAndReport").arguments("{}").build();
        AssistantMessage msg2 = AssistantMessage.builder()
                .content("").toolCalls(List.of(tc2)).finishReason("tool_calls").build();
        rail.afterModelCall(ctxForModel(msg2, List.of(tc2)));

        assertThat(rail.completedSteps()).containsExactlyInAnyOrder(
                "Fetch data file", "Analyze data pattern", "Report results");
    }

    // ==================== B4 fix: short-word threshold ====================

    @Test
    @DisplayName("B4 fix: 3-char stopwords do not cause false step completion")
    void shortWordsDoNotCauseFalseMatch() {
        AssistantMessage planMsg = new AssistantMessage(
                "Step 1: Fetch the user data\n"  // "the" is 3 chars, should not match
                + "Step 2: Analyze all results");  // "all" is 3 chars
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        // Tool call whose name/args contain only 3-char words as keywords
        ToolCall tc = ToolCall.builder().id("1").type("function")
                .name("getTheAllFor")  // contains "the", "all", "for" -- all 3 chars
                .arguments("{\"the\":\"value\",\"and\":true,\"for\":\"test\"}")
                .build();
        AssistantMessage toolMsg = AssistantMessage.builder()
                .content("").toolCalls(List.of(tc)).finishReason("tool_calls").build();

        rail.afterModelCall(ctxForModel(toolMsg, List.of(tc)));

        // Neither step should be completed -- 3-char words are below threshold
        assertThat(rail.completedSteps()).isEmpty();
    }

    @Test
    @DisplayName("B4 fix: 4-char meaningful words still match (data/risk/user/file)")
    void meaningfulShortWordsStillMatch() {
        AssistantMessage planMsg = new AssistantMessage(
                "Step 1: Fetch user data from database\n"
                + "Step 2: Analyze risk factors");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        // "user" (4 chars), "data" (4 chars), "risk" (4 chars) should all match
        ToolCall tc1 = ToolCall.builder().id("1").type("function")
                .name("fetchUserData").arguments("{}").build();
        AssistantMessage msg1 = AssistantMessage.builder()
                .content("").toolCalls(List.of(tc1)).finishReason("tool_calls").build();
        rail.afterModelCall(ctxForModel(msg1, List.of(tc1)));

        assertThat(rail.completedSteps()).contains("Fetch user data from database");

        ToolCall tc2 = ToolCall.builder().id("2").type("function")
                .name("analyzeRisk").arguments("{}").build();
        AssistantMessage msg2 = AssistantMessage.builder()
                .content("").toolCalls(List.of(tc2)).finishReason("tool_calls").build();
        rail.afterModelCall(ctxForModel(msg2, List.of(tc2)));

        assertThat(rail.completedSteps()).contains("Analyze risk factors");
    }

    // ==================== B5 fix: Chinese CJK bigram matching ====================

    @Test
    @DisplayName("B5 fix: Chinese step matched via CJK bigram overlap with Chinese tool name")
    void chineseStepMatchedByBigram() {
        AssistantMessage planMsg = new AssistantMessage(
                "第1步：获取理赔数据\n第2步：分析欺诈风险");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        // Chinese-named tool call (same language as plan steps)
        ToolCall tc = ToolCall.builder().id("1").type("function")
                .name("获取理赔数据工具")
                .arguments("{\"caseId\":\"C001\"}")
                .build();
        AssistantMessage toolMsg = AssistantMessage.builder()
                .content("获取理赔数据中")
                .toolCalls(List.of(tc))
                .finishReason("tool_calls")
                .build();

        rail.afterModelCall(ctxForModel(toolMsg, List.of(tc)));

        assertThat(rail.completedSteps()).contains("获取理赔数据");
        assertThat(rail.completedSteps()).doesNotContain("分析欺诈风险");
    }

    @Test
    @DisplayName("B5 fix: Chinese step with embedded Latin keyword still matches English tool")
    void chineseStepWithLatinKeywordMatchesEnglishTool() {
        AssistantMessage planMsg = new AssistantMessage(
                "Step 1: 获取理赔数据\nStep 2: 运行 fraud detection");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        // English tool name, but step contains "fraud" + "detection" (Latin)
        ToolCall tc = ToolCall.builder().id("1").type("function")
                .name("runFraudDetection").arguments("{}").build();
        AssistantMessage toolMsg = AssistantMessage.builder()
                .content("Running fraud check")
                .toolCalls(List.of(tc))
                .finishReason("tool_calls")
                .build();

        rail.afterModelCall(ctxForModel(toolMsg, List.of(tc)));

        // "fraud" (5 chars) and "detection" (9 chars) are Latin keywords embedded
        assertThat(rail.completedSteps()).contains("运行 fraud detection");
    }

    // ==================== Contradiction detection (E1 signal) ====================

    @Test
    @DisplayName("Detect contradiction: final answer has both pass and fail signals")
    void detectContradictionPassAndFail() {
        AssistantMessage planMsg = new AssistantMessage("Step 1: Audit claim");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        AssistantMessage finalAnswer = new AssistantMessage(
                "The claim PASSES all basic checks but FAILS the advanced audit. "
                + "We should APPROVE because basic checks pass.");

        rail.afterModelCall(ctxForModel(finalAnswer, List.of()));

        assertThat(rail.contradictionDetail()).isNotNull();
        assertThat(rail.contradictionDetail()).contains("pass and fail");
    }

    @Test
    @DisplayName("Detect contradiction: Chinese pass+fail signals")
    void detectContradictionChinese() {
        AssistantMessage planMsg = new AssistantMessage("Step 1: Review claim");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        AssistantMessage finalAnswer = new AssistantMessage(
                "Review passes, documents complete. But risk assessment fails, fraud suspected.");

        rail.afterModelCall(ctxForModel(finalAnswer, List.of()));

        // "passes" + "fails" should trigger contradiction
        assertThat(rail.contradictionDetail()).isNotNull();
        Map<String, Object> ctx = rail.planContextMap();
        assertThat(ctx.get(PlanContextRail.PERCEPTION_UNRELIABLE_KEY)).isEqualTo(true);
    }

    // ==================== B2 fix: Chinese substring false positive ====================

    @Test
    @DisplayName("B2 fix: pure negative Chinese verdict does NOT trigger false contradiction")
    void pureNegativeChineseNoFalseContradiction() {
        AssistantMessage planMsg = new AssistantMessage("Step 1: Review claim");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        // "不满足" contains "满足" as substring -- B2 bug was that this triggered
        // hasPass=true (from "满足") AND hasFail=true (from "不满足")
        AssistantMessage finalAnswer = new AssistantMessage(
                "审核不满足高级要求，不符合风控标准，结论不通过。");

        rail.afterModelCall(ctxForModel(finalAnswer, List.of()));

        // B2 fix: negative-prefixed phrases are scrubbed before positive check
        assertThat(rail.contradictionDetail()).isNull();
    }

    @Test
    @DisplayName("B2 fix: mixed Chinese pass+fail STILL detected as contradiction")
    void mixedChinesePassFailStillDetected() {
        AssistantMessage planMsg = new AssistantMessage("Step 1: Review claim");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        // 满足 (positive) AND 不满足 (negative) → genuine contradiction
        AssistantMessage finalAnswer = new AssistantMessage(
                "基础审核满足要求，但高级审核不满足风控标准。");

        rail.afterModelCall(ctxForModel(finalAnswer, List.of()));

        assertThat(rail.contradictionDetail()).isNotNull();
        assertThat(rail.contradictionDetail()).contains("pass and fail");
    }

    // ==================== B3 fix: deviation ordering ====================

    @Test
    @DisplayName("B3 fix: first legitimate tool call does NOT trigger false deviation")
    void firstLegitimateToolCallNoFalseDeviation() {
        AssistantMessage planMsg = new AssistantMessage(
                "Step 1: Fetch portfolio data\n"
                + "Step 2: Research market conditions\n"
                + "Step 3: Provide investment recommendation");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        // First tool call correctly matches step 1
        // B3 bug: after matchAndCompleteStep removes step 1, checkForDeviation
        // checks against steps 2+3 only → false "no match"
        ToolCall tc = ToolCall.builder().id("1").type("function")
                .name("fetchPortfolio").arguments("{\"id\":\"P1001\"}").build();
        AssistantMessage msg = AssistantMessage.builder()
                .content("Fetching portfolio data")
                .toolCalls(List.of(tc))
                .finishReason("tool_calls")
                .build();

        rail.afterModelCall(ctxForModel(msg, List.of(tc)));

        // B3 fix: checkForDeviation now runs BEFORE matchAndCompleteStep
        // AND against ALL plan steps → fetchPortfolio matches step 1 → no deviation
        assertThat(rail.deviationDetail()).isNull();
        assertThat(rail.completedSteps()).contains("Fetch portfolio data");
    }

    @Test
    @DisplayName("B3 fix: tool call matching a previously-completed step is NOT deviation")
    void repeatCompletedStepNotDeviation() {
        AssistantMessage planMsg = new AssistantMessage(
                "Step 1: Fetch data\nStep 2: Analyze data");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        // Complete step 1
        ToolCall tc1 = ToolCall.builder().id("1").type("function")
                .name("fetchData").arguments("{}").build();
        AssistantMessage msg1 = AssistantMessage.builder()
                .content("").toolCalls(List.of(tc1)).finishReason("tool_calls").build();
        rail.afterModelCall(ctxForModel(msg1, List.of(tc1)));

        // Call step 1 tool again (repetition, not deviation)
        ToolCall tc2 = ToolCall.builder().id("2").type("function")
                .name("fetchData").arguments("{\"refresh\":true}").build();
        AssistantMessage msg2 = AssistantMessage.builder()
                .content("").toolCalls(List.of(tc2)).finishReason("tool_calls").build();
        rail.afterModelCall(ctxForModel(msg2, List.of(tc2)));

        // Matches step 1 (completed) → NOT deviation. Repetition is a different concern.
        assertThat(rail.deviationDetail()).isNull();
    }

    // ==================== Deviation detection (E2 signal) ====================

    @Test
    @DisplayName("Detect deviation: all steps done but agent continues with non-matching tools")
    void detectDeviationAllStepsDone() {
        AssistantMessage planMsg = new AssistantMessage(
                "Step 1: Fetch data file\nStep 2: Return result output");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        // Complete both steps with one tool call
        ToolCall tc = ToolCall.builder().id("1").type("function")
                .name("fetchDataAndReturnResult").arguments("{}").build();
        AssistantMessage msg = AssistantMessage.builder()
                .content("").toolCalls(List.of(tc)).finishReason("tool_calls").build();
        rail.afterModelCall(ctxForModel(msg, List.of(tc)));

        assertThat(rail.completedSteps()).hasSize(2);

        // Extra tool call that matches NO plan step
        ToolCall extraTc = ToolCall.builder().id("2").type("function")
                .name("extraCheck").arguments("{}").build();
        AssistantMessage extraMsg = AssistantMessage.builder()
                .content("").toolCalls(List.of(extraTc)).finishReason("tool_calls").build();
        rail.afterModelCall(ctxForModel(extraMsg, List.of(extraTc)));

        assertThat(rail.deviationDetail()).isNotNull();
        assertThat(rail.deviationDetail()).contains("All plan steps appear completed");
    }

    @Test
    @DisplayName("Detect deviation: tool calls do not match any remaining step")
    void detectDeviationMismatchedTools() {
        AssistantMessage planMsg = new AssistantMessage(
                "Step 1: Fetch customer data\n"
                + "Step 2: Calculate risk score\n"
                + "Step 3: Generate final report");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        // Tool call that matches NO step
        ToolCall weirdTc = ToolCall.builder().id("1").type("function")
                .name("checkWeatherForecast").arguments("{}").build();
        AssistantMessage msg = AssistantMessage.builder()
                .content("").toolCalls(List.of(weirdTc)).finishReason("tool_calls").build();
        rail.afterModelCall(ctxForModel(msg, List.of(weirdTc)));

        assertThat(rail.deviationDetail()).isNotNull();
        assertThat(rail.deviationDetail()).contains("do not match any plan step");
    }

    // ==================== Bug 5 fix: deviation cleared on recovery ====================

    @Test
    @DisplayName("Bug 5 fix: deviation cleared when next response matches plan steps")
    void deviationClearedOnRecovery() {
        AssistantMessage planMsg = new AssistantMessage(
                "Step 1: Fetch data from server\nStep 2: Analyze fetched data");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        // Deviate
        ToolCall weirdTc = ToolCall.builder().id("1").type("function")
                .name("checkWeatherForecast").arguments("{}").build();
        AssistantMessage weirdMsg = AssistantMessage.builder()
                .content("").toolCalls(List.of(weirdTc)).finishReason("tool_calls").build();
        rail.afterModelCall(ctxForModel(weirdMsg, List.of(weirdTc)));
        assertThat(rail.deviationDetail()).isNotNull();

        // Recover: next response matches a plan step
        ToolCall goodTc = ToolCall.builder().id("2").type("function")
                .name("fetchData").arguments("{}").build();
        AssistantMessage goodMsg = AssistantMessage.builder()
                .content("").toolCalls(List.of(goodTc)).finishReason("tool_calls").build();
        rail.afterModelCall(ctxForModel(goodMsg, List.of(goodTc)));

        // Deviation should be cleared (recovery detected)
        assertThat(rail.deviationDetail()).isNull();
        assertThat(rail.completedSteps()).contains("Fetch data from server");
    }

    // ==================== Bug 6 fix: re-extraction on replan ====================

    @Test
    @DisplayName("Bug 6 fix: plan re-extracted after __replan__ signal")
    void planReExtractedAfterReplan() {
        // First plan
        AssistantMessage planMsg = new AssistantMessage(
                "Step 1: Initial approach");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));
        assertThat(rail.isPlanExtracted()).isTrue();
        assertThat(rail.planSteps()).hasSize(1);

        // __replan__ tool call triggers re-extraction
        ToolCall replanTc = ToolCall.builder().id("r1").type("function")
                .name("__replan__")
                .arguments("{\"replan_reason\":\"wrong approach\"}")
                .build();
        AssistantMessage replanMsg = AssistantMessage.builder()
                .content("Replanning with new approach\n"
                        + "Step 1: Revised step one\n"
                        + "Step 2: New step two\n"
                        + "Step 3: Final check")
                .toolCalls(List.of(replanTc))
                .finishReason("tool_calls")
                .build();

        rail.afterModelCall(ctxForModel(replanMsg, List.of(replanTc)));

        // Plan should be re-extracted with new steps
        assertThat(rail.planSteps()).hasSize(3);
        assertThat(rail.planSteps().get(0)).isEqualTo("Revised step one");
        assertThat(rail.planSteps().get(1)).isEqualTo("New step two");
    }

    // ==================== B1 fix: markStepFailed ====================

    @Test
    @DisplayName("B1 fix: afterToolCall with error result records failed step")
    void afterToolCallRecordsFailedStep() {
        AssistantMessage planMsg = new AssistantMessage("Step 1: Fetch external data from API");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        // Tool result contains error signal
        AgentCallbackContext ctx = AgentCallbackContext.builder()
                .inputs(ToolCallInputs.builder()
                        .toolName("fetchExternalData")
                        .toolResult("error: connection timeout, external API unavailable")
                        .build())
                .build();
        rail.afterToolCall(ctx);

        // B1 fix: markStepFailed now actually records the failure
        assertThat(rail.failedSteps()).isNotEmpty();
        assertThat(rail.failedSteps()).contains("Fetch external data from API");
        // Failed steps should appear in planContextMap
        Map<String, Object> ctxMap = rail.planContextMap();
        assertThat(ctxMap.get(PlanContextRail.FAILED_STEPS_KEY)).isNotNull();
    }

    @Test
    @DisplayName("B1 fix: tool failure without matching step records tool name")
    void toolFailureWithoutMatchingStepRecordsToolName() {
        AssistantMessage planMsg = new AssistantMessage("Step 1: Do unrelated task");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        AgentCallbackContext ctx = AgentCallbackContext.builder()
                .inputs(ToolCallInputs.builder()
                        .toolName("unrelatedFailingTool")
                        .toolResult("error: something went wrong")
                        .build())
                .build();
        rail.afterToolCall(ctx);

        // No plan step matched the failing tool → records tool: prefix
        assertThat(rail.failedSteps()).contains("tool:unrelatedFailingTool");
    }

    @Test
    @DisplayName("afterToolCall with success result does not mark step failed")
    void afterToolCallSuccessNoSideEffect() {
        AssistantMessage planMsg = new AssistantMessage("Step 1: Fetch data from API");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        AgentCallbackContext ctx = AgentCallbackContext.builder()
                .inputs(ToolCallInputs.builder()
                        .toolName("fetchData")
                        .toolResult("status: ok, data retrieved successfully")
                        .build())
                .build();
        rail.afterToolCall(ctx);

        // Success result → no failed steps, no completed steps (completion is via afterModelCall)
        assertThat(rail.failedSteps()).isEmpty();
        assertThat(rail.completedSteps()).isEmpty();
    }

    // ==================== planContextMap ====================

    @Test
    @DisplayName("planContextMap reflects current state including remaining and failed steps")
    void planContextMapReflectsState() {
        AssistantMessage planMsg = new AssistantMessage(
                "Step 1: First task done\nStep 2: Second task later\nStep 3: Third task final");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        // Complete step 1
        ToolCall tc = ToolCall.builder().id("1").type("function")
                .name("doFirstTask").arguments("{}").build();
        AssistantMessage msg = AssistantMessage.builder()
                .content("").toolCalls(List.of(tc)).finishReason("tool_calls").build();
        rail.afterModelCall(ctxForModel(msg, List.of(tc)));

        // Mark step 3 as failed via afterToolCall
        AgentCallbackContext failCtx = AgentCallbackContext.builder()
                .inputs(ToolCallInputs.builder()
                        .toolName("thirdTask")
                        .toolResult("error: timeout")
                        .build())
                .build();
        rail.afterToolCall(failCtx);

        Map<String, Object> ctx = rail.planContextMap();
        assertThat(ctx.get("plan_extracted")).isEqualTo(true);
        @SuppressWarnings("unchecked")
        List<String> remaining = (List<String>) ctx.get("remaining_steps");
        // Step 1 completed, Step 3 failed → only Step 2 remaining
        assertThat(remaining).containsExactly("Second task later");
        @SuppressWarnings("unchecked")
        java.util.Set<String> failed = (java.util.Set<String>) ctx.get("failed_steps");
        assertThat(failed).contains("Third task final");
    }

    // ==================== Edge cases ====================

    @Test
    @DisplayName("Null response in afterModelCall does not crash")
    void nullResponseDoesNotCrash() {
        AgentCallbackContext ctx = AgentCallbackContext.builder()
                .inputs(ModelCallInputs.builder().response(null).build())
                .build();
        assertDoesNotThrow(() -> rail.afterModelCall(ctx));
        assertThat(rail.isPlanExtracted()).isFalse();
    }

    @Test
    @DisplayName("beforeModelCall without steering queue does not crash")
    void beforeModelCallWithoutSteeringDoesNotCrash() {
        AssistantMessage planMsg = new AssistantMessage("Step 1: Do something useful");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        AgentCallbackContext ctx = AgentCallbackContext.builder().build();
        assertDoesNotThrow(() -> rail.beforeModelCall(ctx));
    }

    @Test
    @DisplayName("No deviation when no plan was ever extracted")
    void noDeviationWhenNoPlanExtracted() {
        // No plan extracted yet
        assertThat(rail.isPlanExtracted()).isFalse();

        // Tool calls without a plan
        ToolCall tc = ToolCall.builder().id("1").type("function")
                .name("someRandomTool").arguments("{}").build();
        AssistantMessage msg = AssistantMessage.builder()
                .content("").toolCalls(List.of(tc)).finishReason("tool_calls").build();
        rail.afterModelCall(ctxForModel(msg, List.of(tc)));

        // No plan → deviation check skipped (edge case: can't deviate from nothing)
        assertThat(rail.deviationDetail()).isNull();
    }

    @Test
    @DisplayName("Deviation not fired when tool call matches any completed step")
    void deviationNotFiredForRepeatOfCompletedStep() {
        AssistantMessage planMsg = new AssistantMessage(
                "Step 1: Fetch data from server\nStep 2: Process results report");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        // Complete step 1
        ToolCall tc1 = ToolCall.builder().id("1").type("function")
                .name("fetchData").arguments("{}").build();
        rail.afterModelCall(ctxForModel(
                AssistantMessage.builder().content("").toolCalls(List.of(tc1))
                        .finishReason("tool_calls").build(),
                List.of(tc1)));

        // Repeat step 1 tool call (repetition, not deviation)
        ToolCall tc2 = ToolCall.builder().id("2").type("function")
                .name("fetchData").arguments("{\"refresh\":true}").build();
        rail.afterModelCall(ctxForModel(
                AssistantMessage.builder().content("").toolCalls(List.of(tc2))
                        .finishReason("tool_calls").build(),
                List.of(tc2)));

        // Should not flag as deviation -- it matches a plan step (even if completed)
        assertThat(rail.deviationDetail()).isNull();
    }

    @Test
    @DisplayName("Multiple tool calls in one response: deviation only when NONE match")
    void multipleToolCallsOneMatchPreventsDeviation() {
        AssistantMessage planMsg = new AssistantMessage(
                "Step 1: Fetch claim data from server\n"
                + "Step 2: Calculate risk score\n"
                + "Step 3: Generate report output");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        // Two tool calls: one matches, one doesn't
        ToolCall goodTc = ToolCall.builder().id("1").type("function")
                .name("fetchClaimData").arguments("{}").build();
        ToolCall weirdTc = ToolCall.builder().id("2").type("function")
                .name("checkWeather").arguments("{}").build();
        AssistantMessage msg = AssistantMessage.builder()
                .content("").toolCalls(List.of(goodTc, weirdTc))
                .finishReason("tool_calls").build();

        rail.afterModelCall(ctxForModel(msg, List.of(goodTc, weirdTc)));

        // At least one tool call matches a plan step → no deviation
        assertThat(rail.deviationDetail()).isNull();
    }

    @Test
    @DisplayName("Contradiction not detected when content is null")
    void contradictionNotDetectedWhenContentNull() {
        AssistantMessage planMsg = new AssistantMessage("Step 1: Analysis task");
        rail.afterModelCall(ctxForModel(planMsg, List.of()));

        // AssistantMessage with null content
        AssistantMessage msg = AssistantMessage.builder()
                .content(null)
                .build();

        rail.afterModelCall(ctxForModel(msg, List.of()));

        assertThat(rail.contradictionDetail()).isNull();
    }

    // ==================== Helpers ====================

    private static AgentCallbackContext ctxForModel(
            AssistantMessage response, List<ToolCall> toolCalls) {
        AssistantMessage msg;
        if (toolCalls != null && !toolCalls.isEmpty()) {
            msg = AssistantMessage.builder()
                    .content(response.getContentAsString())
                    .toolCalls(toolCalls)
                    .finishReason("tool_calls")
                    .build();
        } else {
            msg = response;
        }
        return AgentCallbackContext.builder()
                .inputs(ModelCallInputs.builder().response(msg).build())
                .build();
    }
}
