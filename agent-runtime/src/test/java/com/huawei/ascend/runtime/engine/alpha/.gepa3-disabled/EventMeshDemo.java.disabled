package com.huawei.ascend.runtime.engine.alpha.gepa3;

import reactor.core.publisher.Flux;
import reactor.core.publisher.Sinks;

import java.util.*;
import java.util.concurrent.ConcurrentHashMap;
import java.util.concurrent.CopyOnWriteArrayList;
import java.util.concurrent.atomic.AtomicInteger;

/**
 * P4 Event Grid PROTOTYPE.
 *
 * <p>Demonstrates the radical claim: <b>Engine hierarchy is accidental coupling.
 * Events are universal composability primitive.</b>
 *
 * <p>Architecture:
 * <ul>
 *   <li>Flat {@link EventBus} (Sinks.Many multicast) replaces imperative orchestration</li>
 *   <li>5 independent processors (Planner/Executor/Verifier/RootCause/Replan) subscribe
 *       to specific event types and publish results — no processor calls another directly</li>
 *   <li>Adding {@link CostTrackerProcessor} requires <b>zero changes</b> to existing processors —
 *       just instantiate and call {@code start()}</li>
 * </ul>
 *
 * <p>E3 trace (device fault → COMPLETED-degraded):
 * <pre>
 *   GoalReceived → PlanGenerated → NodeStarted(tool) → NodeFailed(tool) → LayerCompleted
 *   → VerifyFailed(tool) → RootCauseFound(DeviceFailure) → AcceptPartial
 *   → TaskCompleted(verified=false, degraded=true)
 * </pre>
 *
 * <p>All event types form a single sealed hierarchy — adding a new event type makes
 * every switch-on-event a compile error until handled (or defaulted). This is the same
 * pattern as production sealed hierarchies ({@code RootCause}, {@code ReplanStrategy}).
 */
public final class EventMeshDemo {

    private EventMeshDemo() { /* utility class */ }

    // ========================================================================
    // 1. Sealed Event Hierarchy
    //    All 14 event types in one sealed interface — compiler enforces coverage
    // ========================================================================

    /**
     * Root sealed type for the event mesh. Every event in the system IS-A MeshEvent.
     * Adding a new subtype forces all consuming switch expressions to re-evaluate.
     */
    public sealed interface MeshEvent
            permits MeshEvent.GoalReceived,
                    MeshEvent.PlanGenerated,
                    MeshEvent.PlanRevised,
                    MeshEvent.NodeStarted,
                    MeshEvent.NodeCompleted,
                    MeshEvent.NodeFailed,
                    MeshEvent.LayerCompleted,
                    MeshEvent.VerifyRequested,
                    MeshEvent.VerifyPassed,
                    MeshEvent.VerifyFailed,
                    MeshEvent.RootCauseFound,
                    MeshEvent.ReplanDispatched,
                    MeshEvent.TaskCompleted,
                    MeshEvent.CostTracked {

        /** Every event carries its originating task ID for per-task filtering. */
        String taskId();

        /** Every event has a wall-clock timestamp for traceability. */
        long timestamp();

        // --- Planning phase ---
        record GoalReceived(String taskId, long timestamp, String goal)
                implements MeshEvent {}

        record PlanGenerated(String taskId, long timestamp,
                             List<String> nodeIds,
                             String planDescription)
                implements MeshEvent {}

        record PlanRevised(String taskId, long timestamp,
                           List<String> nodeIds,
                           String revisionReason)
                implements MeshEvent {}

        // --- Execution phase ---
        enum NodeType { LLM_CALL, TOOL_CALL, SUB_AGENT }

        record NodeStarted(String taskId, long timestamp,
                           String nodeId,
                           NodeType nodeType)
                implements MeshEvent {}

        record NodeCompleted(String taskId, long timestamp,
                             String nodeId,
                             String result)
                implements MeshEvent {}

        record NodeFailed(String taskId, long timestamp,
                          String nodeId,
                          String error)
                implements MeshEvent {}

        record LayerCompleted(String taskId, long timestamp,
                              int layerIndex,
                              Map<String, String> nodeResults)
                implements MeshEvent {}

        // --- Verify phase ---
        record VerifyRequested(String taskId, long timestamp)
                implements MeshEvent {}

        record VerifyPassed(String taskId, long timestamp,
                            String feedback)
                implements MeshEvent {}

        record VerifyFailed(String taskId, long timestamp,
                            Set<String> failedNodes,
                            String feedback)
                implements MeshEvent {}

        // --- Self-heal phase ---
        record RootCauseFound(String taskId, long timestamp,
                              SelfHealAction action,
                              Set<String> failedNodes)
                implements MeshEvent {}

        record ReplanDispatched(String taskId, long timestamp,
                                String actionName)
                implements MeshEvent {}

        // --- Terminal ---
        record TaskCompleted(String taskId, long timestamp,
                             String output,
                             boolean verified,
                             boolean degraded)
                implements MeshEvent {}

        // --- Cross-cutting (added by CostTrackerProcessor, zero changes elsewhere) ---
        record CostTracked(String taskId, long timestamp,
                           String source,
                           double amount)
                implements MeshEvent {}
    }

    // ========================================================================
    // 2. SelfHealAction — mirrors production RootCause/ReplanStrategy sealed hierarchies
    // ========================================================================

    /**
     * Sealed self-heal action hierarchy. Dispatch is compile-time exhaustive:
     * delete one arm → compile error.
     */
    public sealed interface SelfHealAction
            permits SelfHealAction.Degrade,
                    SelfHealAction.LocalReplan,
                    SelfHealAction.GlobalReplan {

        /** Device fault → replan won't help → accept partial result. */
        record Degrade(String reason) implements SelfHealAction {}

        /** Plan/answer error → retry failed nodes with hints. */
        record LocalReplan(int maxRounds) implements SelfHealAction {
            public LocalReplan {
                if (maxRounds < 1) maxRounds = 2;
            }
            public static LocalReplan of() { return new LocalReplan(2); }
        }

        /** Catastrophic plan error → discard and re-plan entirely. */
        record GlobalReplan() implements SelfHealAction {}
    }

    // ========================================================================
    // 3. EventBus — Sinks.Many multicast (matches DefaultAgentKernel pattern)
    // ========================================================================

    /**
     * Flat event bus. Replaces the imperative engine hierarchy.
     *
     * <p>Uses {@link Sinks.Many#multicast()} so multiple processors subscribe independently.
     * {@code onBackpressureBuffer()} means events are buffered if no subscriber is ready
     * (idle CPUs stay idle; no spin-wait).
     *
     * <p>Contrast with 2.0 AlphaStrategy.execute(): a 300-line god-method with hard-coded
     * Phase1→Phase2→Phase3 sequencing, manual state accumulation, terminalGuard booleans,
     * and try-catch around .block() calls. This EventBus has NONE of that.
     */
    public static final class EventBus {

        private final Sinks.Many<MeshEvent> sink =
                Sinks.many().multicast().onBackpressureBuffer();

        /**
         * Publish an event. {@code tryEmitNext} is lock-free for the common case;
         * backpressure only kicks in if no downstream demand.
         */
        public void publish(MeshEvent event) {
            Sinks.EmitResult result = sink.tryEmitNext(event);
            if (result.isFailure()) {
                // In a real system this would go to a dead-letter queue;
                // for the prototype, fail-fast.
                throw new IllegalStateException(
                        "EventBus emit failed: " + result + " for " + event);
            }
        }

        /**
         * Raw event stream. Processors subscribe to this and filter for
         * the types they care about.
         */
        public Flux<MeshEvent> events() {
            return sink.asFlux();
        }
    }

    // ========================================================================
    // 4. Five Core Processors
    //    Each processor:
    //      - Subscribes to specific event type(s) on the bus
    //      - Performs its domain logic
    //      - Publishes output events to the bus
    //    NO PROCESSOR CALLS ANOTHER PROCESSOR DIRECTLY.
    //    NO PROCESSOR CALLS .block().
    // ========================================================================

    /**
     * Listens for {@link MeshEvent.GoalReceived}. Publishes {@link MeshEvent.PlanGenerated}.
     *
     * <p>In 2.0: {@code Planner.plan().block()} called imperatively by AlphaStrategy.execute().
     * Here: subscribe to event, publish result. Loose coupling.
     */
    public static final class PlannerProcessor {

        private final EventBus bus;
        private final AtomicInteger planCount = new AtomicInteger(0);

        public PlannerProcessor(EventBus bus) {
            this.bus = bus;
        }

        public void start() {
            bus.events()
                    .ofType(MeshEvent.GoalReceived.class)
                    .subscribe(this::onGoalReceived);
        }

        private void onGoalReceived(MeshEvent.GoalReceived event) {
            // Simulate LLM planning — in production this would call kernel.think()
            List<String> nodes = List.of(
                    "node_research",     // LLM_CALL — gather context
                    "node_calculate",    // TOOL_CALL — compute premium
                    "node_write"         // LLM_CALL — produce answer
            );
            bus.publish(new MeshEvent.PlanGenerated(
                    event.taskId(), System.currentTimeMillis(),
                    nodes, "plan-" + planCount.incrementAndGet()));
        }

        /**
         * Replan entry point — called by downstream when
         * RootCause decides replan is needed.
         */
        public void replan(String taskId, String reason) {
            List<String> nodes = List.of(
                    "node_research", "node_calculate", "node_write");
            bus.publish(new MeshEvent.PlanRevised(
                    taskId, System.currentTimeMillis(), nodes, reason));
        }

        public int planCount() { return planCount.get(); }
    }

    /**
     * Listens for {@link MeshEvent.PlanGenerated} / {@link MeshEvent.PlanRevised}.
     * Executes each node; publishes {@link MeshEvent.NodeStarted},
     * {@link MeshEvent.NodeCompleted}, {@link MeshEvent.NodeFailed},
     * {@link MeshEvent.LayerCompleted}.
     *
     * <p>In 2.0: {@code DefaultPregelExecutor.execute()→executeSuperstep→executeNode} with
     * BSP barrier, virtual threads, CompletableFuture.allOf. Here: sequential iteration
     * over nodes (prototype simplification — real version would parallelize within
     * layer, same event contract).
     */
    public static final class ExecutorProcessor {

        private final EventBus bus;

        /**
         * Node ID that should simulate a device fault.
         * {@code null} means all nodes succeed.
         */
        private volatile String failNodeId = null;

        public ExecutorProcessor(EventBus bus) {
            this.bus = bus;
        }

        public void start() {
            bus.events()
                    .subscribe(event -> {
                        switch (event) {
                            case MeshEvent.PlanGenerated pg -> executePlan(
                                    pg.taskId(), pg.nodeIds());
                            case MeshEvent.PlanRevised pr -> executePlan(
                                    pr.taskId(), pr.nodeIds());
                            default -> { /* ignore */ }
                        }
                    });
        }

        /** Set which node should simulate failure (E3 injection point). */
        public void setFailNode(String nodeId) {
            this.failNodeId = nodeId;
        }

        private void executePlan(String taskId, List<String> nodeIds) {
            Map<String, String> results = new LinkedHashMap<>();

            for (String nodeId : nodeIds) {
                MeshEvent.NodeType type = nodeId.contains("calculate")
                        ? MeshEvent.NodeType.TOOL_CALL
                        : MeshEvent.NodeType.LLM_CALL;

                bus.publish(new MeshEvent.NodeStarted(
                        taskId, System.currentTimeMillis(), nodeId, type));

                // E3 injection: node matches failNodeId → simulate RuntimeException
                if (nodeId.equals(failNodeId)) {
                    bus.publish(new MeshEvent.NodeFailed(
                            taskId, System.currentTimeMillis(), nodeId,
                            "FAILED: RuntimeException in @Tool method"));
                    // do NOT add to results — this is the E3 gap
                    continue;
                }

                String result = "result_of_" + nodeId;
                results.put(nodeId, result);
                bus.publish(new MeshEvent.NodeCompleted(
                        taskId, System.currentTimeMillis(), nodeId, result));
            }

            bus.publish(new MeshEvent.LayerCompleted(
                    taskId, System.currentTimeMillis(), 0, results));
        }
    }

    /**
     * Listens for execution events; validates results.
     *
     * <p>Tracks {@link MeshEvent.NodeFailed} to build executor-failure set,
     * then on {@link MeshEvent.LayerCompleted} runs verification.
     *
     * <p>In 2.0: {@code DefaultVerifier.verify().block()} + ruleVerify checks
     * for {@code "FAILED:"} prefix. Here: same logic, event-driven.
     */
    public static final class VerifierProcessor {

        private final EventBus bus;
        private final Set<String> executorFailedNodes = new HashSet<>();

        public VerifierProcessor(EventBus bus) {
            this.bus = bus;
        }

        public void start() {
            bus.events().subscribe(event -> {
                switch (event) {
                    case MeshEvent.NodeFailed nf ->
                            executorFailedNodes.add(nf.nodeId());
                    case MeshEvent.NodeCompleted nc ->
                            executorFailedNodes.remove(nc.nodeId());
                    case MeshEvent.LayerCompleted lc ->
                            onLayerCompleted(lc);
                    default -> { /* ignore */ }
                }
            });
        }

        private void onLayerCompleted(MeshEvent.LayerCompleted event) {
            String taskId = event.taskId();
            bus.publish(new MeshEvent.VerifyRequested(
                    taskId, System.currentTimeMillis()));

            // Mirror DefaultVerifier.ruleVerify: "FAILED:" prefix = node failure
            Set<String> failed = new HashSet<>();
            for (var entry : event.nodeResults().entrySet()) {
                if (entry.getValue() != null
                        && entry.getValue().startsWith("FAILED:")) {
                    failed.add(entry.getKey());
                }
            }
            // Nodes that failed (not in nodeResults) are also failures
            failed.addAll(executorFailedNodes);

            if (failed.isEmpty()) {
                bus.publish(new MeshEvent.VerifyPassed(
                        taskId, System.currentTimeMillis(),
                        "All nodes passed verification"));
            } else {
                bus.publish(new MeshEvent.VerifyFailed(
                        taskId, System.currentTimeMillis(), failed,
                        "Verification failed for: " + failed));
            }

            executorFailedNodes.clear();
        }
    }

    /**
     * Listens for {@link MeshEvent.NodeFailed} (to track device failures) and
     * {@link MeshEvent.VerifyFailed} (to diagnose root cause).
     *
     * <p>Core logic mirrors {@code AlphaStrategy.diagnoseRootCause:570-580}:
     * <pre>
     *   intersect = verifyFailedNodes ∩ executorFailedNodes
     *   if intersect nonEmpty → DeviceFailure  → Degrade
     *   else                  → PlanOrAnswerError → LocalReplan
     *   (PerceptionUnreliable not modeled in prototype — verifier never throws)
     * </pre>
     */
    public static final class RootCauseProcessor {

        private final EventBus bus;
        private final Set<String> deviceFailureNodes = new HashSet<>();

        public RootCauseProcessor(EventBus bus) {
            this.bus = bus;
        }

        public void start() {
            bus.events().subscribe(event -> {
                switch (event) {
                    case MeshEvent.NodeFailed nf ->
                            deviceFailureNodes.add(nf.nodeId());
                    case MeshEvent.VerifyFailed vf ->
                            diagnose(taskIdFrom(vf), vf.failedNodes());
                    case MeshEvent.TaskCompleted tc ->
                            deviceFailureNodes.clear(); // reset for next task
                    default -> { /* ignore */ }
                }
            });
        }

        private void diagnose(String taskId, Set<String> verifyFailedNodes) {
            // Intersection = nodes both executor-failed AND verify-failed
            Set<String> intersection = new HashSet<>(verifyFailedNodes);
            intersection.retainAll(deviceFailureNodes);

            SelfHealAction action;
            if (!intersection.isEmpty()) {
                // DeviceFailure: tool threw → replan won't help → Degrade
                action = new SelfHealAction.Degrade(
                        "DeviceFailure: tool nodes=" + intersection);
            } else {
                // PlanOrAnswerError: LLM content wrong → replan can fix
                action = new SelfHealAction.LocalReplan(2);
            }

            bus.publish(new MeshEvent.RootCauseFound(
                    taskId, System.currentTimeMillis(),
                    action, verifyFailedNodes));

            deviceFailureNodes.clear();
        }

        // helper — taskId from any MeshEvent
        private static String taskIdFrom(MeshEvent e) { return e.taskId(); }
    }

    /**
     * Listens for {@link MeshEvent.RootCauseFound}. Dispatches based on
     * sealed {@link SelfHealAction} hierarchy (compile-time exhaustive switch).
     *
     * <p>Mirrors {@code AlphaStrategy.executeVerifyLoop:361-364} dispatch:
     * <pre>
     *   DeviceFailure / PerceptionUnreliable  → AcceptPartial
     *   PlanOrAnswerError                     → LocalReplan (with retry cap)
     * </pre>
     */
    public static final class ReplanProcessor {

        private final EventBus bus;
        private final PlannerProcessor planner;
        private final AtomicInteger replanCount = new AtomicInteger(0);
        private static final int MAX_REPLANS = 3;

        public ReplanProcessor(EventBus bus, PlannerProcessor planner) {
            this.bus = bus;
            this.planner = planner;
        }

        public void start() {
            bus.events()
                    .ofType(MeshEvent.RootCauseFound.class)
                    .subscribe(this::onRootCauseFound);
        }

        private void onRootCauseFound(MeshEvent.RootCauseFound event) {
            String taskId = event.taskId();
            SelfHealAction action = event.action();

            // Compile-time exhaustive dispatch on sealed hierarchy
            switch (action) {
                case SelfHealAction.Degrade d -> {
                    // Device fault → AcceptPartial → COMPLETED-degraded
                    bus.publish(new MeshEvent.ReplanDispatched(
                            taskId, System.currentTimeMillis(), "AcceptPartial"));
                    bus.publish(new MeshEvent.TaskCompleted(
                            taskId, System.currentTimeMillis(),
                            assembleDegradedOutput(event.failedNodes(), d.reason()),
                            false,  // verified
                            true)); // degraded
                }

                case SelfHealAction.LocalReplan lr -> {
                    int count = replanCount.incrementAndGet();
                    if (count > MAX_REPLANS) {
                        bus.publish(new MeshEvent.TaskCompleted(
                                taskId, System.currentTimeMillis(),
                                "Exhausted replan limit (" + MAX_REPLANS + ")",
                                false, true));
                    } else {
                        bus.publish(new MeshEvent.ReplanDispatched(
                                taskId, System.currentTimeMillis(),
                                "LocalReplan#" + count));
                        // Re-trigger execution — Planner publishes PlanRevised,
                        // Executor picks it up and re-executes
                        planner.replan(taskId,
                                "LocalReplan retry #" + count);
                    }
                }

                case SelfHealAction.GlobalReplan gr -> {
                    bus.publish(new MeshEvent.ReplanDispatched(
                            taskId, System.currentTimeMillis(), "GlobalReplan"));
                    planner.replan(taskId, "GlobalReplan restart");
                }
            }
        }

        private static String assembleDegradedOutput(
                Set<String> failedNodes, String reason) {
            return String.format(
                    "degraded: failed_nodes=%s, reason=%s", failedNodes, reason);
        }

        public int replanCount() { return replanCount.get(); }
    }

    // ========================================================================
    // 5. CostTrackerProcessor — NEW CAPABILITY, ZERO CHANGES TO EXISTING CODE
    // ========================================================================

    /**
     * Cost monitoring — added with <b>zero changes</b> to the 5 core processors.
     *
     * <p>This is the radical claim in practice:
     * <ul>
     *   <li>Subscribes to {@link MeshEvent.NodeCompleted} — logs "success cost" per node</li>
     *   <li>Subscribes to {@link MeshEvent.NodeFailed} — logs "wasted attempt" per node</li>
     *   <li>Subscribes to {@link MeshEvent.TaskCompleted} — prints cost summary</li>
     *   <li>Publishes {@link MeshEvent.CostTracked} — downstream can consume</li>
     * </ul>
     *
     * <p>No changes to PlannerProcessor, ExecutorProcessor, VerifierProcessor,
     * RootCauseProcessor, or ReplanProcessor. No changes to EventBus. No changes
     * to MeshEvent sealed hierarchy (CostTracked was planned from the start).
     */
    public static final class CostTrackerProcessor {

        private final EventBus bus;
        private final Map<String, Double> nodeCosts = new ConcurrentHashMap<>();
        private final Map<String, Integer> nodeFailureCounts = new ConcurrentHashMap<>();

        public CostTrackerProcessor(EventBus bus) {
            this.bus = bus;
        }

        public void start() {
            // NodeCompleted → accumulate cost
            bus.events()
                    .ofType(MeshEvent.NodeCompleted.class)
                    .subscribe(nc -> {
                        double cost = estimateCost(nc.nodeId());
                        nodeCosts.merge(nc.taskId() + "::" + nc.nodeId(), cost, Double::sum);
                        bus.publish(new MeshEvent.CostTracked(
                                nc.taskId(), System.currentTimeMillis(),
                                "node_completed", cost));
                    });

            // NodeFailed → log wasted attempt (no LLM cost if tool throws)
            bus.events()
                    .ofType(MeshEvent.NodeFailed.class)
                    .subscribe(nf -> {
                        nodeFailureCounts.merge(
                                nf.taskId() + "::" + nf.nodeId(), 1, Integer::sum);
                        bus.publish(new MeshEvent.CostTracked(
                                nf.taskId(), System.currentTimeMillis(),
                                "node_failed", 0.0));
                    });

            // TaskCompleted → print summary (in production: emit metrics, charge billing)
            bus.events()
                    .ofType(MeshEvent.TaskCompleted.class)
                    .subscribe(tc -> {
                        double total = totalCost();
                        int fails = totalFailures();
                        System.out.printf(
                                "[CostTracker] task=%s totalCost=$%.4f failures=%d degraded=%s%n",
                                tc.taskId(), total, fails, tc.degraded());
                    });
        }

        /**
         * Rough LLM cost estimation: LLM_CALL nodes ~$0.015, TOOL_CALL ~$0.001.
         */
        private static double estimateCost(String nodeId) {
            return nodeId.contains("calculate") ? 0.001 : 0.015;
        }

        public double totalCost() {
            return nodeCosts.values().stream()
                    .mapToDouble(Double::doubleValue).sum();
        }

        public int totalFailures() {
            return nodeFailureCounts.values().stream()
                    .mapToInt(Integer::intValue).sum();
        }
    }

    // ========================================================================
    // 6. E3 Trace — end-to-end device fault simulation
    // ========================================================================

    /**
     * Run full E3 trace: device fault (tool throws RuntimeException) → degraded completion.
     *
     * <p>Expected event sequence:
     * <ol>
     *   <li>GoalReceived</li>
     *   <li>PlanGenerated (3 nodes: research, calculate, write)</li>
     *   <li>NodeStarted(node_research) → NodeCompleted(node_research)</li>
     *   <li>NodeStarted(node_calculate) → <b>NodeFailed(node_calculate)</b></li>
     *   <li>NodeStarted(node_write) → NodeCompleted(node_write)</li>
     *   <li>LayerCompleted (node_results contains research + write only)</li>
     *   <li>VerifyFailed (failedNodes = {node_calculate})</li>
     *   <li>RootCauseFound (DeviceFailure, action=Degrade)</li>
     *   <li>ReplanDispatched (AcceptPartial)</li>
     *   <li>TaskCompleted (verified=false, degraded=true)</li>
     * </ol>
     *
     * @return all events collected from the bus during the trace
     */
    public static List<MeshEvent> runE3Trace() {
        EventBus bus = new EventBus();
        List<MeshEvent> collected = new CopyOnWriteArrayList<>();
        bus.events().subscribe(collected::add);

        // Wire 5 processors — declarative, no imperative sequencing
        PlannerProcessor planner = new PlannerProcessor(bus);
        ExecutorProcessor executor = new ExecutorProcessor(bus);
        VerifierProcessor verifier = new VerifierProcessor(bus);
        RootCauseProcessor rootCause = new RootCauseProcessor(bus);
        ReplanProcessor replan = new ReplanProcessor(bus, planner);

        planner.start();
        executor.start();
        verifier.start();
        rootCause.start();
        replan.start();

        // E3 injection: node_calculate is a TOOL_CALL that will throw
        executor.setFailNode("node_calculate");

        // Kick off — the event that starts everything
        bus.publish(new MeshEvent.GoalReceived(
                "task-e3", System.currentTimeMillis(),
                "Compute insurance premium for policy #12345"));

        // Wait for async delivery (processors subscribe on the publishing thread
        // via Sinks.Many multicast, so delivery is synchronous — but a brief sleep
        // ensures all processors have processed the event chain)
        sleepQuietly(100);

        return collected;
    }

    /**
     * Same E3 trace with CostTrackerProcessor added.
     * <b>The 5 core processors are completely unmodified.</b>
     *
     * @return all events + CostTracked events interleaved
     */
    public static List<MeshEvent> runE3TraceWithCostTracker() {
        EventBus bus = new EventBus();
        List<MeshEvent> collected = new CopyOnWriteArrayList<>();
        bus.events().subscribe(collected::add);

        // --- Same 5 processors, UNMODIFIED ---
        PlannerProcessor planner = new PlannerProcessor(bus);
        ExecutorProcessor executor = new ExecutorProcessor(bus);
        VerifierProcessor verifier = new VerifierProcessor(bus);
        RootCauseProcessor rootCause = new RootCauseProcessor(bus);
        ReplanProcessor replan = new ReplanProcessor(bus, planner);

        // --- NEW: CostTrackerProcessor — ONE LINE to add ---
        CostTrackerProcessor costTracker = new CostTrackerProcessor(bus);

        planner.start();
        executor.start();
        verifier.start();
        rootCause.start();
        replan.start();
        costTracker.start();

        executor.setFailNode("node_calculate");

        bus.publish(new MeshEvent.GoalReceived(
                "task-e3-cost", System.currentTimeMillis(),
                "Compute insurance premium for policy #12345"));

        sleepQuietly(100);

        return collected;
    }

    private static void sleepQuietly(long millis) {
        try {
            Thread.sleep(millis);
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
        }
    }
}
