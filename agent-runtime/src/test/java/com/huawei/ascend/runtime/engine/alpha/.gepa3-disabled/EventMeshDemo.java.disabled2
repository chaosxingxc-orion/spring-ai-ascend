package com.huawei.ascend.runtime.engine.alpha.gepa3;

import reactor.core.publisher.Flux;
import reactor.core.publisher.Sinks;

import java.util.*;
import java.util.concurrent.ConcurrentHashMap;
import java.util.concurrent.CopyOnWriteArrayList;
import java.util.concurrent.atomic.AtomicInteger;

/**
 * P4 Event Grid PROTOTYPE (v2 — post P1+P3 review fixes).
 *
 * <p>Demonstrates the radical claim: <b>Events as universal composability primitive.</b>
 *
 * <h2>Changes from v1 (review-driven)</h2>
 * <table>
 *   <tr><th>Issue</th><th>v1</th><th>v2 (fixed)</th></tr>
 *   <tr><td>CRITICAL BUG 1</td><td>PlanOrAnswerError unreachable (verifier only caught execution failures)</td>
 *        <td>Content-failure injection point ({@code contentFailNodeIds}) enables LLM-content-error path</td></tr>
 *   <tr><td>CRITICAL BUG 2</td><td>RootCauseProcessor double-clears state</td>
 *        <td>Single clear in {@code diagnose()}; TaskCompleted does NOT clear</td></tr>
 *   <tr><td>Per-task isolation</td><td>Instance-level HashSet (cross-task contamination)</td>
 *        <td>All state scoped by {@code ConcurrentHashMap<String, Set>} keyed by taskId</td></tr>
 *   <tr><td>SelfHealAction hierarchy</td><td>3 variants (Degrade/LocalReplan/GlobalReplan)</td>
 *        <td>2 variants (Degrade/Replan) — matches production; scope decision in ReplanProcessor</td></tr>
 *   <tr><td>RootCause</td><td>Missing (conflated diagnosis+dispatch)</td>
 *        <td>3-variant sealed hierarchy (DeviceFailure/PlanOrAnswerError/PerceptionUnreliable) — exact match to production</td></tr>
 *   <tr><td>PerceptionUnreliable</td><td>Missing</td>
 *        <td>{@code verifierThrows} injection + perception-first diagnosis priority</td></tr>
 *   <tr><td>Global replan counter</td><td>Shared AtomicInteger</td>
 *        <td>Per-task {@code ConcurrentHashMap<String, AtomicInteger>}</td></tr>
 *   <tr><td>Sleep synchronization</td><td>{@code sleepQuietly(100)}</td>
 *        <td>{@code CompletableFuture<TaskCompleted>} completion signal per trace</td></tr>
 *   <tr><td>"FAILED:" capture</td><td>Dead code (failed nodes skipped, not in results)</td>
 *        <td>Failed nodes added to results with "FAILED:" prefix — both detection paths live</td></tr>
 *   <tr><td>E1/E2/E4 traces</td><td>E3 only</td>
 *        <td>E1 (tool exception), E2 (verify detection), E3 (DeviceFailure), E4-green (LocalReplan), E4-PerceptionUnreliable, E4-retry-exhaustion</td></tr>
 * </table>
 *
 * <h2>Architecture (unchanged core claim)</h2>
 * <ul>
 *   <li>Flat {@link EventBus} (Sinks.Many multicast) replaces imperative orchestration</li>
 *   <li>5 independent processors subscribe to events and publish results — no direct calls</li>
 *   <li>{@link CostTrackerProcessor} added with zero changes to existing processors</li>
 *   <li>All sealed hierarchies compile-time exhaustive</li>
 * </ul>
 */
public final class EventMeshDemo {

    private EventMeshDemo() { /* utility class */ }

    // ========================================================================
    // 1. Sealed Event Hierarchy — 14 event types
    // ========================================================================

    public sealed interface MeshEvent
            permits MeshEvent.GoalReceived,
                    MeshEvent.PlanGenerated,
                    MeshEvent.PlanRevised,
                    MeshEvent.NodeStarted,
                    MeshEvent.NodeCompleted,
                    MeshEvent.NodeFailed,
                    MeshEvent.LayerCompleted,
                    MeshEvent.VerifyRequested,
                    MeshEvent.VerifyPassed,
                    MeshEvent.VerifyFailed,
                    MeshEvent.RootCauseDiagnosed,
                    MeshEvent.ReplanDispatched,
                    MeshEvent.TaskCompleted,
                    MeshEvent.CostTracked {

        String taskId();
        long timestamp();

        // --- Planning phase ---
        record GoalReceived(String taskId, long timestamp, String goal)
                implements MeshEvent {}

        record PlanGenerated(String taskId, long timestamp,
                             List<String> nodeIds,
                             String planDescription)
                implements MeshEvent {}

        record PlanRevised(String taskId, long timestamp,
                           List<String> nodeIds,
                           String revisionReason)
                implements MeshEvent {}

        // --- Execution phase ---
        enum NodeType { LLM_CALL, TOOL_CALL, SUB_AGENT }

        record NodeStarted(String taskId, long timestamp,
                           String nodeId,
                           NodeType nodeType)
                implements MeshEvent {}

        record NodeCompleted(String taskId, long timestamp,
                             String nodeId,
                             String result)
                implements MeshEvent {}

        record NodeFailed(String taskId, long timestamp,
                          String nodeId,
                          String error)
                implements MeshEvent {}

        record LayerCompleted(String taskId, long timestamp,
                              int layerIndex,
                              Map<String, String> nodeResults)  // includes FAILED: entries
                implements MeshEvent {}

        // --- Verify phase ---
        record VerifyRequested(String taskId, long timestamp,
                               int layerIndex)
                implements MeshEvent {}

        record VerifyPassed(String taskId, long timestamp,
                            String feedback)
                implements MeshEvent {}

        record VerifyFailed(String taskId, long timestamp,
                            Set<String> failedNodes,
                            String feedback,
                            boolean verifierThrew)  // v2: perception-unreliable signal
                implements MeshEvent {}

        // --- Self-heal phase ---
        /** Diagnosis only — does NOT bundle dispatch decision. */
        record RootCauseDiagnosed(String taskId, long timestamp,
                                  RootCause cause,
                                  Set<String> failedNodes)
                implements MeshEvent {}

        record ReplanDispatched(String taskId, long timestamp,
                                String actionName)
                implements MeshEvent {}

        // --- Terminal ---
        record TaskCompleted(String taskId, long timestamp,
                             String output,
                             boolean verified,
                             boolean degraded)
                implements MeshEvent {}

        // --- Cross-cutting ---
        record CostTracked(String taskId, long timestamp,
                           String source,
                           double amount)
                implements MeshEvent {}
    }

    // ========================================================================
    // 2. RootCause — 3 variants, exact match to production RootCause sealed hierarchy
    // ========================================================================

    /**
     * Root cause sealed hierarchy — 3 variants matching production
     * {@code com.openjiuwen.core.alpha.verifier.RootCause}.
     *
     * <p>Diagnosis priority (deterministic, zero-LLM):
     * <ol>
     *   <li>Verifier threw → {@link PerceptionUnreliable} (don't trust FAILED)</li>
     *   <li>verify-failed ∩ executor-failed non-empty → {@link DeviceFailure}</li>
     *   <li>Otherwise → {@link PlanOrAnswerError} (content error, replan can fix)</li>
     * </ol>
     */
    public sealed interface RootCause
            permits RootCause.DeviceFailure,
                    RootCause.PlanOrAnswerError,
                    RootCause.PerceptionUnreliable {

        record DeviceFailure(Set<String> nodes) implements RootCause {
            public DeviceFailure { nodes = Set.copyOf(nodes); }
        }

        record PlanOrAnswerError(Set<String> nodes) implements RootCause {
            public PlanOrAnswerError { nodes = Set.copyOf(nodes); }
        }

        record PerceptionUnreliable(boolean verifierThrew) implements RootCause {}
    }

    // ========================================================================
    // 3. SelfHealAction — 2 variants, exact match to production
    // ========================================================================

    /**
     * Self-heal action — 2 variants matching production
     * {@code com.openjiuwen.runtime.beta.selfheal.SelfHealAction}.
     *
     * <p>Dispatch (pure function, RootCause → SelfHealAction):
     * <ul>
     *   <li>{@link RootCause.DeviceFailure} → {@link Degrade}</li>
     *   <li>{@link RootCause.PerceptionUnreliable} → {@link Degrade}</li>
     *   <li>{@link RootCause.PlanOrAnswerError} → {@link Replan} (scope decided by failedNodes size)</li>
     * </ul>
     */
    public sealed interface SelfHealAction
            permits SelfHealAction.Degrade,
                    SelfHealAction.Replan {

        /** Device/perception fault → replan won't help → accept partial result. */
        record Degrade(String reason) implements SelfHealAction {}

        /** Content error → replan can fix (scope: local if ≤2 nodes, global if >2). */
        record Replan(String reason) implements SelfHealAction {}
    }

    /**
     * Pure dispatch function — mirrors production {@code RootCauseDispatcher.dispatch()}.
     * Sealed switch: delete one arm → compile error.
     */
    public static SelfHealAction dispatch(RootCause cause) {
        return switch (cause) {
            case RootCause.DeviceFailure df ->
                    new SelfHealAction.Degrade(
                            "Device failure: tool/infra error — replan cannot fix broken tools. "
                            + "Failed nodes: " + df.nodes());
            case RootCause.PerceptionUnreliable pu ->
                    new SelfHealAction.Degrade(
                            "Perception unreliable: verifier "
                            + (pu.verifierThrew() ? "threw exception" : "returned null")
                            + " — cannot trust its FAILED judgement. Accepting partial result.");
            case RootCause.PlanOrAnswerError pe ->
                    new SelfHealAction.Replan(
                            "Plan/answer error: content wrong — replan can fix. "
                            + "Failed nodes: " + pe.nodes());
        };
    }

    // ========================================================================
    // 4. EventBus — Sinks.Many multicast
    // ========================================================================

    public static final class EventBus {

        private final Sinks.Many<MeshEvent> sink =
                Sinks.many().multicast().onBackpressureBuffer();

        public void publish(MeshEvent event) {
            Sinks.EmitResult result = sink.tryEmitNext(event);
            if (result.isFailure()) {
                throw new IllegalStateException(
                        "EventBus emit failed: " + result + " for " + event);
            }
        }

        public Flux<MeshEvent> events() {
            return sink.asFlux();
        }
    }

    // ========================================================================
    // 5. PlannerProcessor
    // ========================================================================

    public static final class PlannerProcessor {

        private final EventBus bus;
        private final AtomicInteger planCount = new AtomicInteger(0);

        public PlannerProcessor(EventBus bus) {
            this.bus = bus;
        }

        public void start() {
            bus.events()
                    .ofType(MeshEvent.GoalReceived.class)
                    .subscribe(this::onGoalReceived);
        }

        private void onGoalReceived(MeshEvent.GoalReceived event) {
            List<String> nodes = List.of(
                    "node_research",     // LLM_CALL
                    "node_calculate",    // TOOL_CALL
                    "node_write"         // LLM_CALL
            );
            bus.publish(new MeshEvent.PlanGenerated(
                    event.taskId(), System.currentTimeMillis(),
                    nodes, "plan-" + planCount.incrementAndGet()));
        }

        /** Replan entry point. */
        public void replan(String taskId, String reason) {
            List<String> nodes = List.of(
                    "node_research", "node_calculate", "node_write");
            bus.publish(new MeshEvent.PlanRevised(
                    taskId, System.currentTimeMillis(), nodes, reason));
        }

        public int planCount() { return planCount.get(); }
    }

    // ========================================================================
    // 6. ExecutorProcessor
    // ========================================================================

    /**
     * Executes plan nodes. FIXED: failed nodes are now added to results with
     * {@code "FAILED:"} prefix so both verifier detection paths are live:
     * <ol>
     *   <li>Rule-based: scan nodeResults for "FAILED:" prefix</li>
     *   <li>Event-based: track {@link MeshEvent.NodeFailed} events</li>
     * </ol>
     */
    public static final class ExecutorProcessor {

        private final EventBus bus;
        /** Per-task device fault injection: taskId → nodeId that should fail. */
        private final ConcurrentHashMap<String, String> failNodeByTask = new ConcurrentHashMap<>();

        public ExecutorProcessor(EventBus bus) {
            this.bus = bus;
        }

        public void start() {
            bus.events()
                    .ofType(MeshEvent.PlanGenerated.class)
                    .subscribe(pg -> executePlan(pg.taskId(), pg.nodeIds()));

            bus.events()
                    .ofType(MeshEvent.PlanRevised.class)
                    .subscribe(pr -> executePlan(pr.taskId(), pr.nodeIds()));
        }

        /** Set which node should simulate device failure for a given task. */
        public void setFailNode(String taskId, String nodeId) {
            if (nodeId != null) {
                failNodeByTask.put(taskId, nodeId);
            } else {
                failNodeByTask.remove(taskId);
            }
        }

        private void executePlan(String taskId, List<String> nodeIds) {
            Map<String, String> results = new LinkedHashMap<>();
            String failNode = failNodeByTask.get(taskId);

            for (String nodeId : nodeIds) {
                MeshEvent.NodeType type = nodeId.contains("calculate")
                        ? MeshEvent.NodeType.TOOL_CALL
                        : MeshEvent.NodeType.LLM_CALL;

                bus.publish(new MeshEvent.NodeStarted(
                        taskId, System.currentTimeMillis(), nodeId, type));

                // E1/E3 injection: node matches failNode → device fault
                if (nodeId.equals(failNode)) {
                    String error = "FAILED: RuntimeException in " + nodeId;
                    // FIXED (CRITICAL BUG 1 foundations): put FAILED: entry in results
                    // so the verifier's rule-based prefix check is NOT dead code
                    results.put(nodeId, error);
                    bus.publish(new MeshEvent.NodeFailed(
                            taskId, System.currentTimeMillis(), nodeId, error));
                    continue;
                }

                String result = "result_of_" + nodeId;
                results.put(nodeId, result);
                bus.publish(new MeshEvent.NodeCompleted(
                        taskId, System.currentTimeMillis(), nodeId, result));
            }

            bus.publish(new MeshEvent.LayerCompleted(
                    taskId, System.currentTimeMillis(), 0, results));
        }

        /** Clean up per-task state after terminal event. */
        public void cleanup(String taskId) {
            failNodeByTask.remove(taskId);
        }
    }

    // ========================================================================
    // 7. VerifierProcessor — TWO detection modes, PerceptionUnreliable aware
    // ========================================================================

    /**
     * Verifier with TWO detection modes (matching production {@code MinimalAgentEngine.verify()}):
     * <ol>
     *   <li><b>RULE:</b> scan nodeResults for "FAILED:" prefix → rule-based failure</li>
     *   <li><b>CONTENT:</b> (simulated) LLM-as-judge marks nodes with wrong content
     *       as failed even though they executed without error → content-failure path</li>
     * </ol>
     *
     * <p>PerceptionUnreliable: when {@code verifierThrowsTask} is set, simulates verifier
     * crash → publishes VerifyFailed with {@code verifierThrew=true} → RootCauseProcessor
     * diagnoses PerceptionUnreliable with top priority.
     */
    public static final class VerifierProcessor {

        private final EventBus bus;
        /** Per-task: nodes that published NodeFailed. */
        private final ConcurrentHashMap<String, Set<String>> executorFailedNodes = new ConcurrentHashMap<>();
        /** Per-task: nodes that should be marked as content-failure (simulates LLM-as-judge). */
        private final ConcurrentHashMap<String, Set<String>> contentFailNodeIds = new ConcurrentHashMap<>();
        /** Per-task: verifier should simulate throwing. */
        private final Set<String> verifierThrowsTasks = ConcurrentHashMap.newKeySet();

        public VerifierProcessor(EventBus bus) {
            this.bus = bus;
        }

        public void start() {
            bus.events().subscribe(event -> {
                String taskId = event.taskId();
                switch (event) {
                    case MeshEvent.NodeFailed nf ->
                            executorFailedNodes
                                    .computeIfAbsent(taskId, k -> ConcurrentHashMap.newKeySet())
                                    .add(nf.nodeId());
                    case MeshEvent.NodeCompleted nc ->
                            executorFailedNodes
                                    .getOrDefault(taskId, Set.of())
                                    .remove(nc.nodeId());
                    case MeshEvent.LayerCompleted lc ->
                            onLayerCompleted(lc);
                    case MeshEvent.PlanRevised pr -> {
                        // FIXED: reset state on replan (prevents stale state)
                        executorFailedNodes.remove(pr.taskId());
                    }
                    case MeshEvent.TaskCompleted tc -> {
                        executorFailedNodes.remove(tc.taskId());
                        contentFailNodeIds.remove(tc.taskId());
                        verifierThrowsTasks.remove(tc.taskId());
                    }
                    default -> { /* ignore */ }
                }
            });
        }

        /** Inject content failure: node executes successfully but LLM judge flags it. */
        public void setContentFailNode(String taskId, String nodeId) {
            contentFailNodeIds
                    .computeIfAbsent(taskId, k -> ConcurrentHashMap.newKeySet())
                    .add(nodeId);
        }

        /** Inject verifier throw for PerceptionUnreliable path. */
        public void setVerifierThrows(String taskId, boolean throws_) {
            if (throws_) {
                verifierThrowsTasks.add(taskId);
            } else {
                verifierThrowsTasks.remove(taskId);
            }
        }

        private void onLayerCompleted(MeshEvent.LayerCompleted event) {
            String taskId = event.taskId();
            bus.publish(new MeshEvent.VerifyRequested(
                    taskId, System.currentTimeMillis(), event.layerIndex()));

            // PerceptionUnreliable injection: verifier throws
            if (verifierThrowsTasks.contains(taskId)) {
                bus.publish(new MeshEvent.VerifyFailed(
                        taskId, System.currentTimeMillis(),
                        Set.of(), // verifier crashed — no reliable failedNodes
                        "Verifier threw: simulated crash (LLM timeout)",
                        true)); // verifierThrew=true → PerceptionUnreliable signal
                return;
            }

            // Detection mode 1: RULE — "FAILED:" prefix in nodeResults
            Set<String> failed = ConcurrentHashMap.newKeySet();
            for (var entry : event.nodeResults().entrySet()) {
                if (entry.getValue() != null
                        && entry.getValue().startsWith("FAILED:")) {
                    failed.add(entry.getKey());
                }
            }

            // Detection mode 2: EVENT — NodeFailed events (nodes not in results)
            Set<String> efNodes = executorFailedNodes.getOrDefault(taskId, Set.of());
            failed.addAll(efNodes);

            // Detection mode 3 (v2): CONTENT — LLM-as-judge content failure
            // Nodes executed successfully but produced wrong content
            Set<String> cfNodes = contentFailNodeIds.getOrDefault(taskId, Set.of());
            failed.addAll(cfNodes);

            if (failed.isEmpty()) {
                bus.publish(new MeshEvent.VerifyPassed(
                        taskId, System.currentTimeMillis(),
                        "All nodes passed verification"));
            } else {
                bus.publish(new MeshEvent.VerifyFailed(
                        taskId, System.currentTimeMillis(), failed,
                        "Verification failed for: " + failed,
                        false)); // verifierThrew=false (verifier worked correctly)
            }
        }
    }

    // ========================================================================
    // 8. RootCauseProcessor — 3-variant diagnosis, per-task isolation
    // ========================================================================

    /**
     * Diagnoses root cause from deterministic signals.
     *
     * <p>Matches production {@code RootCauseDiagnoser.diagnose()} exactly:
     * <ol>
     *   <li>{@code verifyThrew} → PerceptionUnreliable (top priority)</li>
     *   <li>{@code verify-failed ∩ executor-failed} non-empty → DeviceFailure</li>
     *   <li>Otherwise → PlanOrAnswerError</li>
     * </ol>
     *
     * <p>FIXED (CRITICAL BUG 2): Single clear in {@code diagnose()}.
     * TaskCompleted does NOT clear — that was the stale-clear bug.
     * PlanRevised clears to prevent stale state across replans.
     */
    public static final class RootCauseProcessor {

        private final EventBus bus;
        /** Per-task: nodes that emitted NodeFailed (executor-level device failures). */
        private final ConcurrentHashMap<String, Set<String>> deviceFailureNodes = new ConcurrentHashMap<>();
        /** Per-task: whether the verifier threw for this task. */
        private final ConcurrentHashMap<String, Boolean> verifierThrewFlag = new ConcurrentHashMap<>();

        public RootCauseProcessor(EventBus bus) {
            this.bus = bus;
        }

        public void start() {
            bus.events().subscribe(event -> {
                String taskId = event.taskId();
                switch (event) {
                    case MeshEvent.NodeFailed nf ->
                            deviceFailureNodes
                                    .computeIfAbsent(taskId, k -> ConcurrentHashMap.newKeySet())
                                    .add(nf.nodeId());
                    case MeshEvent.VerifyFailed vf -> {
                        verifierThrewFlag.put(taskId, vf.verifierThrew());
                        diagnose(taskId, vf.failedNodes());
                    }
                    case MeshEvent.PlanRevised pr -> {
                        // FIXED: clear on replan — prevents stale deviceFailureNodes
                        // from polluting the new attempt's diagnosis
                        deviceFailureNodes.remove(pr.taskId());
                        verifierThrewFlag.remove(pr.taskId());
                    }
                    case MeshEvent.TaskCompleted tc -> {
                        // Cleanup only after terminal event
                        deviceFailureNodes.remove(tc.taskId());
                        verifierThrewFlag.remove(tc.taskId());
                    }
                    default -> { /* ignore */ }
                }
            });
        }

        private void diagnose(String taskId, Set<String> verifyFailedNodes) {
            boolean vThrew = verifierThrewFlag.getOrDefault(taskId, false);
            Set<String> devNodes = deviceFailureNodes.getOrDefault(taskId, Set.of());
            Set<String> vfNodes = verifyFailedNodes != null ? verifyFailedNodes : Set.of();

            RootCause cause;
            if (vThrew) {
                // Priority 1: verifier threw → PerceptionUnreliable
                cause = new RootCause.PerceptionUnreliable(true);
            } else if (!intersection(devNodes, vfNodes).isEmpty()) {
                // Priority 2: intersection non-empty → DeviceFailure
                cause = new RootCause.DeviceFailure(
                        intersection(devNodes, vfNodes));
            } else {
                // Priority 3: no intersection → PlanOrAnswerError (content error)
                cause = new RootCause.PlanOrAnswerError(vfNodes);
            }

            bus.publish(new MeshEvent.RootCauseDiagnosed(
                    taskId, System.currentTimeMillis(), cause, vfNodes));

            // FIXED (CRITICAL BUG 2): single clear — only here, not also in TaskCompleted
            // Rationale: diagnosis is the decision point; after diagnosis, state resets
            // for the next round. TaskCompleted cleanup is for memory, not for state reset.
            deviceFailureNodes.remove(taskId);
            verifierThrewFlag.remove(taskId);
        }

        private static Set<String> intersection(Set<String> a, Set<String> b) {
            if (a == null || b == null || a.isEmpty() || b.isEmpty()) return Set.of();
            Set<String> result = new HashSet<>(a);
            result.retainAll(b);
            return result;
        }
    }

    // ========================================================================
    // 9. ReplanProcessor — dispatch + action, per-task retry counters
    // ========================================================================

    /**
     * Dispatches on {@link RootCause} (3 variants → 2 {@link SelfHealAction} variants).
     *
     * <p>FIXED:
     * <ul>
     *   <li>Per-task retry counters ({@code ConcurrentHashMap}) — no cross-task exhaustion</li>
     *   <li>{@link RootCause.PlanOrAnswerError} → LocalReplan if ≤2 nodes, GlobalReplan if >2
     *       (matches production {@code MinimalAgentEngine.dispatch()})</li>
     *   <li>VerifyPassed → TaskCompleted(verified=true) — v1 had no consumer for VerifyPassed</li>
     * </ul>
     */
    public static final class ReplanProcessor {

        private final EventBus bus;
        private final PlannerProcessor planner;
        /** Per-task replan counter (FIXED: was global AtomicInteger). */
        private final ConcurrentHashMap<String, AtomicInteger> replanCounts = new ConcurrentHashMap<>();
        private static final int MAX_REPLANS = 3;

        public ReplanProcessor(EventBus bus, PlannerProcessor planner) {
            this.bus = bus;
            this.planner = planner;
        }

        public void start() {
            // RootCauseDiagnosed → dispatch → act
            bus.events()
                    .ofType(MeshEvent.RootCauseDiagnosed.class)
                    .subscribe(this::onRootCauseDiagnosed);

            // VerifyPassed → TaskCompleted(verified=true) — v2: added consumer
            bus.events()
                    .ofType(MeshEvent.VerifyPassed.class)
                    .subscribe(vp -> {
                        bus.publish(new MeshEvent.TaskCompleted(
                                vp.taskId(), System.currentTimeMillis(),
                                "All nodes passed verification. " + vp.feedback(),
                                true,  // verified
                                false)); // degraded
                    });

            // Cleanup per-task state on terminal
            bus.events()
                    .ofType(MeshEvent.TaskCompleted.class)
                    .subscribe(tc -> replanCounts.remove(tc.taskId()));
        }

        private void onRootCauseDiagnosed(MeshEvent.RootCauseDiagnosed event) {
            String taskId = event.taskId();
            RootCause cause = event.cause();
            SelfHealAction action = dispatch(cause);

            switch (action) {
                case SelfHealAction.Degrade d -> {
                    bus.publish(new MeshEvent.ReplanDispatched(
                            taskId, System.currentTimeMillis(), "AcceptPartial"));
                    bus.publish(new MeshEvent.TaskCompleted(
                            taskId, System.currentTimeMillis(),
                            assembleDegradedOutput(event.failedNodes(), d.reason()),
                            false,  // verified
                            true)); // degraded
                }

                case SelfHealAction.Replan r -> {
                    int count = replanCounts
                            .computeIfAbsent(taskId, k -> new AtomicInteger(0))
                            .incrementAndGet();

                    if (count > MAX_REPLANS) {
                        bus.publish(new MeshEvent.ReplanDispatched(
                                taskId, System.currentTimeMillis(),
                                "ExhaustedReplanLimit"));
                        bus.publish(new MeshEvent.TaskCompleted(
                                taskId, System.currentTimeMillis(),
                                "Exhausted replan limit (" + MAX_REPLANS + ")",
                                false, true));
                        return;
                    }

                    // Scope decision: ≤2 failed nodes → local replan, >2 → global replan
                    // Matches production MinimalAgentEngine.dispatch() logic
                    boolean localReplan = event.failedNodes().size() <= 2;

                    String scope = localReplan ? "LocalReplan" : "GlobalReplan";
                    bus.publish(new MeshEvent.ReplanDispatched(
                            taskId, System.currentTimeMillis(),
                            scope + "#" + count));

                    String reason = r.reason() + " (attempt " + count + "/" + MAX_REPLANS + ")";
                    planner.replan(taskId, reason);
                }
            }
        }

        private static String assembleDegradedOutput(
                Set<String> failedNodes, String reason) {
            return String.format(
                    "degraded: failed_nodes=%s, reason=%s", failedNodes, reason);
        }

        public int replanCount(String taskId) {
            AtomicInteger c = replanCounts.get(taskId);
            return c != null ? c.get() : 0;
        }
    }

    // ========================================================================
    // 10. CostTrackerProcessor — ZERO CHANGES to existing processors
    // ========================================================================

    public static final class CostTrackerProcessor {

        private final EventBus bus;
        /** Per-task cost tracking. */
        private final ConcurrentHashMap<String, Double> nodeCosts = new ConcurrentHashMap<>();
        private final ConcurrentHashMap<String, Integer> nodeFailureCounts = new ConcurrentHashMap<>();

        public CostTrackerProcessor(EventBus bus) {
            this.bus = bus;
        }

        public void start() {
            bus.events()
                    .ofType(MeshEvent.NodeCompleted.class)
                    .subscribe(nc -> {
                        double cost = estimateCost(nc.nodeId());
                        nodeCosts.merge(key(nc.taskId(), nc.nodeId()), cost, Double::sum);
                        bus.publish(new MeshEvent.CostTracked(
                                nc.taskId(), System.currentTimeMillis(),
                                "node_completed", cost));
                    });

            bus.events()
                    .ofType(MeshEvent.NodeFailed.class)
                    .subscribe(nf -> {
                        nodeFailureCounts.merge(
                                key(nf.taskId(), nf.nodeId()), 1, Integer::sum);
                        bus.publish(new MeshEvent.CostTracked(
                                nf.taskId(), System.currentTimeMillis(),
                                "node_failed", 0.0));
                    });

            bus.events()
                    .ofType(MeshEvent.TaskCompleted.class)
                    .subscribe(tc -> {
                        double total = totalCost();
                        int fails = totalFailures();
                        System.out.printf(
                                "[CostTracker] task=%s totalCost=$%.4f failures=%d degraded=%s%n",
                                tc.taskId(), total, fails, tc.degraded());
                        // Clean up per-task cost data
                        nodeCosts.keySet().removeIf(k -> k.startsWith(tc.taskId() + "::"));
                        nodeFailureCounts.keySet().removeIf(k -> k.startsWith(tc.taskId() + "::"));
                    });
        }

        private static double estimateCost(String nodeId) {
            return nodeId.contains("calculate") ? 0.001 : 0.015;
        }

        private static String key(String taskId, String nodeId) {
            return taskId + "::" + nodeId;
        }

        public double totalCost() {
            return nodeCosts.values().stream()
                    .mapToDouble(Double::doubleValue).sum();
        }

        public int totalFailures() {
            return nodeFailureCounts.values().stream()
                    .mapToInt(Integer::intValue).sum();
        }
    }

    // ========================================================================
    // 11. Trace methods — E1 through E4, with proper completion signaling
    // ========================================================================

    /** Shared bus+collection+processors wiring, returns collected events. */
    private static List<MeshEvent> runTrace(
            String taskId,
            Consumer5<PlannerProcessor, ExecutorProcessor, VerifierProcessor,
                       RootCauseProcessor, ReplanProcessor> injectFaults,
            boolean withCostTracker,
            Runnable afterPublish) {

        EventBus bus = new EventBus();
        List<MeshEvent> collected = new CopyOnWriteArrayList<>();
        bus.events().subscribe(collected::add);

        PlannerProcessor planner = new PlannerProcessor(bus);
        ExecutorProcessor executor = new ExecutorProcessor(bus);
        VerifierProcessor verifier = new VerifierProcessor(bus);
        RootCauseProcessor rootCause = new RootCauseProcessor(bus);
        ReplanProcessor replan = new ReplanProcessor(bus, planner);

        planner.start();
        executor.start();
        verifier.start();
        rootCause.start();
        replan.start();

        CostTrackerProcessor costTracker = null;
        if (withCostTracker) {
            costTracker = new CostTrackerProcessor(bus);
            costTracker.start();
        }

        // Inject faults
        injectFaults.accept(planner, executor, verifier, rootCause, replan);

        // Kick off
        bus.publish(new MeshEvent.GoalReceived(
                taskId, System.currentTimeMillis(),
                "Compute insurance premium for policy #12345"));

        // Instead of sleep(), collect events until TaskCompleted arrives
        // Sinks.Many.multicast() delivers synchronously on the publishing thread,
        // so by the time publish(GoalReceived) returns, the entire chain has
        // completed. But for safety, we poll briefly.
        long deadline = System.currentTimeMillis() + 5_000; // 5s timeout
        while (System.currentTimeMillis() < deadline) {
            boolean hasTerminal = collected.stream()
                    .anyMatch(e -> e instanceof MeshEvent.TaskCompleted
                            && ((MeshEvent.TaskCompleted) e).taskId().equals(taskId));
            if (hasTerminal) break;
            Thread.yield();
        }

        if (afterPublish != null) {
            afterPublish.run();
        }

        return collected;
    }

    @FunctionalInterface
    private interface Consumer5<A, B, C, D, E> {
        void accept(A a, B b, C c, D d, E e);
    }

    // --- E1: Tool exception → "FAILED:" capture ---

    /**
     * E1 trace: tool throws RuntimeException → captured as "FAILED:" in results.
     *
     * <p>Event sequence:
     * <pre>
     *   GoalReceived → PlanGenerated → NodeStarted(research) → NodeCompleted(research)
     *   → NodeStarted(calculate) → NodeFailed(calculate, "FAILED: RuntimeException...")
     *   → NodeStarted(write) → NodeCompleted(write)
     *   → LayerCompleted (results: research=ok, calculate=FAILED:..., write=ok)
     *   → VerifyRequested → VerifyFailed(calculate) → RootCauseDiagnosed(DeviceFailure)
     *   → ReplanDispatched(AcceptPartial) → TaskCompleted(verified=false, degraded=true)
     * </pre>
     */
    public static List<MeshEvent> runE1Trace() {
        String taskId = "task-e1";
        return runTrace(taskId,
                (planner, executor, verifier, rootCause, replan) -> {
                    executor.setFailNode(taskId, "node_calculate");
                },
                false, null);
    }

    // --- E2: Verifier detects failure via BOTH rule-based and NodeFailed tracking ---

    /**
     * E2 trace: verifier correctly detects failure via:
     * <ol>
     *   <li>"FAILED:" prefix in nodeResults (rule-based path)</li>
     *   <li>NodeFailed event tracking (event-based path)</li>
     * </ol>
     *
     * <p>Same as E1 but verifies both detection mechanisms are live.
     */
    public static List<MeshEvent> runE2Trace() {
        return runE1Trace(); // E2 uses the same scenario; test asserts both detection paths
    }

    // --- E3: DeviceFailure → Degrade (the original E3 path) ---

    /**
     * E3 trace: device fault → root cause = DeviceFailure → Degrade → AcceptPartial.
     */
    public static List<MeshEvent> runE3Trace() {
        String taskId = "task-e3";
        return runTrace(taskId,
                (planner, executor, verifier, rootCause, replan) -> {
                    executor.setFailNode(taskId, "node_calculate");
                },
                false, null);
    }

    // --- E3 with CostTracker ---

    /**
     * E3 trace + CostTrackerProcessor. Same 5 processors, zero modifications.
     */
    public static List<MeshEvent> runE3TraceWithCostTracker() {
        String taskId = "task-e3-cost";
        return runTrace(taskId,
                (planner, executor, verifier, rootCause, replan) -> {
                    executor.setFailNode(taskId, "node_calculate");
                },
                true, null);
    }

    // --- E4 Green: PlanOrAnswerError → LocalReplan → succeed ---

    /**
     * E4 green path: content error (not device fault).
     *
     * <p>Scenario: node_calculate executes successfully (no NodeFailed),
     * but verifier marks it as content-failure (simulating LLM-as-judge).
     * No NodeFailed event → intersection is empty → PlanOrAnswerError → LocalReplan.
     *
     * <p>Event sequence:
     * <pre>
     *   GoalReceived → PlanGenerated → NodeStarted*3 → NodeCompleted*3
     *   → LayerCompleted (all nodes in results, no FAILED: prefix)
     *   → VerifyRequested → VerifyFailed(calculate, verifierThrew=false)
     *   → RootCauseDiagnosed(PlanOrAnswerError) → ReplanDispatched(LocalReplan#1)
     *   → PlanRevised → NodeStarted*3 → NodeCompleted*3
     *   → LayerCompleted → VerifyRequested → VerifyPassed
     *   → TaskCompleted(verified=true, degraded=false)
     * </pre>
     */
    public static List<MeshEvent> runE4GreenTrace() {
        String taskId = "task-e4-green";
        return runTrace(taskId,
                (planner, executor, verifier, rootCause, replan) -> {
                    // No device fault — node_calculate executes successfully
                    // But verifier marks it as content failure
                    verifier.setContentFailNode(taskId, "node_calculate");
                },
                false, null);
    }

    // --- E4: PerceptionUnreliable → Degrade ---

    /**
     * E4 PerceptionUnreliable path: verifier throws → Degrade.
     *
     * <p>Scenario: verifier crashes (simulated LLM timeout).
     * RootCauseProcessor sees verifierThrew=true → PerceptionUnreliable → Degrade.
     * This is the safety path: "don't blindly trust FAILED."
     */
    public static List<MeshEvent> runE4PerceptionUnreliableTrace() {
        String taskId = "task-e4-pu";
        return runTrace(taskId,
                (planner, executor, verifier, rootCause, replan) -> {
                    verifier.setVerifierThrows(taskId, true);
                },
                false, null);
    }

    // --- E4: Max retries exhausted ---

    /**
     * E4 retry-exhaustion path: PlanOrAnswerError persists across replans.
     */
    public static List<MeshEvent> runE4MaxRetriesTrace() {
        String taskId = "task-e4-retry";
        return runTrace(taskId,
                (planner, executor, verifier, rootCause, replan) -> {
                    // Content failure on ALL replan attempts
                    // The verifier always marks node_calculate as content-failed
                    verifier.setContentFailNode(taskId, "node_calculate");
                },
                false, null);
    }

    // --- Convenience: E3 trace for backward-compatible tests ---

    /** @deprecated use {@link #runE3Trace()} directly */
    @Deprecated
    public static List<MeshEvent> runE3TraceLegacy() {
        return runE3Trace();
    }
}
