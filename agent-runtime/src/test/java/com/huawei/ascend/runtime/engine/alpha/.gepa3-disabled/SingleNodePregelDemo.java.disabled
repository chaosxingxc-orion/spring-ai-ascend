package com.huawei.ascend.runtime.engine.alpha.gepa3;

import com.openjiuwen.core.alpha.graph.TaskEdge;
import com.openjiuwen.core.alpha.graph.TaskGraph;
import com.openjiuwen.core.alpha.graph.TaskNode;
import com.openjiuwen.core.alpha.graph.TaskNodeType;
import com.openjiuwen.core.alpha.model.ExecutionPolicy;
import com.openjiuwen.core.alpha.model.PlanGoal;
import com.openjiuwen.core.alpha.model.PlanningMode;
import com.openjiuwen.core.alpha.model.VerifyMode;
import com.openjiuwen.core.alpha.verifier.ReplanStrategy;
import com.openjiuwen.core.alpha.verifier.RootCause;
import com.openjiuwen.core.alpha.verifier.VerifyResult;
import com.openjiuwen.core.kernel.model.*;
import com.openjiuwen.runtime.alpha.verifier.DefaultVerifier;
import com.openjiuwen.runtime.alpha.verifier.Verifier;
import com.openjiuwen.runtime.beta.selfheal.RootCauseDiagnoser;
import com.openjiuwen.runtime.beta.selfheal.RootCauseDispatcher;
import com.openjiuwen.runtime.beta.selfheal.SelfHealAction;
import com.openjiuwen.runtime.core.engine.AgentKernel;
import com.openjiuwen.runtime.core.engine.DefaultAgentKernel;
import com.openjiuwen.runtime.core.engine.DefaultSafetyBoundary;
import com.openjiuwen.runtime.core.fixtures.MockChatModel;
import com.openjiuwen.runtime.core.fixtures.MockCheckpointStore;
import com.openjiuwen.runtime.core.fixtures.MockToolProvider;

import java.time.Duration;
import java.util.*;

/**
 * <h1>SingleNodePregelDemo: 1-node TaskGraph 的 PEV 单轨原型</h1>
 *
 * <p>演示 1-node TaskGraph 从工具异常到根因诊断再到 LocalReplan（带 correctionHint）
 * 的完整 E1-E4 闭环。每个步骤手动驱动（不依赖 DefaultPregelExecutor/AlphaStrategy），
 * 暴露底层确定性信号流：谁失败、谁验证、诊断如何取交集、dispatch 如何抹分支。</p>
 *
 * <h2>E1-E4 语义</h2>
 * <ul>
 *   <li><b>E1 (工具异常)</b>：kernel.invokeTool() 抛 RuntimeException → 捕获为 {@code "FAILED: ..."} 字符串</li>
 *   <li><b>E2 (Verifier 感知失败)</b>：DefaultVerifier.ruleVerify() 检测 {@code "FAILED:"} 前缀 →
 *       该节点判为 verify-failed</li>
 *   <li><b>E3 (根因诊断)</b>：RootCauseDiagnoser.diagnose() 计算 verify-failed ∩ tool-failed 交集
 *       → 非空 → DeviceFailure（确定性纯函数，零 LLM 口算）</li>
 *   <li><b>E4 (sealed dispatch → Degrade → LocalReplan)</b>：
 *        E3 诊断为 DeviceFailure → Degrade（replan 无效，AcceptPartial）；
 *        绿色路径（PlanOrAnswerError）→ Replan → 构造带 correctionHint 的新 TaskNode →
 *        重新 kernel.think()（模拟 LocalReplan 自纠）</li>
 * </ul>
 *
 * <h2>与 DefaultPregelExecutor + AlphaStrategy 的对应关系</h2>
 * <table>
 *   <tr><th>本 Demo 步骤</th><th>对应 DefaultPregelExecutor</th><th>对应 AlphaStrategy</th></tr>
 *   <tr><td>kernel.invokeTool()</td><td>:258 executeToolNode → 异常捕获 :198-201</td><td>—</td></tr>
 *   <tr><td>"FAILED:" 前缀</td><td>:200 nodeResults.put(id, "FAILED: " + e.getMessage())</td><td>—</td></tr>
 *   <tr><td>failedNodes 累积</td><td>:199 failedNodes.add(node.id())</td><td>:211 executorFailedNodes.addAll()</td></tr>
 *   <tr><td>verifier.verify()</td><td>—</td><td>:328 verifier.verify().block()</td></tr>
 *   <tr><td>ruleVerify "FAILED:" 检查</td><td>—</td><td>DefaultVerifier:175-179</td></tr>
 *   <tr><td>diagnoseRootCause()</td><td>—</td><td>:355 diagnoseRootCause()</td></tr>
 *   <tr><td>RootCauseDispatcher.dispatch()</td><td>—</td><td>:361-364 switch(cause)</td></tr>
 *   <tr><td>correctionHint</td><td>:290-294 &lt;correction&gt; XML 标签</td><td>:435-436 correctionHint 注入</td></tr>
 * </table>
 *
 * <p>DEMO OUTPUT（每个步骤打印到 stdout）：步进式追踪，结尾输出结论。</p>
 */
public final class SingleNodePregelDemo {

    private SingleNodePregelDemo() {}

    // ==================== Demo 入口 ====================

    /**
     * 运行完整 E1-E4 追踪演示。
     *
     * @return DemoResult 聚合结果
     */
    public static DemoResult run() {
        System.out.println("=".repeat(72));
        System.out.println("SingleNodePregelDemo: 1-node PEV 单轨 E1-E4 追踪");
        System.out.println("=".repeat(72));

        // ---- 基础设施 ----
        TaskId taskId = TaskId.generate();
        NodeId nodeId = new NodeId("T");
        PlanGoal goal = PlanGoal.of("查询案例状态", List.of("返回有效的案例状态"));
        ExecutionPolicy policy = new ExecutionPolicy(
            PlanningMode.AUTO, VerifyMode.STRICT, 3, 4, true);

        // ---- E1: 工具异常 ----
        System.out.println("\n── E1: 工具异常 ──");
        String toolName = "getCaseStatus";
        String exceptionMessage = "连接超时: 无法访问案例服务 (timeout 30s)";

        // 注册一个恒抛异常的工具（模拟设备故障）
        MockToolProvider tools = new MockToolProvider()
            .registerFailing(toolName, exceptionMessage);
        AgentKernel kernel = createKernel("unused-llm-response", tools);

        // 执行工具调用 → 模拟 DefaultPregelExecutor.executeToolNode() 的异常路径
        BudgetLimits budget = BudgetLimits.start(Budget.Fixed.developmentDefault());
        String capturedResult;
        boolean toolThrew = false;
        try {
            ToolResult tr = kernel.invokeTool(new ToolName(toolName), Map.of("caseNo", "ORD-001"), budget)
                .block(Duration.ofSeconds(5));
            capturedResult = (tr != null && tr.success()) ? String.valueOf(tr.result()) : "FAILED: 工具返回失败";
        } catch (Exception e) {
            toolThrew = true;
            capturedResult = "FAILED: " + e.getMessage();
        }
        System.out.printf("  tool exception: %s%n", toolThrew);
        System.out.printf("  captured result: %s%n", capturedResult);
        assert capturedResult.startsWith("FAILED:");
        assert toolThrew;

        // 累积 executor 设备故障信号（镜像 DefaultPregelExecutor:199 + AlphaStrategy:211）
        Set<String> toolFailedNodes = Set.of(nodeId.value());
        Map<NodeId, Object> nodeResults = Map.of(nodeId, (Object) capturedResult);

        // ---- E2: Verifier 感知失败 ----
        System.out.println("\n── E2: Verifier 感知失败 ──");

        // 创建单节点 TaskGraph
        TaskNode toolNode = TaskNode.of(nodeId.value(), toolName, TaskNodeType.TOOL_CALL);
        TaskGraph graph = new TaskGraph(goal.description(), List.of(toolNode), List.of());

        // DefaultVerifier.ruleVerify() 检测 "FAILED:" 前缀（:175-179）
        // 我们手动调用 verify() 看 ruleVerify 是否捕获该节点
        Verifier verifier = new DefaultVerifier(kernel);
        VerifyResult verifyResult = verifier.verify(taskId, goal, graph, nodeResults, policy, budget)
            .block(Duration.ofSeconds(10));

        System.out.printf("  verify passed: %s%n", verifyResult.passed());
        System.out.printf("  verify failedNodes: %s%n", verifyResult.failedNodes());
        System.out.printf("  overallFeedback: %s%n", verifyResult.overallFeedback());

        // ruleVerify 检查 passed=false —— 因为结果 startsWith("FAILED:")
        boolean ruleCaughtFailure = verifyResult.nodeResults().stream()
            .anyMatch(r -> r.nodeId().equals(nodeId.value()) && !r.passed()
                && r.method() == VerifyResult.VerifyMethod.RULE);
        System.out.printf("  ruleVerify caught 'FAILED:' prefix: %s%n", ruleCaughtFailure);

        Set<String> verifyFailedNodes = verifyResult.failedNodes();
        assert !verifyResult.passed();
        assert verifyFailedNodes.contains(nodeId.value());

        // ---- E3: 根因诊断（确定性纯函数） ----
        System.out.println("\n── E3: 根因诊断（确定性纯函数，零 LLM 口算）──");
        System.out.printf("  tool-failed nodes: %s%n", toolFailedNodes);
        System.out.printf("  verify-failed nodes: %s%n", verifyFailedNodes);

        // RootCauseDiagnoser.diagnose() = AlphaStrategy.diagnoseRootCause() 的移植版
        // verifyThrew=false（verifier 正常工作），toolFailedNodes ∩ verifyFailedNodes = {T} ≠ ∅
        RootCause cause = RootCauseDiagnoser.diagnose(false, toolFailedNodes, verifyFailedNodes);

        System.out.printf("  diagnosed RootCause: %s%n", cause);

        // 验证交集计算正确
        Set<String> intersection = new LinkedHashSet<>(toolFailedNodes);
        intersection.retainAll(verifyFailedNodes);
        System.out.printf("  intersection (tool ∩ verify): %s%n", intersection);
        assert !intersection.isEmpty();
        assert cause instanceof RootCause.DeviceFailure df
            && df.nodes().equals(intersection)
            : "E3 断言失败：应诊断为 DeviceFailure，交集非空证明设备故障";

        // ---- E4: sealed dispatch → Degrade (AcceptPartial) + PlanOrAnswerError 绿径 LocalReplan ----
        System.out.println("\n── E4: sealed dispatch ──");
        SelfHealAction action = RootCauseDispatcher.dispatch(cause);
        System.out.printf("  dispatched action: %s%n", action);
        assert action instanceof SelfHealAction.Degrade
            : "E4 断言失败：DeviceFailure 应 dispatch 为 Degrade（replan 无效）";

        // 设备故障 → Degrade（不对应 LocalReplan，因为同输入重跑还错）
        // 此路径 = AlphaStrategy:361 DeviceFailure → AcceptPartial

        // ---- 绿径: PlanOrAnswerError → LocalReplan with correctionHint ----
        System.out.println("\n── 绿径: PlanOrAnswerError → LocalReplan with correctionHint ──");

        // 模拟场景：工具成功但 LLM 判失败（content 错）
        MockToolProvider successTools = new MockToolProvider()
            .register(toolName, "案例 ORD-001 状态: 已赔付"); // 工具成功
        AgentKernel kernel2 = createKernel("unused", successTools);

        // 工具成功 → 无 FAILED: 前缀
        ToolResult tr2 = kernel2.invokeTool(new ToolName(toolName), Map.of(), budget)
            .block(Duration.ofSeconds(5));
        Map<NodeId, Object> successResults = Map.of(nodeId, (Object) String.valueOf(tr2.result()));
        System.out.printf("  tool result (success path): %s%n", tr2.result());

        // Verifier 判失败（但原因 = 内容错，非设备故障）
        // 这里用空 toolFailedNodes 模拟——工具执行成功，verify 看到的是内容质量问题
        Set<String> emptyToolFailed = Set.of();
        VerifyResult contentFail = VerifyResult.failed("内容质量不达标", Set.of(nodeId.value()));

        RootCause cause2 = RootCauseDiagnoser.diagnose(false, emptyToolFailed,
            contentFail.failedNodes());
        System.out.printf("  diagnosed (success path): %s%n", cause2);
        assert cause2 instanceof RootCause.PlanOrAnswerError
            : "绿径断言失败：工具成功 + verify 失败 → PlanOrAnswerError";

        SelfHealAction action2 = RootCauseDispatcher.dispatch(cause2);
        System.out.printf("  dispatched action (success path): %s%n", action2);
        assert action2 instanceof SelfHealAction.Replan
            : "绿径断言失败：PlanOrAnswerError 应 dispatch 为 Replan";

        // 构造带 correctionHint 的新 TaskNode（模拟 AlphaStrategy:435-436 correctionHint 注入）
        String correctionHint = "地面真值反馈：案例 ORD-001 实际状态为 '已赔付'，"
            + "verify 发现 LLM 判错，请用此地面真值修正";
        TaskNode correctedNode = new TaskNode(
            nodeId,
            toolNode.description(),
            TaskNodeType.LLM_CALL, // LocalReplan 通常只对 LLM_CALL 节点注 correctionHint
            Map.of(),
            toolNode.expectedOutput(),
            toolNode.status(),
            correctionHint // 7 参 canonical：仅 LocalReplan 重做路径注 correctionHint
        );
        System.out.printf("  corrected node correctionHint: %s%n", correctedNode.correctionHint());
        assert correctedNode.correctionHint() != null
            && correctedNode.correctionHint().equals(correctionHint)
            : "绿径断言失败：correctionHint 应被注入";

        // correctionHint 在 DefaultPregelExecutor.executeLLMNode() :290-294 被消费：
        //   prompt.append("\n<correction>");
        //   prompt.append(PromptSecurity.escapeXml(hint));
        //   prompt.append("</correction>");
        // 然后 kernel.think(prompt) → LLM 看到地面真值自纠

        // ---- 汇总 ----
        System.out.println("\n" + "=".repeat(72));
        System.out.println("DEMO 通过：E1-E4 全链路追踪完成");
        System.out.println("=".repeat(72));

        return new DemoResult(
            taskId, nodeId, goal, graph, policy,
            capturedResult, toolThrew,
            verifyResult, cause, action,
            cause2, action2, correctedNode
        );
    }

    // ==================== 辅助 ====================

    private static AgentKernel createKernel(String llmResponse, MockToolProvider tools) {
        return new DefaultAgentKernel(
            new MockChatModel(llmResponse),
            tools.build(),
            new MockCheckpointStore(),
            new DefaultSafetyBoundary()
        );
    }

    // ==================== DemoResult 聚合 ====================

    /** 聚合 E1-E4 所有步骤的输入/输出，供测试断言。 */
    public record DemoResult(
        TaskId taskId,
        NodeId nodeId,
        PlanGoal goal,
        TaskGraph graph,
        ExecutionPolicy policy,
        // E1
        String capturedResult,
        boolean toolThrew,
        // E2
        VerifyResult verifyResult,
        // E3
        RootCause deviceFailureCause,
        // E4
        SelfHealAction degradeAction,
        // 绿径: PlanOrAnswerError
        RootCause planOrAnswerErrorCause,
        SelfHealAction replanAction,
        // LocalReplan correctionHint
        TaskNode correctedNode
    ) {}
}
