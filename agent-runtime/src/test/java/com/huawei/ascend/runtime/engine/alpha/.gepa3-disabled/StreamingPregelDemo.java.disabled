package com.huawei.ascend.runtime.engine.alpha.gepa3;

import com.openjiuwen.core.alpha.graph.TaskGraph;
import com.openjiuwen.core.alpha.graph.TaskNode;
import com.openjiuwen.core.alpha.graph.TaskNodeType;
import com.openjiuwen.core.kernel.model.Budget;
import com.openjiuwen.core.kernel.model.BudgetLimits;
import com.openjiuwen.core.kernel.model.NodeId;
import com.openjiuwen.core.kernel.model.TaskId;
import com.openjiuwen.core.kernel.model.ToolName;
import com.openjiuwen.core.kernel.model.ToolResult;
import com.openjiuwen.runtime.core.engine.AgentKernel;
import reactor.core.publisher.Flux;
import reactor.core.publisher.Mono;

import java.time.Duration;
import java.util.ArrayList;
import java.util.Collections;
import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;
import java.util.Set;
import java.util.concurrent.ConcurrentHashMap;
import java.util.concurrent.atomic.AtomicBoolean;
import java.util.concurrent.atomic.AtomicLong;

/**
 * StreamingPregelDemo — 零阻塞流式 Pregel 执行器原型。
 *
 * <h2>动机</h2>
 * 当前 BSP 执行器（DefaultPregelExecutor.executeSuperstep）对每个节点使用
 * {@code CompletableFuture.runAsync} + {@code .block()} 模式：
 * <pre>{@code
 *   kernel.think(prompt, budget, taskId, nodeId()).block();  // 虚拟线程阻塞
 *   kernel.invokeTool(toolName, args, budget).block();       // 同上
 * }</pre>
 * 这导致：
 * <ul>
 *   <li>背压浪费 — Mono 内部的 backpressure 信号在 .block() 时被丢弃</li>
 *   <li>取消盲点 — 外部 Flux 取消时，正在进行的 .block() 不感知上游 cancel</li>
 *   <li>错误通道塌缩 — Reactive 的 onErrorResume/retry 被 try-catch 替代</li>
 * </ul>
 *
 * <h2>本原型的承诺</h2>
 * <ol>
 *   <li><b>零 .block()</b> — 每个 kernel 调用保持 Mono，组合进 Flux 管道</li>
 *   <li><b>自愈</b> — 单节点失败不杀整层：{@code .timeout() + .onErrorResume()}</li>
 *   <li><b>BSP 屏障</b> — {@code .collectList().flatMap(nextLayer)} 替代 {@code CompletableFuture.allOf().get()}</li>
 *   <li><b>背压</b> — flatMap concurrency 参数限制并行度；下游 request(n) 控制发射速率</li>
 *   <li><b>取消传播</b> — doOnCancel/doFinally 清理资源，取消穿透整个 react 链</li>
 * </ol>
 *
 * <h2>与现状的对照（代码行号引用自代码阅读报告 P6）</h2>
 * <table border="1">
 *   <tr><th>现状 (blocking)</th><th>本原型 (reactive)</th></tr>
 *   <tr><td>DefaultPregelExecutor:335 .block()</td><td>本行消失 — Mono 组合进 Flux</td></tr>
 *   <tr><td>DefaultPregelExecutor:189 CF.runAsync + semaphore</td><td>flatMap(concurrency) — Reactor 内建背压</td></tr>
 *   <tr><td>DefaultPregelExecutor:209 CF.allOf().get()</td><td>collectList().flatMap(nextLayer)</td></tr>
 *   <tr><td>DefaultPregelExecutor:199-200 try-catch → failedNodes</td><td>onErrorResume → NodeResult.failed()</td></tr>
 *   <tr><td>AlphaStrategy:328-330 verifyResult = ... .block()</td><td>verifyResult = ... .flatMap(diagnose) 组合</td></tr>
 * </table>
 *
 * <h2>已知限制（原型范围外）</h2>
 * <ul>
 *   <li>不实现 executeVerifyLoop 递归 — 仅演示单层 BSP 的流式化</li>
 *   <li>不依赖 Spring DI — 纯构造器注入 kernel，可直接 new 测试</li>
 *   <li>不实现 sub-agent 递归 — 仅 TOOL_CALL + LLM_CALL 节点类型</li>
 *   <li>No persisted checkpoint — 演示用内存 Map</li>
 * </ul>
 */
public class StreamingPregelDemo {

    // ── 超时常量（对齐 AlphaStrategy LLM_TIMEOUT / COR-003/004） ──
    private static final Duration NODE_TIMEOUT = Duration.ofSeconds(120);
    private static final Duration LAYER_TIMEOUT = Duration.ofSeconds(360);

    private final AgentKernel kernel;

    public StreamingPregelDemo(AgentKernel kernel) {
        this.kernel = kernel;
    }

    // ════════════════════════════════════════════════════════════════
    // 公共类型
    // ════════════════════════════════════════════════════════════════

    /**
     * 单节点执行结果 — 不可变记录，替代共享 mutable Map。
     */
    public record NodeResult(NodeId nodeId, Object value, boolean failed, String error) {
        public static NodeResult ok(NodeId id, Object value) {
            return new NodeResult(id, value, false, null);
        }

        public static NodeResult failed(NodeId id, String error) {
            return new NodeResult(id, "FAILED: " + error, true, error);
        }
    }

    /**
     * 一个 superstep 的结果 — 原子层输出。
     */
    public record SuperstepResult(
            int layerIndex,
            List<NodeResult> nodeResults,
            Set<NodeId> failedNodes) {
    }

    // ════════════════════════════════════════════════════════════════
    // 公共入口：流式执行整个 TaskGraph
    // ════════════════════════════════════════════════════════════════

    /**
     * 流式执行完整 TaskGraph，返回 {@link Flux}{@code <SuperstepResult>}。
     *
     * <p>每一层是一个 superstep。同层节点通过 flatMap 并行，层间通过
     * {@code concatMap} 串行（BSP 语义：等全集后再推进到下一层）。
     *
     * <p>背压：下游如果消费慢，{@code flatMap} 的 concurrency 参数限制同层
     * 并行度，{@code concatMap} 阻止跨层预取。
     *
     * <p>取消：任何时候下游 dispose，整个 react 链取消 —
     * 包括正在进行的 kernel.think()/invokeTool() 的底层 HTTP 请求。
     *
     * @param taskId      任务 ID
     * @param graph       要执行的 TaskGraph
     * @param initialBudget 初始预算限额
     * @return 逐层发射的 SuperstepResult（冷源，subscribe 才启动）
     */
    public Flux<SuperstepResult> execute(TaskId taskId, TaskGraph graph, BudgetLimits initialBudget) {
        List<List<TaskNode>> layers = graph.executionLayers();

        // 累加器：持有跨层共享的可变状态（层间数据依赖需要）
        Accumulator acc = new Accumulator(initialBudget);

        return Flux.fromIterable(layers)
                .concatMap(layer -> executeSuperstep(taskId, layer, acc, layers.indexOf(layer)))
                .doOnCancel(acc::markCancelled)
                .doFinally(signal -> acc.dispose());
    }

    // ════════════════════════════════════════════════════════════════
    // 核心方法：零阻塞 executeSuperstep
    // ════════════════════════════════════════════════════════════════

    /**
     * 执行一个 superstep（一层 DAG 节点）— <b>完全无阻塞</b>。
     *
     * <p><b>对照: DefaultPregelExecutor.executeSuperstep (line 175-230)</b>:
     * 原实现用 {@code CompletableFuture.runAsync} 为每节点起虚拟线程 →
     * 每个虚拟线程内 {@code kernel.think().block()} →
     * {@code CF.allOf().get(layerTimeout)} 屏障。
     *
     * <p>本实现：
     * <ol>
     *   <li>{@code Flux.fromIterable(layer)} 发射同层节点</li>
     *   <li>{@code flatMap(concurrency)} 并行执行 — Reactor 内建线程调度</li>
     *   <li>每节点 {@code executeNode(taskId, node, acc)} 返回 {@code Mono<NodeResult>}</li>
     *   <li>{@code .timeout(LAYER_TIMEOUT)} 整层超时护盾</li>
     *   <li>{@code .onErrorResume()} — 即使整层超时也不杀 Flux，发 partial 结果</li>
     *   <li>{@code collectList()} 是 BSP 屏障 — 等价于 allOf().get()，但非阻塞</li>
     *   <li>{@code map → SuperstepResult} — 组装层结果</li>
     * </ol>
     *
     * @param taskId     任务 ID
     * @param layer      当前层节点列表
     * @param acc        跨层累加器（预算 + 已完成结果）
     * @param layerIndex 层索引（0-based）
     * @return Mono&lt;SuperstepResult&gt; — 单层完成信号（非阻塞）
     */
    Mono<SuperstepResult> executeSuperstep(
            TaskId taskId, List<TaskNode> layer, Accumulator acc, int layerIndex) {

        int concurrency = Math.min(layer.size(), Runtime.getRuntime().availableProcessors());

        return Flux.fromIterable(layer)
                // 背压点 1：flatMap concurrency 限制同层并行度
                .flatMap(node -> executeNode(taskId, node, acc)
                        // ── 自愈：单节点超时不杀整层 ──
                        .timeout(NODE_TIMEOUT)
                        .onErrorResume(e -> {
                            // 对照 DefaultPregelExecutor:199-200
                            // 原实现: catch(Exception) → failedNodes.add → "FAILED: " + msg
                            acc.recordFailed(node.id());
                            return Mono.just(NodeResult.failed(node.id(),
                                    "节点超时或异常: " + e.getMessage()));
                        }),
                        concurrency)   // ← 背压在此：最多 concurrency 个节点同时执行
                // 背压点 2：collectList() 是 BSP 屏障
                // 对照 DefaultPregelExecutor:209 allOf().get(layerTimeout)
                .collectList()
                // 整层超时护盾（collectList 之前各节点已有单独 timeout，
                // 这里保护的是"最后一个节点永远不完成"的病理场景）
                .timeout(LAYER_TIMEOUT)
                .onErrorResume(e ->
                        // 整层超时 → 发射当前已收集的结果作为 partial layer
                        Flux.fromIterable(layer)
                                .flatMap(node -> {
                                    if (acc.hasResult(node.id())) {
                                        return Mono.just(acc.getResult(node.id()));
                                    }
                                    acc.recordFailed(node.id());
                                    return Mono.just(NodeResult.failed(node.id(),
                                            "层超时: " + e.getMessage()));
                                })
                                .collectList()
                )
                .map(results -> {
                    List<NodeResult> resultList = List.copyOf(results);
                    // 将结果写入累加器，供下游层做依赖解析
                    for (NodeResult nr : resultList) {
                        if (!nr.failed()) {
                            acc.putResult(nr.nodeId(), nr);
                        }
                    }
                    return new SuperstepResult(layerIndex, resultList, acc.snapshotFailed());
                });
    }

    // ════════════════════════════════════════════════════════════════
    // 节点分发（对照 DefaultPregelExecutor:238-243 executeNode dispatch）
    // ════════════════════════════════════════════════════════════════

    /**
     * 按节点类型分发执行 — 返回 {@code Mono<NodeResult>}，<b>无 .block()</b>。
     *
     * <p>对照: DefaultPregelExecutor.executeNode (line 238-243) 用 switch 分发，
     * 但每种分发内部都有 .block()。
     * 本方法返回 Mono，由调用方（flatMap）组合。
     */
    private Mono<NodeResult> executeNode(TaskId taskId, TaskNode node, Accumulator acc) {
        return switch (node.type()) {
            case LLM_CALL -> executeLLMNode(taskId, node, acc);
            case TOOL_CALL -> executeToolNode(taskId, node, acc);
            case SUB_AGENT -> Mono.just(NodeResult.failed(node.id(),
                    "SUB_AGENT 不在原型范围 — deferred (铁律①诚实边界)"));
        };
    }

    // ════════════════════════════════════════════════════════════════
    // LLM 节点（对照 DefaultPregelExecutor:335 kernel.think().block()）
    // ════════════════════════════════════════════════════════════════

    /**
     * 执行 LLM 推理节点 — <b>不调 .block()</b>。
     *
     * <p>原实现 (DefaultPregelExecutor:335):
     * <pre>{@code return kernel.think(prompt, budget, taskId, node.id()).block();}</pre>
     *
     * <p>本实现:
     * <pre>{@code return kernel.think(prompt, budget, taskId, node.id()).map(...)}</pre>
     *
     * <p>Mono 保持打开，与上游 flatMap 的并发控制、下游 timeout 的取消传播
     * 自然组合 — 不塌缩为同步调用。
     */
    private Mono<NodeResult> executeLLMNode(TaskId taskId, TaskNode node, Accumulator acc) {
        String prompt = buildLLMPrompt(node, acc);
        BudgetLimits current = acc.budgetRef.get();

        return kernel.think(prompt, current, taskId, node.id())
                .map(output -> {
                    acc.recordLLMCall(256); // 估算 token（原型：固定 256）
                    return NodeResult.ok(node.id(), output);
                });
    }

    // ════════════════════════════════════════════════════════════════
    // Tool 节点（对照 DefaultPregelExecutor:248-259 executeToolNode）
    // ════════════════════════════════════════════════════════════════

    /**
     * 执行工具节点 — <b>不调 .block()</b>。
     *
     * <p>原实现 (DefaultPregelExecutor:253-258):
     * <pre>{@code
     * ToolResult result = kernel.invokeTool(toolName, args, budget).block();
     * if (result != null && result.success()) return result.result();
     * throw new RuntimeException("工具调用失败: " + ...);
     * }</pre>
     *
     * <p>本实现: {@code invokeTool → flatMap → 成功取 result / 失败发 error}
     * 保持 Mono 链，错误走 Reactor error channel 而非 Java exception throw。
     */
    private Mono<NodeResult> executeToolNode(TaskId taskId, TaskNode node, Accumulator acc) {
        Map<String, Object> resolvedArgs = resolveInputs(node.inputs(), acc);
        ToolName toolName = new ToolName(bareToolName(node.description()));

        return kernel.invokeTool(toolName, resolvedArgs, acc.budgetRef.get())
                .flatMap(result -> {
                    acc.recordToolCall();
                    if (result != null && result.success()) {
                        return Mono.just(NodeResult.ok(node.id(), result.result()));
                    }
                    // 错误走 Mono error channel（不抛 Java exception）
                    String errMsg = "工具调用失败: " + (result != null ? result.error() : "null");
                    return Mono.error(new RuntimeException(errMsg));
                });
    }

    // ════════════════════════════════════════════════════════════════
    // 辅助方法
    // ════════════════════════════════════════════════════════════════

    private String buildLLMPrompt(TaskNode node, Accumulator acc) {
        StringBuilder sb = new StringBuilder();
        sb.append("任务: ").append(node.description()).append("\n");
        if (!node.inputs().isEmpty()) {
            sb.append("输入:\n");
            node.inputs().forEach((key, ref) -> {
                NodeId depId = resolveNodeRef(ref);
                Object val = acc.getResultValue(depId);
                sb.append("  ").append(key).append(" = ").append(val).append("\n");
            });
        }
        if (node.expectedOutput() != null && !node.expectedOutput().isBlank()) {
            sb.append("期望输出: ").append(node.expectedOutput()).append("\n");
        }
        return sb.toString();
    }

    private Map<String, Object> resolveInputs(Map<String, String> inputs, Accumulator acc) {
        if (inputs == null || inputs.isEmpty()) return Map.of();
        Map<String, Object> resolved = new LinkedHashMap<>();
        inputs.forEach((key, ref) -> {
            NodeId depId = resolveNodeRef(ref);
            resolved.put(key, acc.getResultValue(depId));
        });
        return Collections.unmodifiableMap(resolved);
    }

    /**
     * 从 "${nodeId.output}" 或裸 "nodeId" 引用中提取 NodeId。
     */
    static NodeId resolveNodeRef(String ref) {
        String cleaned = ref.replace("${", "").replace("}", "");
        if (cleaned.contains(".")) {
            cleaned = cleaned.substring(0, cleaned.indexOf('.'));
        }
        return new NodeId(cleaned);
    }

    /**
     * 从节点描述中提取裸工具名。
     * 原 DefaultPregelExecutor 使用 ToolNames.bareToolName(node.description())。
     */
    static String bareToolName(String description) {
        if (description == null || description.isBlank()) return "unknown";
        // 取第一行或空格前第一个词作为工具名
        String trimmed = description.trim();
        int space = trimmed.indexOf(' ');
        return space > 0 ? trimmed.substring(0, space) : trimmed;
    }

    // ════════════════════════════════════════════════════════════════
    // 跨层累加器（原型：线程安全但非持久化）
    // ════════════════════════════════════════════════════════════════

    /**
     * 跨层累积状态 — 替代原实现在 AlphaStrategy 中散布的 mutable Map。
     *
     * <p>线程安全：{@link ConcurrentHashMap} + {@link AtomicLong} + {@link AtomicBoolean}。
     *
     * <p>对照：
     * <ul>
     *   <li>原 executorFailedNodes (AlphaStrategy:211) → 本 acc.failedNodes</li>
     *   <li>原 executorSkippedNodes → 不在原型范围</li>
     *   <li>原 budgetRef (AlphaStrategy:102) → 本 acc.budgetRef</li>
     *   <li>原 nodeResults Map (DefaultPregelExecutor:197) → 本 acc.results</li>
     * </ul>
     */
    static class Accumulator {
        final Map<NodeId, NodeResult> results = new ConcurrentHashMap<>();
        final Set<NodeId> failedNodes = ConcurrentHashMap.newKeySet();
        final java.util.concurrent.atomic.AtomicReference<BudgetLimits> budgetRef;
        final AtomicLong llmCalls = new AtomicLong(0);
        final AtomicLong toolCalls = new AtomicLong(0);
        final AtomicBoolean cancelled = new AtomicBoolean(false);

        Accumulator(BudgetLimits initialBudget) {
            this.budgetRef = new java.util.concurrent.atomic.AtomicReference<>(initialBudget);
        }

        void putResult(NodeId id, NodeResult result) {
            results.put(id, result);
        }

        boolean hasResult(NodeId id) {
            return results.containsKey(id);
        }

        NodeResult getResult(NodeId id) {
            return results.get(id);
        }

        Object getResultValue(NodeId id) {
            NodeResult nr = results.get(id);
            return nr != null ? nr.value() : null;
        }

        void recordFailed(NodeId id) {
            failedNodes.add(id);
        }

        Set<NodeId> snapshotFailed() {
            return Set.copyOf(failedNodes);
        }

        void recordLLMCall(int tokens) {
            llmCalls.incrementAndGet();
            budgetRef.updateAndGet(b -> b.recordLLMCall(tokens));
        }

        void recordToolCall() {
            toolCalls.incrementAndGet();
            budgetRef.updateAndGet(BudgetLimits::recordToolCall);
        }

        void markCancelled() {
            cancelled.set(true);
        }

        boolean isCancelled() {
            return cancelled.get();
        }

        void dispose() {
            results.clear();
            failedNodes.clear();
        }
    }
}
