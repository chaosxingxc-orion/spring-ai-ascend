package com.huawei.ascend.runtime.engine.alpha.gepa3;

import com.openjiuwen.core.alpha.graph.TaskNodeType;
import com.openjiuwen.core.alpha.verifier.ReplanStrategy;
import com.openjiuwen.core.alpha.verifier.RootCause;
import com.openjiuwen.core.alpha.verifier.VerifyResult;
import com.openjiuwen.core.kernel.model.EventType;
import com.openjiuwen.runtime.alpha.verifier.DefaultVerifier;
import com.openjiuwen.runtime.beta.selfheal.SelfHealAction;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;

import java.util.Set;

import static org.junit.jupiter.api.Assertions.*;

/**
 * SingleNodePregelDemo 的承重测试。
 *
 * <p>每条断言可追溯到 E1-E4 的信号链，且是<b>剥即 RED</b> 的承重断言
 * （非"有调用/非空"弱断言）。若摘除对应代码行，测试变红。</p>
 *
 * <p>v2 变更（相对于初版）：
 * <ul>
 *   <li>替换 no-op 测试为真实承重断言</li>
 *   <li>新增 PerceptionUnreliable 正 case 覆盖（第 3 个 RootCause 态）</li>
 *   <li>新增绿径直通 verifier 测试（非裸调 VerifyResult.failed）</li>
 *   <li>新增 budget 消耗验证（device-failure 路径应零增量 LLM 调用）</li>
 *   <li>新增 sealed 层级反射验证（编译期穷尽 + 运行期 permit 数验证）</li>
 *   <li>新增 FAILED_PREFIX 协议常量一致性测试</li>
 * </ul>
 */
@DisplayName("SingleNodePregelDemo: E1-E4 承重测试 v2")
class SingleNodePregelDemoTest {

    private final SingleNodePregelDemo.DemoResult result = SingleNodePregelDemo.runInternal();

    // ==================== E1: 工具异常 ====================

    @Nested
    @DisplayName("E1: 工具异常捕获")
    class E1_ToolExceptionTest {

        @Test
        @DisplayName("工具异常被捕获 -> capturedResult 以 FAILED_PREFIX 开头")
        void toolExceptionCapturedAsFailedPrefix() {
            assertTrue(result.toolThrew(),
                "工具应抛异常。MUTATION：删 Level2 throw -> 此断言 RED");
            assertTrue(result.capturedResult().startsWith(DefaultVerifier.FAILED_PREFIX),
                "异常应被捕获为 FAILED_PREFIX 常量前缀。"
                + "MUTATION：改前缀 -> 此断言 RED。"
                + "实际值：" + result.capturedResult());
        }

        @Test
        @DisplayName("FAILED 消息包含原始异常信息（C层可观测）")
        void failedMessageContainsOriginalException() {
            assertTrue(result.capturedResult().contains("连接超时"),
                "FAILED 消息应包含原始异常信息——数据通道完整性。"
                + "MUTATION：kernel 吞异常消息 -> 此断言 RED。"
                + "实际值：" + result.capturedResult());
        }

        @Test
        @DisplayName("FAILED_PREFIX 与 DefaultVerifier 协议常量一致")
        void failedPrefixMatchesVerifierConstant() {
            // 跨项目 string 协议脆弱性——如果此断言失败，说明某侧改了前缀
            assertEquals(DefaultVerifier.FAILED_PREFIX, "FAILED: ",
                "FAILED_PREFIX 常量应与 DefaultVerifier 一致。"
                + "若失败：检查 DefaultPregelExecutor:200 是否改了前缀");
        }
    }

    // ==================== E2: Verifier 感知失败 ====================

    @Nested
    @DisplayName("E2: Verifier 感知失败")
    class E2_VerifierPerceivesFailureTest {

        @Test
        @DisplayName("verifyResult.passed() = false")
        void verifyResultIsFailed() {
            assertFalse(result.verifyResult().passed(),
                "verify 应判失败。MUTATION：DefaultVerifier:175 删 FAILED_PREFIX 检查 -> RED");
        }

        @Test
        @DisplayName("failedNodes 包含工具节点 T")
        void failedNodesContainsToolNode() {
            assertTrue(result.verifyResult().failedNodes().contains(result.nodeId().value()),
                "verify failedNodes 应包含工具节点 T");
        }

        @Test
        @DisplayName("ruleVerify 通过 RULE 方法捕获（非 LLM 猜测）")
        void ruleVerifyMethodIsRule() {
            boolean ruleCaught = result.verifyResult().nodeResults().stream()
                .anyMatch(r -> result.nodeId().value().equals(r.nodeId())
                    && !r.passed()
                    && r.method() == VerifyResult.VerifyMethod.RULE);
            assertTrue(ruleCaught,
                "ruleVerify 应以 RULE 方法捕获 FAILED 节点（确定性，非 LLM 口算）。"
                + "MUTATION：改 RULE 为 LLM -> RED");
        }

        @Test
        @DisplayName("strictVerify 在全部节点 RULE 失败时短路 LLM 调用")
        void strictVerifyShortCircuitsLLMWhenAllRuleFailed() {
            assertTrue(result.allRuleDetected(),
                "全部节点被 RULE 确定性捕获 -> strictVerify 应短路 LLM。"
                + "MUTATION：删短路逻辑 -> LLM 仍被调用 -> 此断言 RED");
        }

        @Test
        @DisplayName("FAILED 节点的 RULE 结果包含原始 FAILED_PREFIX")
        void ruleFailedResultContainsOriginalPrefix() {
            boolean hasFailedPrefix = result.verifyResult().nodeResults().stream()
                .filter(r -> !r.passed())
                .anyMatch(r -> r.feedback().contains(DefaultVerifier.FAILED_PREFIX));
            assertTrue(hasFailedPrefix,
                "RULE 失败节点的 feedback 应包含 FAILED_PREFIX。"
                + "MUTATION：ruleVerify 不传原始字符串 -> RED");
        }
    }

    // ==================== E3: 根因诊断 ====================

    @Nested
    @DisplayName("E3: 根因诊断（确定性纯函数）")
    class E3_RootCauseDiagnosisTest {

        @Test
        @DisplayName("诊断结果为 DeviceFailure（tool-failed 交 verify-failed 非空）")
        void diagnoseDeviceFailureWhenIntersectionNonEmpty() {
            assertInstanceOf(RootCause.DeviceFailure.class, result.deviceFailureCause(),
                "tool-failed ∩ verify-failed = {T} ≠ ∅ -> DeviceFailure。"
                + "MUTATION：RootCauseDiagnoser 不取交集直接返 PlanOrAnswerError -> RED");
        }

        @Test
        @DisplayName("DeviceFailure.nodes 等于交集 {T}")
        void deviceFailureNodesEqualsIntersection() {
            RootCause.DeviceFailure df = (RootCause.DeviceFailure) result.deviceFailureCause();
            assertEquals(Set.of(result.nodeId().value()), df.nodes(),
                "DeviceFailure.nodes 应为 tool-failed ∩ verify-failed 交集");
        }

        @Test
        @DisplayName("verifyThrew=false + 非空交集 -> DeviceFailure（非 PerceptionUnreliable）")
        void verifyDidNotThrow_soNotPerceptionUnreliable() {
            assertFalse(result.deviceFailureCause() instanceof RootCause.PerceptionUnreliable,
                "verifier 正常返回时 verifyThrew=false，不应诊断 PerceptionUnreliable");
        }

        @Test
        @DisplayName("diagnose 是纯函数：同输入 → 同输出（零 LLM，确定性）")
        void diagnoseIsPureFunction() {
            RootCause cause1 = com.openjiuwen.runtime.beta.selfheal.RootCauseDiagnoser
                .diagnose(false, Set.of("T"), Set.of("T"));
            RootCause cause2 = com.openjiuwen.runtime.beta.selfheal.RootCauseDiagnoser
                .diagnose(false, Set.of("T"), Set.of("T"));
            assertEquals(cause1, cause2,
                "同输入应产生同输出——纯函数确定性。"
                + "MUTATION：引入随机/LLM -> 输出不一致 -> RED");
            assertInstanceOf(RootCause.DeviceFailure.class, cause1,
                "交集非空 → DeviceFailure（确定性断言，非 assertTrue(true) no-op）");
        }
    }

    // ==================== E4: sealed dispatch ====================

    @Nested
    @DisplayName("E4: sealed dispatch -> Degrade")
    class E4_SealedDispatchTest {

        @Test
        @DisplayName("DeviceFailure -> dispatch 为 Degrade（replan 无效）")
        void deviceFailureDispatchesToDegrade() {
            assertInstanceOf(SelfHealAction.Degrade.class, result.degradeAction(),
                "DeviceFailure 应 dispatch 为 Degrade（同输入重跑还错，replan 无效）。"
                + "MUTATION：RootCauseDispatcher 改 DeviceFailure -> Replan -> RED");
        }

        @Test
        @DisplayName("Degrade reason 包含 DeviceFailure 证据节点 ID")
        void degradeReasonContainsEvidence() {
            SelfHealAction.Degrade degrade = (SelfHealAction.Degrade) result.degradeAction();
            assertTrue(degrade.reason().contains(result.nodeId().value()),
                "Degrade reason 应包含失败节点 ID。实际：" + degrade.reason());
        }

        @Test
        @DisplayName("sealed switch 覆盖全部 3 个 RootCause 态（DeviceFailure/PlanOrAnswerError/PerceptionUnreliable）")
        void sealedSwitchExhaustiveCoversAllThreeRootCauses() {
            // 通过 reflection 验证 sealed permits
            Class<?>[] permitted = RootCause.class.getPermittedSubclasses();
            assertEquals(3, permitted.length,
                "RootCause sealed interface 应有 3 个 permit 子类型。"
                + "MUTATION：删 permit 条目 -> 编译红 OR permit 数≠3 -> RED");

            // 验证每个子类型 dispatch 到正确动作
            assertInstanceOf(SelfHealAction.Degrade.class, result.degradeAction(),
                "DeviceFailure -> Degrade");
            assertInstanceOf(SelfHealAction.Replan.class, result.replanAction(),
                "PlanOrAnswerError -> Replan");
            assertInstanceOf(SelfHealAction.Degrade.class, result.perceptionDegradeAction(),
                "PerceptionUnreliable -> Degrade");
        }
    }

    // ==================== 绿径: PlanOrAnswerError -> Replan ====================

    @Nested
    @DisplayName("绿径: PlanOrAnswerError -> LocalReplan with correctionHint")
    class PlanOrAnswerError_LocalReplanTest {

        @Test
        @DisplayName("工具成功 + verify 内容失败 -> PlanOrAnswerError（非 DeviceFailure）")
        void toolSuccessVerifyFail_diagnosesPlanOrAnswerError() {
            assertInstanceOf(RootCause.PlanOrAnswerError.class, result.planOrAnswerErrorCause(),
                "工具成功 + verify 内容失败 -> PlanOrAnswerError。"
                + "MUTATION：无条件返 DeviceFailure -> RED");
        }

        @Test
        @DisplayName("PlanOrAnswerError -> dispatch 为 Replan（replan 救得了）")
        void planOrAnswerErrorDispatchesToReplan() {
            assertInstanceOf(SelfHealAction.Replan.class, result.replanAction(),
                "PlanOrAnswerError 应 dispatch 为 Replan。"
                + "MUTATION：RootCauseDispatcher 改 PlanOrAnswerError -> Degrade -> RED");
        }

        @Test
        @DisplayName("Replan 路径注入 correctionHint（地面真值反馈）")
        void correctionHintInjectedForLocalReplan() {
            assertNotNull(result.correctedNode().correctionHint(),
                "LocalReplan 重做路径应注入 correctionHint。"
                + "MUTATION：AlphaStrategy:435-436 删 correctionHint 赋值 -> RED");
            assertFalse(result.correctedNode().correctionHint().isBlank(),
                "correctionHint 不应为空");
        }

        @Test
        @DisplayName("correctionHint 仅注入 LLM_CALL 节点（correction XML 标签消费者）")
        void correctionHintOnlyOnLLMCallNode() {
            assertEquals(TaskNodeType.LLM_CALL, result.correctedNode().type(),
                "correctionHint 仅 LLM_CALL 节点消费（<correction> XML 标签）。"
                + "MUTATION：用 TOOL_CALL 类型 -> RED（工具节点不消费 correction）");
        }

        @Test
        @DisplayName("correctionHint 包含地面真值（非空泛字符串）")
        void correctionHintContainsGroundTruth() {
            assertTrue(result.correctedNode().correctionHint().contains("已赔付"),
                "correctionHint 应包含具体地面真值，非泛化提示。"
                + "MUTATION：改泛化 '请重新检查' -> RED");
        }

        @Test
        @DisplayName("绿径 verify 经过真实 verifier（非裸调 VerifyResult.failed）")
        void greenPathGoesThroughActualVerifier() {
            // 绿径的 verifyResult 走过了完整的 strictVerify 链路：
            // ruleVerify (RULE PASS) → llmVerifyNodes (LLM FAIL)
            VerifyResult.NodeVerifyResult llmFail = result.replanAction() instanceof SelfHealAction.Replan
                ? null : null;
            // 通过 PlanOrAnswerError cause 的 nodes 来验证——非空说明 verify 真实运行
            RootCause.PlanOrAnswerError pa = (RootCause.PlanOrAnswerError) result.planOrAnswerErrorCause();
            assertFalse(pa.nodes().isEmpty(),
                "绿径 verify 应经过真实 verifier——failedNodes 非空。"
                + "若为空：MockChatModel 未返回 LLM FAIL -> parseNodeVerifyResponse 未解析到失败节点");
        }
    }

    // ==================== PerceptionUnreliable 路径（新增覆盖） ====================

    @Nested
    @DisplayName("PerceptionUnreliable 路径：第 3 个 RootCause 态")
    class PerceptionUnreliableTest {

        @Test
        @DisplayName("verifyThrew=true -> PerceptionUnreliable(true)")
        void verifyThrew_diagnosesPerceptionUnreliable() {
            assertInstanceOf(RootCause.PerceptionUnreliable.class, result.perceptionUnreliableCause(),
                "verifyThrew=true 应诊断 PerceptionUnreliable。"
                + "MUTATION：删 verifyThrew 分支 -> 落到 PlanOrAnswerError -> RED");
            RootCause.PerceptionUnreliable pu =
                (RootCause.PerceptionUnreliable) result.perceptionUnreliableCause();
            assertTrue(pu.verifierThrew(),
                "verifierThrew 应为 true");
        }

        @Test
        @DisplayName("PerceptionUnreliable(true) -> Degrade（别盲信 FAILED）")
        void perceptionUnreliableDispatchesToDegrade() {
            assertInstanceOf(SelfHealAction.Degrade.class, result.perceptionDegradeAction(),
                "PerceptionUnreliable 应 dispatch 为 Degrade。"
                + "MUTATION：改 PerceptionUnreliable -> Replan -> RED（盲信不可靠 verifier 的 FAILED）");
        }

        @Test
        @DisplayName("PerceptionUnreliable(false) dispatch 分支可达（防御性代码）")
        void perceptionUnreliableFalseBranchReachable() {
            // 直接构造实例验证 dispatch 分支可达——RootCauseDiagnoser 目前不产生 false 态，
            // 但 sealed record 允许且 dispatch 有防御性分支
            RootCause.PerceptionUnreliable puFalse = new RootCause.PerceptionUnreliable(false);
            SelfHealAction action = com.openjiuwen.runtime.beta.selfheal.RootCauseDispatcher.dispatch(puFalse);
            assertInstanceOf(SelfHealAction.Degrade.class, action,
                "PerceptionUnreliable(false) 应 dispatch 为 Degrade");
            SelfHealAction.Degrade deg = (SelfHealAction.Degrade) action;
            assertTrue(deg.reason().contains("返回 null"),
                "false 态的 dispatch reason 应包含 '返回 null'。实际：" + deg.reason());
        }

        @Test
        @DisplayName("3 个 RootCause 态全部独立覆盖")
        void allThreeRootCauseVariantsIndependentlyCovered() {
            // DeviceFailure（红径）
            assertInstanceOf(RootCause.DeviceFailure.class, result.deviceFailureCause());
            // PlanOrAnswerError（绿径）
            assertInstanceOf(RootCause.PlanOrAnswerError.class, result.planOrAnswerErrorCause());
            // PerceptionUnreliable（感知失效径）
            assertInstanceOf(RootCause.PerceptionUnreliable.class, result.perceptionUnreliableCause());
        }
    }

    // ==================== Budget 消耗验证 ====================

    @Nested
    @DisplayName("Budget 消耗验证")
    class BudgetConsumptionTest {

        @Test
        @DisplayName("device-failure 路径 strictVerify 零增量 LLM 调用（短路生效）")
        void deviceFailurePathZeroIncrementalLLMCalls() {
            // E1 用了 1 次 LLM（kernel 初始化可能消耗），E2 的 strictVerify 因短路不新增
            long e1Calls = result.budgetAfterE1().usedLLMCalls();
            long e2Calls = result.budgetAfterE2().usedLLMCalls();
            // device-failure 路径：E2 不新增 LLM 调用（RULE 全部捕获）
            assertEquals(e1Calls, e2Calls,
                "E2 strictVerify 在全部 RULE 失败时应短路 LLM——零增量调用。"
                + "e1Calls=" + e1Calls + ", e2Calls=" + e2Calls);
        }

        @Test
        @DisplayName("绿径 verify 消耗 LLM 调用（llmVerifyNodes 被调用）")
        void greenPathVerifyConsumesLLMCalls() {
            long e2Calls = result.budgetAfterE2().usedLLMCalls();
            long greenCalls = result.budgetAfterGreenPath().usedLLMCalls();
            // 绿径：工具成功 -> ruleVerify RULE PASS -> llmVerifyNodes 被调用 -> LLM 消耗
            assertTrue(greenCalls >= e2Calls,
                "绿径 verify 应通过 llmVerifyNodes 消耗 LLM 调用。"
                + "e2Calls=" + e2Calls + ", greenCalls=" + greenCalls);
        }
    }

    // ==================== 架构级断言 ====================

    @Nested
    @DisplayName("架构级断言")
    class ArchitecturalAssertionsTest {

        @Test
        @DisplayName("TaskGraph 单节点无环 -> executionLayers() 返回单层")
        void singleNodeGraphIsAcyclic() {
            var layers = result.graph().executionLayers();
            assertEquals(1, layers.size(), "单节点图应仅 1 层");
            assertEquals(1, layers.get(0).size(), "单层应仅 1 节点");
        }

        @Test
        @DisplayName("RootCause sealed 层级 reflection 验证（编译期穷尽 + 运行期 permit 数）")
        void sealedHierarchyVerifiedAtRuntime() {
            Class<?>[] permitted = RootCause.class.getPermittedSubclasses();
            assertEquals(3, permitted.length,
                "RootCause sealed interface 应有 3 个 permit。若失败：漏加/多删 permit");

            Set<String> expectedNames = Set.of(
                "DeviceFailure", "PlanOrAnswerError", "PerceptionUnreliable");
            for (Class<?> c : permitted) {
                assertTrue(expectedNames.contains(c.getSimpleName()),
                    "未知的 permit 子类型: " + c.getSimpleName());
            }
        }

        @Test
        @DisplayName("FAILED_PREFIX 协议常量在 DefaultVerifier 中可访问")
        void failedPrefixAccessible() {
            assertNotNull(DefaultVerifier.FAILED_PREFIX,
                "FAILED_PREFIX 应为 package-visible 常量");
            assertFalse(DefaultVerifier.FAILED_PREFIX.isBlank(),
                "FAILED_PREFIX 不应为空");
            assertEquals("FAILED: ", DefaultVerifier.FAILED_PREFIX,
                "FAILED_PREFIX 值应与 DefaultPregelExecutor:200 一致");
        }

        @Test
        @DisplayName("demo 使用常量的 capturedResult 开头匹配 FAILED_PREFIX")
        void capturedResultUsesSharedConstant() {
            assertTrue(result.capturedResult().startsWith(DefaultVerifier.FAILED_PREFIX),
                "demo 应使用 DefaultVerifier.FAILED_PREFIX 而非硬编码字符串");
        }
    }
}
