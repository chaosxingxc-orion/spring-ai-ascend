package com.huawei.ascend.runtime.engine.alpha.gepa3;

import static org.assertj.core.api.Assertions.assertThat;
import static org.assertj.core.api.Assertions.assertThatThrownBy;
import static org.junit.jupiter.api.Assertions.assertDoesNotThrow;

import java.util.Map;
import java.util.concurrent.BlockingQueue;
import java.util.concurrent.LinkedBlockingQueue;
import java.util.concurrent.TimeUnit;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;

/**
 * Federal twin demo: PEV (2.0 BSP) handoff to ReActAgent (1.0 loop) and back
 * via a typed {@link BlockingQueue} channel.
 *
 * <h3>What this proves</h3>
 * <ol>
 *   <li><b>Protocol independence</b> — PEV-side code and ReActAgent-side code
 *       share only {@link PevReActProtocol} (the sealed message types). Neither
 *       references the other's implementation classes.</li>
 *   <li><b>Sealed dispatch correctness</b> — every switch on a sealed interface
 *       is compile-time exhaustive. The compiler rejects missing branches.</li>
 *   <li><b>Bidirectional handoff</b> — PEV sends a request; ReActAgent
 *       processes and responds; PEV consumes the response.</li>
 *   <li><b>Three root-cause paths</b> — completed, degraded (DeviceFailure),
 *       and replan-requested (PlanOrAnswerError) all flow through the channel.</li>
 * </ol>
 *
 * <h3>Analogy</h3>
 * <p>Two OS kernels communicating over TCP. Shared wire protocol
 * ({@code PevReActProtocol}), independent network stacks
 * ({@code PevAdapter} / {@code ReActAdapter}).
 *
 * @author P3 federal-twin spike (2026-07-01)
 */
@DisplayName("PevReActProtocol — federal twin handoff via BlockingQueue")
class EngineAdapterDemo {

    // ── Channel: the typed "wire" ─────────────────────────────────────

    /** PEV pushes requests here. */
    private final BlockingQueue<PevReActProtocol.Handoff> pevToReActQueue =
            new LinkedBlockingQueue<>();

    /** ReActAgent pushes responses here. */
    private final BlockingQueue<PevReActProtocol.Response> reActToPevQueue =
            new LinkedBlockingQueue<>();

    // ── PEV-side adapter (2.0 BSP) ────────────────────────────────────

    /**
     * PEV adapter: depends ONLY on {@link PevReActProtocol.PevToReAct} and
     * {@link PevReActProtocol.ReActToPev}. Zero knowledge of ReActAgent internals.
     */
    static final class PevAdapter {

        private final BlockingQueue<PevReActProtocol.Handoff> sendQueue;
        private final BlockingQueue<PevReActProtocol.Response> recvQueue;

        PevAdapter(
                BlockingQueue<PevReActProtocol.Handoff> sendQueue,
                BlockingQueue<PevReActProtocol.Response> recvQueue) {
            this.sendQueue = sendQueue;
            this.recvQueue = recvQueue;
        }

        /** PEV dispatches a sub-task to ReActAgent and blocks for the response. */
        PevReActProtocol.Response handoffAndWait(PevReActProtocol.PevToReAct request)
                throws InterruptedException {
            var handoff = PevReActProtocol.Handoff.of(request);
            sendQueue.put(handoff);
            // In production: poll with timeout + degrade path.
            // For prototype: blocking receive on the same thread (virtual-thread-safe).
            PevReActProtocol.Response response = recvQueue.poll(5, TimeUnit.SECONDS);
            if (response == null) {
                throw new IllegalStateException(
                        "handoff timed out: corrId=" + handoff.correlationId());
            }
            return response;
        }

        /**
         * PEV interprets the ReActAgent response — sealed dispatch, compile-time exhaustive.
         * Returns a PEV-level decision string for assertion.
         */
        static String interpret(PevReActProtocol.Response response) {
            return switch (response.message()) {
                case PevReActProtocol.ReActToPev.SubTaskCompleted c ->
                        "ACCEPT: result=" + c.result() + " reasoning=" + c.reasoningTrace();
                case PevReActProtocol.ReActToPev.SubTaskDegraded d ->
                        "DEGRADE(AcceptPartial): cause=" + d.cause() + " output=" + d.degradedOutput();
                case PevReActProtocol.ReActToPev.SubTaskReplanRequested r ->
                        "REPLAN: reason=" + r.reason();
                case PevReActProtocol.ReActToPev.ContextResponse cr ->
                        "CONTEXT: facts=" + cr.facts();
            };
        }
    }

    // ── ReActAgent-side adapter (1.0 loop) ────────────────────────────

    /**
     * ReActAgent adapter: depends ONLY on {@link PevReActProtocol.ReActToPev}
     * and {@link PevReActProtocol.PevToReAct}. Zero knowledge of PEV/Pregel internals.
     *
     * <p>In production, this would be driven by ReActAgent's think→tool→think loop.
     * For the prototype, it simulates:
     * <ul>
     *   <li>completed: LLM returns answer directly (no tool needed)</li>
     *   <li>degraded: tool throws RuntimeException → RootCauseRail dispatches Degrade</li>
     *   <li>replan: LLM calls __replan__ virtual tool → ReplanRail escalates</li>
     *   <li>context: KnowledgeBridge query</li>
     * </ul>
     */
    static final class ReActAdapter {

        private final BlockingQueue<PevReActProtocol.Handoff> recvQueue;
        private final BlockingQueue<PevReActProtocol.Response> sendQueue;

        ReActAdapter(
                BlockingQueue<PevReActProtocol.Handoff> recvQueue,
                BlockingQueue<PevReActProtocol.Response> sendQueue) {
            this.recvQueue = recvQueue;
            this.sendQueue = sendQueue;
        }

        /** ReActAgent worker loop: pull handoff, dispatch, send response. */
        void processOne() throws InterruptedException {
            PevReActProtocol.Handoff handoff = recvQueue.poll(5, TimeUnit.SECONDS);
            if (handoff == null) return; // timeout — no work

            PevReActProtocol.ReActToPev message =
                    dispatch(handoff.request(), handoff.correlationId());
            sendQueue.put(PevReActProtocol.Response.to(handoff, message));
        }

        /**
         * Sealed dispatch on PevToReAct — compile-time exhaustive.
         * This is structurally analogous to AlphaStrategy.executeVerifyLoop's
         * switch on RootCause.
         */
        static PevReActProtocol.ReActToPev dispatch(
                PevReActProtocol.PevToReAct request, String taskId) {
            return switch (request) {
                case PevReActProtocol.PevToReAct.ExecuteSubTask e -> {
                    // Simulate ReActAgent think→tool→think loop result.
                    // In production: ReActAgent.invoke(inputs) runs the full loop.
                    if (e.inputs().containsKey("__simulate_tool_failure__")) {
                        yield new PevReActProtocol.ReActToPev.SubTaskDegraded(
                                e.taskId(),
                                "partial_output_here",
                                "DeviceFailure: tool " + e.inputs().get("__simulate_tool_failure__")
                                        + " threw RuntimeException");
                    }
                    if (e.inputs().containsKey("__simulate_replan__")) {
                        yield new PevReActProtocol.ReActToPev.SubTaskReplanRequested(
                                e.taskId(),
                                "PlanOrAnswerError: verify FAILED on node " + e.goal());
                    }
                    yield new PevReActProtocol.ReActToPev.SubTaskCompleted(
                            e.taskId(),
                            "reActResultFor:" + e.goal(),
                            "think→tool_call(claims-lookup)→think→answer");
                }
                case PevReActProtocol.PevToReAct.CancelSubTask c ->
                        new PevReActProtocol.ReActToPev.SubTaskDegraded(
                                c.taskId(), null, "Cancelled by PEV");
                case PevReActProtocol.PevToReAct.QueryContext q ->
                        new PevReActProtocol.ReActToPev.ContextResponse(
                                q.taskId(),
                                Map.of("answer", "context_for:" + q.question()));
            };
        }
    }

    // ── Tests ─────────────────────────────────────────────────────────

    @Nested
    @DisplayName("Bidirectional handoff")
    class BidirectionalHandoff {

        @Test
        @DisplayName("PEV → ExecuteSubTask → completed → PEV interprets ACCEPT")
        void completedRoundTrip() throws Exception {
            var pev = new PevAdapter(pevToReActQueue, reActToPevQueue);
            var react = new ReActAdapter(pevToReActQueue, reActToPevQueue);

            // Start ReActAdapter worker in a virtual thread (simulating async execution)
            Thread.startVirtualThread(() -> {
                try { react.processOne(); } catch (InterruptedException e) { Thread.currentThread().interrupt(); }
            });

            var request = new PevReActProtocol.PevToReAct.ExecuteSubTask(
                    "task-1", "lookup_claim_details",
                    "用户询问理赔进度", Map.of("claimId", "CLM-001"));
            PevReActProtocol.Response response = pev.handoffAndWait(request);

            assertThat(response.correlationId()).isNotNull();
            assertThat(response.message())
                    .isInstanceOf(PevReActProtocol.ReActToPev.SubTaskCompleted.class);

            var completed = (PevReActProtocol.ReActToPev.SubTaskCompleted) response.message();
            assertThat(completed.taskId()).isEqualTo("task-1");
            assertThat(completed.result()).asString().contains("reActResultFor:lookup_claim_details");
            assertThat(completed.reasoningTrace()).contains("think→tool_call");

            String pevDecision = PevAdapter.interpret(response);
            assertThat(pevDecision).startsWith("ACCEPT:");
        }

        @Test
        @DisplayName("PEV → ExecuteSubTask → tool failure → degraded → PEV interprets DEGRADE")
        void degradedRoundTrip() throws Exception {
            var pev = new PevAdapter(pevToReActQueue, reActToPevQueue);
            var react = new ReActAdapter(pevToReActQueue, reActToPevQueue);

            Thread.startVirtualThread(() -> {
                try { react.processOne(); } catch (InterruptedException e) { Thread.currentThread().interrupt(); }
            });

            var request = new PevReActProtocol.PevToReAct.ExecuteSubTask(
                    "task-2", "verify_claim_amount",
                    "用户上传发票", Map.of(
                    "invoiceId", "INV-002",
                    "__simulate_tool_failure__", "claims-verify-tool"));
            PevReActProtocol.Response response = pev.handoffAndWait(request);

            assertThat(response.message())
                    .isInstanceOf(PevReActProtocol.ReActToPev.SubTaskDegraded.class);

            var degraded = (PevReActProtocol.ReActToPev.SubTaskDegraded) response.message();
            assertThat(degraded.taskId()).isEqualTo("task-2");
            assertThat(degraded.cause()).contains("DeviceFailure");
            assertThat(degraded.cause()).contains("claims-verify-tool");

            String pevDecision = PevAdapter.interpret(response);
            assertThat(pevDecision).startsWith("DEGRADE(AcceptPartial):");
            assertThat(pevDecision).contains("DeviceFailure");
        }

        @Test
        @DisplayName("PEV → ExecuteSubTask → replan → PEV interprets REPLAN")
        void replanRoundTrip() throws Exception {
            var pev = new PevAdapter(pevToReActQueue, reActToPevQueue);
            var react = new ReActAdapter(pevToReActQueue, reActToPevQueue);

            Thread.startVirtualThread(() -> {
                try { react.processOne(); } catch (InterruptedException e) { Thread.currentThread().interrupt(); }
            });

            var request = new PevReActProtocol.PevToReAct.ExecuteSubTask(
                    "task-3", "calculate_deductible",
                    "多险种混合计算", Map.of("__simulate_replan__", true));
            PevReActProtocol.Response response = pev.handoffAndWait(request);

            assertThat(response.message())
                    .isInstanceOf(PevReActProtocol.ReActToPev.SubTaskReplanRequested.class);

            var replan = (PevReActProtocol.ReActToPev.SubTaskReplanRequested) response.message();
            assertThat(replan.taskId()).isEqualTo("task-3");
            assertThat(replan.reason()).contains("PlanOrAnswerError");

            String pevDecision = PevAdapter.interpret(response);
            assertThat(pevDecision).startsWith("REPLAN:");
        }

        @Test
        @DisplayName("PEV → QueryContext → ReActAgent returns facts")
        void contextQueryRoundTrip() throws Exception {
            var pev = new PevAdapter(pevToReActQueue, reActToPevQueue);
            var react = new ReActAdapter(pevToReActQueue, reActToPevQueue);

            Thread.startVirtualThread(() -> {
                try { react.processOne(); } catch (InterruptedException e) { Thread.currentThread().interrupt(); }
            });

            var request = new PevReActProtocol.PevToReAct.QueryContext(
                    "task-4", "what is the policy deductible for CLM-003?");
            PevReActProtocol.Response response = pev.handoffAndWait(request);

            assertThat(response.message())
                    .isInstanceOf(PevReActProtocol.ReActToPev.ContextResponse.class);

            var ctx = (PevReActProtocol.ReActToPev.ContextResponse) response.message();
            assertThat(ctx.taskId()).isEqualTo("task-4");
            assertThat(ctx.facts()).containsKey("answer");

            String pevDecision = PevAdapter.interpret(response);
            assertThat(pevDecision).startsWith("CONTEXT:");
        }

        @Test
        @DisplayName("CancelSubTask: PEV cancels → ReActAgent acknowledges with degraded")
        void cancelRoundTrip() throws Exception {
            var pev = new PevAdapter(pevToReActQueue, reActToPevQueue);
            var react = new ReActAdapter(pevToReActQueue, reActToPevQueue);

            Thread.startVirtualThread(() -> {
                try { react.processOne(); } catch (InterruptedException e) { Thread.currentThread().interrupt(); }
            });

            var request = new PevReActProtocol.PevToReAct.CancelSubTask("task-5");
            PevReActProtocol.Response response = pev.handoffAndWait(request);

            assertThat(response.message())
                    .isInstanceOf(PevReActProtocol.ReActToPev.SubTaskDegraded.class);

            var degraded = (PevReActProtocol.ReActToPev.SubTaskDegraded) response.message();
            assertThat(degraded.cause()).contains("Cancelled");
        }
    }

    @Nested
    @DisplayName("Sealed type guarantees")
    class SealedTypeGuarantees {

        @Test
        @DisplayName("Switch on PevToReAct is compile-time exhaustive (4 variants)")
        void pevToReActExhaustive() {
            // This test PROVES the switch compiles (compile-time check).
            // If a new variant is added to PevToReAct without updating this switch,
            // the build breaks. This is the mutation-prove guarantee.
            assertDoesNotThrow(() -> {
                for (PevReActProtocol.PevToReAct msg : allPevToReActVariants()) {
                    String dispatched = dispatchPevToReAct(msg, "test-task");
                    assertThat(dispatched).isNotNull();
                }
            });
        }

        @Test
        @DisplayName("Switch on ReActToPev is compile-time exhaustive (4 variants)")
        void reActToPevExhaustive() {
            assertDoesNotThrow(() -> {
                for (PevReActProtocol.ReActToPev msg : allReActToPevVariants()) {
                    String dispatched = dispatchReActToPev(msg);
                    assertThat(dispatched).isNotNull();
                }
            });
        }

        @Test
        @DisplayName("Missing variant in switch is COMPILE-TIME error (documentation)")
        void sealedGuaranteeDocumentation() {
            // The Java compiler rejects any switch on a sealed interface that
            // does not cover all permitted subtypes. This is structurally
            // stronger than runtime RED tests — the build itself is the proof.
            //
            // Proof: try commenting out one case below. Compilation fails with:
            //   "the switch statement does not cover all possible input values"
            //
            // This is how the protocol enforces independent evolution:
            // add a message type → all switch sites must be updated.
            for (PevReActProtocol.PevToReAct msg : allPevToReActVariants()) {
                String result = switch (msg) {
                    case PevReActProtocol.PevToReAct.ExecuteSubTask e -> "ExecuteSubTask:" + e.taskId();
                    case PevReActProtocol.PevToReAct.CancelSubTask c -> "CancelSubTask:" + c.taskId();
                    case PevReActProtocol.PevToReAct.QueryContext q -> "QueryContext:" + q.taskId();
                };
                assertThat(result).isNotNull();
            }
        }

        // -- helpers --

        private static PevReActProtocol.PevToReAct[] allPevToReActVariants() {
            return new PevReActProtocol.PevToReAct[]{
                    new PevReActProtocol.PevToReAct.ExecuteSubTask(
                            "t1", "goal", "ctx", Map.of()),
                    new PevReActProtocol.PevToReAct.CancelSubTask("t2"),
                    new PevReActProtocol.PevToReAct.QueryContext("t3", "q?")
            };
        }

        private static PevReActProtocol.ReActToPev[] allReActToPevVariants() {
            return new PevReActProtocol.ReActToPev[]{
                    new PevReActProtocol.ReActToPev.SubTaskCompleted("t1", "ok", "trace"),
                    new PevReActProtocol.ReActToPev.SubTaskDegraded("t2", "partial", "DeviceFailure"),
                    new PevReActProtocol.ReActToPev.SubTaskReplanRequested("t3", "PlanOrAnswerError"),
                    new PevReActProtocol.ReActToPev.ContextResponse("t4", Map.of("k", "v"))
            };
        }

        private static String dispatchPevToReAct(PevReActProtocol.PevToReAct msg, String taskId) {
            return ReActAdapter.dispatch(msg, taskId).toString();
        }

        private static String dispatchReActToPev(PevReActProtocol.ReActToPev msg) {
            return PevAdapter.interpret(new PevReActProtocol.Response("corr-1", msg));
        }
    }

    @Nested
    @DisplayName("Independent evolution proof")
    class IndependentEvolution {

        /**
         * PEV-side code that only depends on the protocol, not ReActAgent.
         * This class compiles without any import from openjiuwen.core.singleagent.
         */
        @Test
        @DisplayName("PEV-side adapter has zero dependency on ReActAgent implementation")
        void pevAdapterHasZeroReActDependency() {
            // PevAdapter compiles without importing ReActAgent, ReActAgentConfig,
            // AgentRail, or any class in com.openjiuwen.core.singleagent.*
            // The only shared code is PevReActProtocol (this package).
            //
            // Verifiable by: grep -c "import com.openjiuwen.core.singleagent"
            // in PevAdapter source → returns 0.
            var pev = new PevAdapter(pevToReActQueue, reActToPevQueue);
            assertThat(pev).isNotNull();
        }

        /**
         * ReActAgent-side code that only depends on the protocol, not PEV/Pregel.
         */
        @Test
        @DisplayName("ReActAdapter has zero dependency on PEV/BSP implementation")
        void reActAdapterHasZeroPevDependency() {
            // ReActAdapter compiles without importing PregelExecutor, AlphaStrategy,
            // TaskGraph, or any class in com.openjiuwen.core.alpha.graph.*
            var react = new ReActAdapter(pevToReActQueue, reActToPevQueue);
            assertThat(react).isNotNull();
        }

        /**
         * Adding a new message type forces all sites to update.
         *
         * <p>If a developer adds {@code PevToReAct.NewVariant}, then:
         * <ol>
         *   <li>{@code ReActAdapter.dispatch} switch breaks at compile time</li>
         *   <li>Any other switch on {@code PevToReAct} also breaks</li>
         *   <li>The build is red until every site handles the new variant</li>
         * </ol>
         *
         * This is mutation-prove at the <b>build</b> level, not at the test level.
         */
        @Test
        @DisplayName("Protocol evolution: adding a variant is compile-red until all sites updated")
        void protocolEvolutionCompileProve() {
            // The current 3 variants of PevToReAct and 4 variants of ReActToPev
            // are all handled. Adding a 4th to PevToReAct or a 5th to ReActToPev
            // would break this test at compile time — the build itself proves
            // exhaustive handling.
            assertThat(PevReActProtocol.PevToReAct.class.getPermittedSubclasses())
                    .hasSize(3);
            assertThat(PevReActProtocol.ReActToPev.class.getPermittedSubclasses())
                    .hasSize(4);
        }

        @Test
        @DisplayName("Wire format: Handoff and Response are pure data, no behavior")
        void wireFormatIsPureData() {
            var handoff = PevReActProtocol.Handoff.of(
                    new PevReActProtocol.PevToReAct.ExecuteSubTask(
                            "t", "g", "c", Map.of("k", "v")));
            assertThat(handoff.correlationId()).isNotEmpty();
            assertThat(handoff.request()).isNotNull();

            var response = PevReActProtocol.Response.to(handoff,
                    new PevReActProtocol.ReActToPev.SubTaskCompleted("t", "ok", "trace"));
            assertThat(response.correlationId()).isEqualTo(handoff.correlationId());
            assertThat(response.message()).isNotNull();
        }

        @Test
        @DisplayName("Multiple concurrent handoffs by correlation ID")
        void concurrentHandoffsByCorrelationId() throws Exception {
            var pev = new PevAdapter(pevToReActQueue, reActToPevQueue);
            var react = new ReActAdapter(pevToReActQueue, reActToPevQueue);

            // Start a worker that processes 3 handoffs
            Thread.startVirtualThread(() -> {
                try {
                    react.processOne();
                    react.processOne();
                    react.processOne();
                } catch (InterruptedException e) {
                    Thread.currentThread().interrupt();
                }
            });

            var h1 = pev.handoffAndWait(new PevReActProtocol.PevToReAct.QueryContext("t-a", "q1"));
            var h2 = pev.handoffAndWait(new PevReActProtocol.PevToReAct.QueryContext("t-b", "q2"));
            var h3 = pev.handoffAndWait(new PevReActProtocol.PevToReAct.QueryContext("t-c", "q3"));

            // Each response has its own correlation ID
            assertThat(h1.correlationId()).isNotEqualTo(h2.correlationId());
            assertThat(h2.correlationId()).isNotEqualTo(h3.correlationId());
            assertThat(h1.correlationId()).isNotEqualTo(h3.correlationId());

            // All are ContextResponse
            assertThat(h1.message()).isInstanceOf(PevReActProtocol.ReActToPev.ContextResponse.class);
            assertThat(h2.message()).isInstanceOf(PevReActProtocol.ReActToPev.ContextResponse.class);
            assertThat(h3.message()).isInstanceOf(PevReActProtocol.ReActToPev.ContextResponse.class);
        }
    }

    @Nested
    @DisplayName("Null-safety and validation")
    class NullSafety {

        @Test
        @DisplayName("ExecuteSubTask rejects null fields")
        void executeSubTaskRejectsNull() {
            assertThatThrownBy(() ->
                    new PevReActProtocol.PevToReAct.ExecuteSubTask(null, "goal", "ctx", Map.of()))
                    .isInstanceOf(NullPointerException.class);
        }

        @Test
        @DisplayName("SubTaskDegraded requires cause")
        void subTaskDegradedRequiresCause() {
            assertThatThrownBy(() ->
                    new PevReActProtocol.ReActToPev.SubTaskDegraded("t1", "out", null))
                    .isInstanceOf(NullPointerException.class);
        }

        @Test
        @DisplayName("Handoff correlationId is auto-generated UUID")
        void handoffAutoCorrelationId() {
            var h1 = PevReActProtocol.Handoff.of(
                    new PevReActProtocol.PevToReAct.CancelSubTask("t1"));
            var h2 = PevReActProtocol.Handoff.of(
                    new PevReActProtocol.PevToReAct.CancelSubTask("t2"));
            // UUIDs are unique
            assertThat(h1.correlationId()).isNotEqualTo(h2.correlationId());
        }
    }
}
