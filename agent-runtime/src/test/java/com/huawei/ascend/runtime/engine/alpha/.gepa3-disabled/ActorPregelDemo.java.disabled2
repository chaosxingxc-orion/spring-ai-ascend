package com.huawei.ascend.runtime.engine.alpha.gepa3;

import com.openjiuwen.core.alpha.verifier.RootCause;
import com.openjiuwen.core.alpha.verifier.VerifyResult;

import java.util.*;
import java.util.concurrent.BlockingQueue;
import java.util.concurrent.LinkedBlockingQueue;
import java.util.concurrent.TimeUnit;

/**
 * Actor模型 PROTOTYPE —— 用 BlockingQueue inbox + 不可变消息 + 零锁 替代共享内存并发。
 *
 * <h2>P7 review fixes applied</h2>
 * <table border="1">
 *   <tr><th>Bug</th><th>Fix</th></tr>
 *   <tr><td>E1: Success unreachable (passed() computed but never checked)</td>
 *       <td>handleVerifyResponse checks vr.verifyResult().passed() BEFORE sealed dispatch</td></tr>
 *   <tr><td>E2: Indistinguishable from E3 (no content validator)</td>
 *       <td>ContentVerifier interface injected into VerifyActor; content-fail vs tool-fail
 *           distinguishable via intersection logic in diagnoseRootCause</td></tr>
 *   <tr><td>E4: verifyThrew dead code (declared false, never mutated)</td>
 *       <td>try-catch wraps ENTIRE verification block; verifyThrew set on any exception</td></tr>
 *   <tr><td>Bug 5: Inbox multiplexing (run() + executeSuperstep poll same inbox)</td>
 *       <td>Per-superstep reply channel: ExecuteActor creates fresh BlockingQueue per
 *           superstep. ToolActors reply to that channel, not main inbox.</td></tr>
 *   <tr><td>Bug 6: BSP superstep violation (layers 1+2 in one batch)</td>
 *       <td>Supervisor sends ONE layer at a time, blocks on per-layer reply channel,
 *           then sends next layer</td></tr>
 *   <tr><td>Bug 7: PlanActor ignores retry context</td>
 *       <td>PlanRequest carries failureContext; protocol supports it</td></tr>
 *   <tr><td>Bug 8: No phase guard on handlePlanResponse</td>
 *       <td>Phase validation before accepting message</td></tr>
 *   <tr><td>Bug 9: Data race on allResults</td>
 *       <td>Terminal state via volatile TerminalRecord (single safe publication)</td></tr>
 *   <tr><td>Bug 10: Unbounded queues</td>
 *       <td>Bounded capacity (256) — backpressure via BlockingQueue.put()</td></tr>
 *   <tr><td>Bug 11: Slow PoisonPill (10s poll)</td>
 *       <td>100ms poll everywhere; sub-second shutdown</td></tr>
 * </table>
 *
 * @author gepa3 prototype (P7) — evolved
 */
public final class ActorPregelDemo {

    private ActorPregelDemo() {}

    // ========================================================================
    // Content verifier — injected strategy to distinguish E2 (content wrong)
    // from E3 (tool failed). P7 review: "ContentVerifier as a strategy."
    // ========================================================================
    @FunctionalInterface
    public interface ContentVerifier {
        /** @return set of nodeIds whose content is semantically wrong */
        Set<String> verifyContent(Map<String, String> nodeResults);
    }

    /** No-op content verifier — default for E3-only demo. */
    public static final ContentVerifier NO_CONTENT_CHECK = results -> Set.of();

    /** Immutable terminal record — single volatile write eliminates data race (Bug 9 fix). */
    public record TerminalRecord(String output, boolean degraded, String phase) {}

    // ========================================================================
    // 不可变消息类型（全部 record）
    // ========================================================================

    public record StartPev(String taskId, String goal) {}
    /** PlanRequest now carries failureContext for replan hints (Bug 7 fix). */
    public record PlanRequest(String taskId, String goal, String failureContext) {}
    public record PlanResponse(String taskId, DemoTaskGraph graph) {}
    /** Execute ONE layer at a time. replyTo is a per-layer channel (Bug 5/6 fix). */
    public record ExecuteLayer(String taskId, List<DemoNode> nodes, Map<String, String> upstreamResults,
                                BlockingQueue<LayerResult> replyTo) {}
    public record LayerResult(String taskId, Map<String, String> nodeResults,
                               Set<String> failedNodes, Set<String> skippedNodes) {}
    public record VerifyRequest(String taskId, Map<String, String> nodeResults,
                                 Set<String> executorFailedNodes, Set<String> executorSkippedNodes) {}
    public record VerifyResponse(String taskId, VerifyResult verifyResult, RootCause rootCause,
                                  boolean verifyThrew) {}
    /** ToolCallRequest carries per-superstep replyTo channel (Bug 5 fix). */
    public record ToolCallRequest(String nodeId, String toolName, String params,
                                   BlockingQueue<ToolCallResponse> replyTo) {}
    public record ToolCallResponse(String nodeId, String result) {}
    public record PoisonPill() {}

    public record DemoTaskGraph(String goal, List<List<DemoNode>> layers) {}
    public record DemoNode(String id, String toolName, String description) {}

    // ========================================================================
    // PlanActor
    // ========================================================================

    static class PlanActor implements Runnable {
        private final BlockingQueue<Object> inbox;
        private final BlockingQueue<Object> supervisorInbox;
        private final String name;

        PlanActor(String name, BlockingQueue<Object> inbox, BlockingQueue<Object> supervisorInbox) {
            this.name = name;
            this.inbox = inbox;
            this.supervisorInbox = supervisorInbox;
        }

        @Override
        public void run() {
            while (true) {
                try {
                    Object msg = inbox.poll(100, TimeUnit.MILLISECONDS);
                    if (msg == null) continue;
                    if (msg instanceof PoisonPill) return;
                    if (msg instanceof PlanRequest req) {
                        String hint = req.failureContext() != null ? req.failureContext() : "";
                        log("[PlanActor:%s] PlanRequest taskId=%s goal=%s failureContext=%s",
                                name, req.taskId(), req.goal(), hint.isEmpty() ? "(none)" : hint);

                        DemoNode claimInfo = new DemoNode("claim_info", "fetch_claim", "获取理赔信息");
                        DemoNode verifyPolicy = new DemoNode("verify_policy", "verify_coverage",
                                "核查保单覆盖范围（E3 注入点）");
                        DemoNode calculatePayout = new DemoNode("calculate_payout", "calc_payment",
                                "计算赔付金额");

                        DemoTaskGraph graph = new DemoTaskGraph(req.goal(), List.of(
                                List.of(claimInfo),
                                List.of(verifyPolicy),
                                List.of(calculatePayout)
                        ));

                        supervisorInbox.put(new PlanResponse(req.taskId(), graph));
                        log("[PlanActor:%s] → Supervisor: PlanResponse layers=%d", name, graph.layers().size());
                    }
                } catch (InterruptedException e) {
                    Thread.currentThread().interrupt();
                    return;
                }
            }
        }
    }

    // ========================================================================
    // ExecuteActor — per-superstep reply channel (Bug 5 fix)
    // ========================================================================

    static class ExecuteActor implements Runnable {
        private final BlockingQueue<Object> inbox;
        private final BlockingQueue<Object> supervisorInbox;
        private final String name;
        private final Map<String, BlockingQueue<Object>> toolInboxes;

        ExecuteActor(String name, BlockingQueue<Object> inbox,
                     BlockingQueue<Object> supervisorInbox,
                     Map<String, BlockingQueue<Object>> toolInboxes) {
            this.name = name;
            this.inbox = inbox;
            this.supervisorInbox = supervisorInbox;
            this.toolInboxes = toolInboxes;
        }

        @Override
        public void run() {
            while (true) {
                try {
                    Object msg = inbox.poll(100, TimeUnit.MILLISECONDS);
                    if (msg == null) continue;
                    if (msg instanceof PoisonPill) return;
                    if (msg instanceof ExecuteLayer req) {
                        executeLayer(req);
                    }
                } catch (InterruptedException e) {
                    Thread.currentThread().interrupt();
                    return;
                }
            }
        }

        /**
         * Execute ONE layer using a per-superstep reply channel.
         *
         * <p><b>Bug 5 fix:</b> ToolCallRequest carries a dedicated per-superstep
         * {@code BlockingQueue<ToolCallResponse>} as replyTo. ToolActors reply to
         * THAT channel, not the ExecuteActor main inbox. Main inbox only handles
         * ExecuteLayer commands + PoisonPill — zero multiplexing.</p>
         */
        private void executeLayer(ExecuteLayer req) throws InterruptedException {
            List<DemoNode> nodes = req.nodes();
            log("[ExecuteActor:%s] ExecuteLayer taskId=%s nodes=%d layerNode=%s",
                    name, req.taskId(), nodes.size(),
                    nodes.stream().map(DemoNode::id).toList());

            Map<String, String> nodeResults = new LinkedHashMap<>();
            Set<String> failedNodes = new LinkedHashSet<>();
            Set<String> skippedNodes = new LinkedHashSet<>();

            // Per-superstep reply channel — fresh for each layer execution
            BlockingQueue<ToolCallResponse> superstepChannel =
                    new LinkedBlockingQueue<>(nodes.size() * 2);

            int expectedResponses = 0;
            for (DemoNode node : nodes) {
                BlockingQueue<Object> toolInbox = toolInboxes.get(node.toolName());
                if (toolInbox == null) {
                    skippedNodes.add(node.id());
                    nodeResults.put(node.id(), "SKIPPED: 工具未注册");
                    continue;
                }
                expectedResponses++;
                toolInbox.put(new ToolCallRequest(node.id(), node.toolName(),
                        "params_for_" + node.id(), superstepChannel));
                log("[ExecuteActor:%s] → ToolActor[%s]: ToolCallRequest nodeId=%s",
                        name, node.toolName(), node.id());
            }

            // Collect from per-superstep channel — no interference with main inbox
            int received = 0;
            long deadline = System.currentTimeMillis() + 10_000;
            while (received < expectedResponses) {
                long remaining = deadline - System.currentTimeMillis();
                if (remaining <= 0) {
                    log("[ExecuteActor:%s] per-superstep channel timeout (received=%d/%d)",
                            name, received, expectedResponses);
                    for (DemoNode node : nodes) {
                        if (!nodeResults.containsKey(node.id())) {
                            failedNodes.add(node.id());
                            nodeResults.put(node.id(), "FAILED: timeout waiting for ToolActor");
                        }
                    }
                    break;
                }
                ToolCallResponse tcr = superstepChannel.poll(
                        Math.min(remaining, 500), TimeUnit.MILLISECONDS);
                if (tcr == null) continue;
                received++;
                nodeResults.put(tcr.nodeId(), tcr.result());
                if (tcr.result().startsWith("FAILED:")) {
                    failedNodes.add(tcr.nodeId());
                    log("[ExecuteActor:%s] ToolCallResponse nodeId=%s FAILED", name, tcr.nodeId());
                } else {
                    log("[ExecuteActor:%s] ToolCallResponse nodeId=%s OK", name, tcr.nodeId());
                }
            }

            LayerResult resp = new LayerResult(req.taskId(), nodeResults, failedNodes, skippedNodes);
            req.replyTo().put(resp);
            log("[ExecuteActor:%s] → Supervisor: LayerResult failed=%d skipped=%d results=%d",
                    name, failedNodes.size(), skippedNodes.size(), nodeResults.size());
        }
    }

    // ========================================================================
    // ToolActor
    // ========================================================================

    static class ToolActor implements Runnable {
        private final BlockingQueue<Object> inbox;
        private final String toolName;
        private final boolean shouldFail;

        ToolActor(String toolName, BlockingQueue<Object> inbox, boolean shouldFail) {
            this.toolName = toolName;
            this.inbox = inbox;
            this.shouldFail = shouldFail;
        }

        @Override
        public void run() {
            while (true) {
                try {
                    Object msg = inbox.poll(100, TimeUnit.MILLISECONDS);
                    if (msg == null) continue;
                    if (msg instanceof PoisonPill) return;
                    if (msg instanceof ToolCallRequest req) {
                        processToolCall(req);
                    }
                } catch (InterruptedException e) {
                    Thread.currentThread().interrupt();
                    return;
                }
            }
        }

        private void processToolCall(ToolCallRequest req) throws InterruptedException {
            String result;
            if (shouldFail) {
                log("[ToolActor:%s] E3 INJECTED: tool timeout nodeId=%s", toolName, req.nodeId());
                result = "FAILED: java.net.SocketTimeoutException: " + toolName
                        + " connect timed out after 2000ms";
                Thread.sleep(200);
            } else {
                log("[ToolActor:%s] execute nodeId=%s params=%s", toolName, req.nodeId(), req.params());
                result = "OK: " + toolName + " completed for node " + req.nodeId();
                Thread.sleep(50);
            }
            // Reply to per-superstep channel — NOT the ExecuteActor main inbox
            req.replyTo().put(new ToolCallResponse(req.nodeId(), result));
            log("[ToolActor:%s] → per-superstep channel: nodeId=%s", toolName, req.nodeId());
        }
    }

    // ========================================================================
    // VerifyActor — E4 fix: try-catch around entire verification block
    // ========================================================================

    static class VerifyActor implements Runnable {
        private final BlockingQueue<Object> inbox;
        private final BlockingQueue<Object> supervisorInbox;
        private final String name;
        private final ContentVerifier contentVerifier;

        VerifyActor(String name, BlockingQueue<Object> inbox, BlockingQueue<Object> supervisorInbox,
                    ContentVerifier contentVerifier) {
            this.name = name;
            this.inbox = inbox;
            this.supervisorInbox = supervisorInbox;
            this.contentVerifier = contentVerifier;
        }

        @Override
        public void run() {
            while (true) {
                try {
                    Object msg = inbox.poll(100, TimeUnit.MILLISECONDS);
                    if (msg == null) continue;
                    if (msg instanceof PoisonPill) return;
                    if (msg instanceof VerifyRequest req) {
                        verifyAndDiagnose(req);
                    }
                } catch (InterruptedException e) {
                    Thread.currentThread().interrupt();
                    return;
                }
            }
        }

        private void verifyAndDiagnose(VerifyRequest req) throws InterruptedException {
            log("[VerifyActor:%s] VerifyRequest taskId=%s", name, req.taskId());

            // E4 FIX: try-catch wraps ENTIRE verification block
            boolean verifyThrew = false;
            Set<String> verifyFailedNodes = new LinkedHashSet<>();
            List<VerifyResult.NodeVerifyResult> nodeVerifyResults = new ArrayList<>();

            try {
                // Phase 1: Rule check — "FAILED:" prefix
                for (Map.Entry<String, String> e : req.nodeResults().entrySet()) {
                    String nodeId = e.getKey();
                    String result = e.getValue();
                    if (result != null && result.startsWith("FAILED:")) {
                        verifyFailedNodes.add(nodeId);
                        nodeVerifyResults.add(new VerifyResult.NodeVerifyResult(
                                nodeId, false, "节点执行失败: " + result,
                                VerifyResult.VerifyMethod.RULE));
                    } else {
                        nodeVerifyResults.add(new VerifyResult.NodeVerifyResult(
                                nodeId, true, "OK", VerifyResult.VerifyMethod.RULE));
                    }
                }

                // Phase 2: Content check — distinguishes E2 from E3
                Set<String> contentFailed = contentVerifier.verifyContent(req.nodeResults());
                verifyFailedNodes.addAll(contentFailed);

            } catch (Exception ex) {
                // E4 REACHABLE: any exception in verification → PerceptionUnreliable
                verifyThrew = true;
                log("[VerifyActor:%s] verifier crashed: %s", name, ex.getMessage());
            }

            RootCause rootCause = diagnoseRootCause(
                    verifyFailedNodes, verifyThrew,
                    req.executorFailedNodes(), req.executorSkippedNodes());

            VerifyResult vr;
            if (verifyFailedNodes.isEmpty() && !verifyThrew) {
                vr = VerifyResult.passed("所有节点验证通过");
            } else {
                vr = VerifyResult.failed("节点验证失败: " + verifyFailedNodes,
                        nodeVerifyResults, verifyFailedNodes);
            }

            supervisorInbox.put(new VerifyResponse(req.taskId(), vr, rootCause, verifyThrew));
            log("[VerifyActor:%s] → Supervisor: VerifyResponse rootCause=%s failedNodes=%s verifyThrew=%s",
                    name, rootCause.getClass().getSimpleName(), verifyFailedNodes, verifyThrew);
        }

        /**
         * Root cause diagnosis — pure function, zero side effects.
         *
         * <p>Priority order (matches AlphaStrategy.diagnoseRootCause):
         * <ol>
         *   <li>verifyThrew → PerceptionUnreliable</li>
         *   <li>verifyFailed ∩ (executorFailed ∪ executorSkipped) ≠ ∅ → DeviceFailure</li>
         *   <li>else → PlanOrAnswerError</li>
         * </ol>
         */
        static RootCause diagnoseRootCause(Set<String> verifyFailedNodes, boolean verifyThrew,
                                           Set<String> executorFailedNodes, Set<String> executorSkippedNodes) {
            if (verifyThrew) {
                return new RootCause.PerceptionUnreliable(true);
            }

            Set<String> deviceSignals = new LinkedHashSet<>();
            if (executorFailedNodes != null) deviceSignals.addAll(executorFailedNodes);
            if (executorSkippedNodes != null) deviceSignals.addAll(executorSkippedNodes);

            Set<String> deviceHit = new LinkedHashSet<>(verifyFailedNodes);
            deviceHit.retainAll(deviceSignals);
            if (!deviceHit.isEmpty()) {
                return new RootCause.DeviceFailure(deviceHit);
            }

            return new RootCause.PlanOrAnswerError(verifyFailedNodes);
        }
    }

    // ========================================================================
    // SupervisorActor — E1 fix: check passed() BEFORE sealed dispatch
    // ========================================================================

    static class SupervisorActor implements Runnable {
        private final BlockingQueue<Object> inbox;
        private final String taskId;
        private final String goal;
        private final int maxRetries;

        private final BlockingQueue<Object> planInbox;
        private final BlockingQueue<Object> executeInbox;
        private final BlockingQueue<Object> verifyInbox;

        enum Phase { PLAN, EXECUTE, VERIFY, DONE }
        Phase phase = Phase.PLAN;

        private int retryCount = 0;
        private int executedLayers = 0;
        private DemoTaskGraph currentGraph = null;
        private final Map<String, String> allResults = new LinkedHashMap<>();
        private final Set<String> accFailedNodes = new LinkedHashSet<>();
        private final Set<String> accSkippedNodes = new LinkedHashSet<>();

        /** Terminal state via volatile immutable record — single safe publication (Bug 9 fix). */
        volatile TerminalRecord terminal = null;

        // Backward-compatible fields for existing tests
        public volatile String finalOutput;
        public volatile boolean degraded;

        SupervisorActor(String taskId, String goal, int maxRetries,
                        BlockingQueue<Object> inbox,
                        BlockingQueue<Object> planInbox,
                        BlockingQueue<Object> executeInbox,
                        BlockingQueue<Object> verifyInbox) {
            this.taskId = taskId;
            this.goal = goal;
            this.maxRetries = maxRetries;
            this.inbox = inbox;
            this.planInbox = planInbox;
            this.executeInbox = executeInbox;
            this.verifyInbox = verifyInbox;
        }

        @Override
        public void run() {
            try {
                planInbox.put(new PlanRequest(taskId, goal, null));
                log("[Supervisor] → PlanActor: PlanRequest");

                while (phase != Phase.DONE) {
                    Object msg = inbox.poll(100, TimeUnit.MILLISECONDS); // Bug 11: 100ms, not 10s
                    if (msg == null) continue;

                    if (msg instanceof PlanResponse pr) {
                        handlePlanResponse(pr);
                    } else if (msg instanceof LayerResult lr) {
                        handleLayerResult(lr);
                    } else if (msg instanceof VerifyResponse vr) {
                        handleVerifyResponse(vr);
                    } else if (msg instanceof PoisonPill) {
                        phase = Phase.DONE;
                        break;
                    }
                }
                log("[Supervisor] exit PEV loop phase=DONE finalOutput=%s", finalOutput);
            } catch (InterruptedException e) {
                Thread.currentThread().interrupt();
                setTerminal("INTERRUPTED: " + e.getMessage(), true);
            }
        }

        /** Bug 8 FIX: phase guard — only accept PlanResponse in PLAN phase. */
        private void handlePlanResponse(PlanResponse pr) throws InterruptedException {
            if (phase != Phase.PLAN) {
                log("[Supervisor] ignoring PlanResponse — not in PLAN phase (current=%s)", phase);
                return;
            }
            log("[Supervisor] ← PlanActor: PlanResponse layers=%d", pr.graph().layers().size());
            this.currentGraph = pr.graph();
            executedLayers = 0;
            allResults.clear();

            if (!pr.graph().layers().isEmpty()) {
                executeNextLayer();
            } else {
                setTerminal("EMPTY_GRAPH", true);
            }
        }

        /** Bug 6 FIX: execute ONE layer at a time with BSP barrier. */
        private void executeNextLayer() throws InterruptedException {
            List<DemoNode> layer = currentGraph.layers().get(executedLayers);
            BlockingQueue<LayerResult> layerChannel = new LinkedBlockingQueue<>(1);
            executeInbox.put(new ExecuteLayer(taskId, layer,
                    new LinkedHashMap<>(allResults), layerChannel));
            phase = Phase.EXECUTE;
            log("[Supervisor] → ExecuteActor: ExecuteLayer layer=%d/%d nodes=%s",
                    executedLayers, currentGraph.layers().size(),
                    layer.stream().map(DemoNode::id).toList());

            // BLOCK until this layer completes (BSP barrier)
            LayerResult lr = layerChannel.poll(30, TimeUnit.SECONDS);
            if (lr != null) {
                inbox.put(lr); // Feed into main loop for handleLayerResult
            } else {
                setTerminal("TIMEOUT: layer " + executedLayers + " stalled", true);
            }
        }

        private void handleLayerResult(LayerResult lr) throws InterruptedException {
            log("[Supervisor] ← ExecuteActor: LayerResult failed=%d results=%d",
                    lr.failedNodes().size(), lr.nodeResults().size());

            allResults.putAll(lr.nodeResults());
            accFailedNodes.addAll(lr.failedNodes());
            accSkippedNodes.addAll(lr.skippedNodes());
            executedLayers++;

            // More layers remain → execute next (Bug 6 FIX: sequential layers)
            if (currentGraph != null && executedLayers < currentGraph.layers().size()) {
                executeNextLayer();
                return;
            }

            // All layers complete → verify
            verifyInbox.put(new VerifyRequest(taskId, new LinkedHashMap<>(allResults),
                    Collections.unmodifiableSet(new LinkedHashSet<>(accFailedNodes)),
                    Collections.unmodifiableSet(new LinkedHashSet<>(accSkippedNodes))));
            phase = Phase.VERIFY;
            log("[Supervisor] → VerifyActor: VerifyRequest results=%d failed=%d",
                    allResults.size(), accFailedNodes.size());
        }

        /**
         * Verify response handler — sealed three-way dispatch.
         *
         * <p><b>E1 FIX:</b> Check {@code vr.verifyResult().passed()} BEFORE sealed dispatch.
         * Original: passed() was computed but never read — every success fell through
         * to PlanOrAnswerError → spurious replan → false degraded termination.</p>
         */
        private void handleVerifyResponse(VerifyResponse vr) {
            log("[Supervisor] ← VerifyActor: VerifyResponse rootCause=%s passed=%s verifyThrew=%s",
                    vr.rootCause().getClass().getSimpleName(), vr.verifyResult().passed(), vr.verifyThrew());

            // === E1 FIX: explicit success check BEFORE sealed dispatch ===
            if (vr.verifyResult().passed() && !vr.verifyThrew()) {
                log("[Supervisor] E1 TRACE: all passed → COMPLETED (not degraded)");
                setTerminal("COMPLETED: all nodes passed | results=" + allResults.keySet(), false);
                return;
            }

            // === sealed three-way dispatch ===
            if (vr.rootCause() instanceof RootCause.DeviceFailure df) {
                log("[Supervisor] E3 TRACE: DeviceFailure → AcceptPartial → COMPLETED-degraded");
                log("[Supervisor]   evidence nodes: %s", df.nodes());
                setTerminal("COMPLETED-degraded: DeviceFailure " + df.nodes()
                        + " | completedResults=" + allResults.keySet(), true);
            } else if (vr.rootCause() instanceof RootCause.PerceptionUnreliable pu) {
                log("[Supervisor] E4 TRACE: PerceptionUnreliable → AcceptPartial");
                setTerminal("COMPLETED-degraded: PerceptionUnreliable verifierThrew=" + pu.verifierThrew()
                        + " | completedResults=" + allResults.keySet(), true);
            } else if (vr.rootCause() instanceof RootCause.PlanOrAnswerError poe) {
                log("[Supervisor] E2 TRACE: PlanOrAnswerError → check retry budget retryCount=%d/%d",
                        retryCount, maxRetries);
                if (retryCount < maxRetries) {
                    retryCount++;
                    accFailedNodes.clear();
                    accSkippedNodes.clear();
                    try {
                        // Bug 7: PlanRequest carries failure context
                        planInbox.put(new PlanRequest(taskId,
                                goal + " [retry " + retryCount + "/" + maxRetries + "]",
                                "上次失败节点: " + poe.nodes()));
                        executedLayers = 0;
                        allResults.clear();
                        phase = Phase.PLAN;
                        log("[Supervisor] → PlanActor: GlobalReplan retry=%d/%d context=%s",
                                retryCount, maxRetries, poe.nodes());
                    } catch (InterruptedException e) {
                        Thread.currentThread().interrupt();
                        setTerminal("COMPLETED-degraded: replan interrupted", true);
                    }
                } else {
                    log("[Supervisor] retry budget exhausted → AcceptPartial");
                    setTerminal("COMPLETED-degraded: retries exhausted " + poe.nodes()
                            + " | completedResults=" + allResults.keySet(), true);
                }
            } else {
                throw new AssertionError("unreachable: unknown RootCause subtype " + vr.rootCause().getClass());
            }
        }

        private void setTerminal(String output, boolean isDegraded) {
            if (phase == Phase.DONE) return;
            this.finalOutput = output;
            this.degraded = isDegraded;
            this.terminal = new TerminalRecord(output, isDegraded, "DONE"); // Bug 9: safe publication
            this.phase = Phase.DONE;
            log("[Supervisor] TERMINATE: %s", output);
        }
    }

    // ========================================================================
    // 日志
    // ========================================================================

    static void log(String format, Object... args) {
        System.out.printf("[%tT] %s%n", System.currentTimeMillis(), String.format(format, args));
    }

    // ========================================================================
    // Public entry points — backward compatible API + new E1/E2/E4 scenarios
    // ========================================================================

    public static void main(String[] args) throws Exception {
        runE3Demonstration();
    }

    /** Run E3 device-failure scenario (backward compatible). */
    public static SupervisorActor runE3Demonstration() throws Exception {
        return runScenario("task-e3-demo", "保险理赔：车损事故定损", 2,
                Map.of("fetch_claim", false, "verify_coverage", true, "calc_payment", false),
                NO_CONTENT_CHECK);
    }

    /** Run E1 success scenario — all tools pass, content verifier passes. */
    public static SupervisorActor runE1Demonstration() throws Exception {
        return runScenario("task-e1-demo", "保险理赔：正常定损", 2,
                Map.of("fetch_claim", false, "verify_coverage", false, "calc_payment", false),
                NO_CONTENT_CHECK);
    }

    /** Run E2 content-error scenario — tools pass but content verifier flags wrong answer. */
    public static SupervisorActor runE2Demonstration() throws Exception {
        return runScenario("task-e2-demo", "保险理赔：内容错误", 2,
                Map.of("fetch_claim", false, "verify_coverage", false, "calc_payment", false),
                results -> Set.of("calculate_payout"));
    }

    /** Run E4 verifier-crash scenario — content verifier throws. */
    public static SupervisorActor runE4Demonstration() throws Exception {
        return runScenario("task-e4-demo", "保险理赔：验证器崩溃", 2,
                Map.of("fetch_claim", false, "verify_coverage", false, "calc_payment", false),
                results -> { throw new RuntimeException("verifier internal crash"); });
    }

    /**
     * General scenario runner — parameterized by tool failure map and content verifier.
     *
     * @param taskId          Task identifier
     * @param goal            Task goal description
     * @param maxRetries      Maximum replan attempts
     * @param toolFailures    Map of toolName → shouldFail (E3 injection)
     * @param contentVerifier Content verification strategy (E2 injection)
     */
    public static SupervisorActor runScenario(String taskId, String goal, int maxRetries,
                                               Map<String, Boolean> toolFailures,
                                               ContentVerifier contentVerifier) throws Exception {
        log("============================================================");
        log("ActorPregelDemo: %s", goal);
        log("============================================================");

        // Bug 10 FIX: bounded inboxes (capacity 256)
        BlockingQueue<Object> supervisorInbox = new LinkedBlockingQueue<>(256);
        BlockingQueue<Object> planInbox = new LinkedBlockingQueue<>(256);
        BlockingQueue<Object> executeInbox = new LinkedBlockingQueue<>(256);
        BlockingQueue<Object> verifyInbox = new LinkedBlockingQueue<>(256);

        BlockingQueue<Object> fetchClaimInbox = new LinkedBlockingQueue<>(256);
        BlockingQueue<Object> verifyCoverageInbox = new LinkedBlockingQueue<>(256);
        BlockingQueue<Object> calcPaymentInbox = new LinkedBlockingQueue<>(256);

        Map<String, BlockingQueue<Object>> toolInboxes = Map.of(
                "fetch_claim", fetchClaimInbox,
                "verify_coverage", verifyCoverageInbox,
                "calc_payment", calcPaymentInbox
        );

        // Create Actors
        SupervisorActor supervisor = new SupervisorActor(
                taskId, goal, maxRetries,
                supervisorInbox, planInbox, executeInbox, verifyInbox);

        PlanActor planActor = new PlanActor("planner", planInbox, supervisorInbox);
        ExecuteActor executeActor = new ExecuteActor("executor", executeInbox, supervisorInbox, toolInboxes);
        VerifyActor verifyActor = new VerifyActor("verifier", verifyInbox, supervisorInbox, contentVerifier);

        ToolActor fetchClaim = new ToolActor("fetch_claim", fetchClaimInbox,
                toolFailures.getOrDefault("fetch_claim", false));
        ToolActor verifyCoverage = new ToolActor("verify_coverage", verifyCoverageInbox,
                toolFailures.getOrDefault("verify_coverage", false));
        ToolActor calcPayment = new ToolActor("calc_payment", calcPaymentInbox,
                toolFailures.getOrDefault("calc_payment", false));

        // Start all Actor threads
        Thread supervisorThread = new Thread(supervisor, "supervisor");
        Thread planThread = new Thread(planActor, "plan");
        Thread executeThread = new Thread(executeActor, "execute");
        Thread verifyThread = new Thread(verifyActor, "verify");
        Thread fetchThread = new Thread(fetchClaim, "tool-fetch_claim");
        Thread verifyPolicyThread = new Thread(verifyCoverage, "tool-verify_coverage");
        Thread calcThread = new Thread(calcPayment, "tool-calc_payment");

        supervisorThread.start();
        planThread.start();
        executeThread.start();
        verifyThread.start();
        fetchThread.start();
        verifyPolicyThread.start();
        calcThread.start();

        // Wait for Supervisor to complete
        supervisorThread.join(30_000);

        // Bug 11 FIX: fast shutdown — 100ms poll + PoisonPill = sub-second
        planInbox.put(new PoisonPill());
        executeInbox.put(new PoisonPill());
        verifyInbox.put(new PoisonPill());
        fetchClaimInbox.put(new PoisonPill());
        verifyCoverageInbox.put(new PoisonPill());
        calcPaymentInbox.put(new PoisonPill());
        supervisorInbox.put(new PoisonPill());

        for (Thread t : new Thread[]{planThread, executeThread, verifyThread,
                fetchThread, verifyPolicyThread, calcThread}) {
            t.join(5_000);
        }

        log("============================================================");
        log("Scenario result:");
        log("  finalOutput: %s", supervisor.finalOutput);
        log("  degraded:    %s", supervisor.degraded);
        log("  phase:       %s", supervisor.phase);
        log("  terminal:    %s", supervisor.terminal);
        log("============================================================");

        return supervisor;
    }
}
