package com.huawei.ascend.runtime.engine.alpha.gepa3;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;

import java.util.List;
import java.util.Set;
import java.util.stream.Collectors;

import static org.junit.jupiter.api.Assertions.*;

/**
 * Tests for {@link EventMeshDemo} — the P4 Event Grid prototype.
 *
 * <p>Test strategy:
 * <ul>
 *   <li>E3 trace: full event sequence from tool exception to COMPLETED-degraded</li>
 *   <li>CostTracker: zero-change composability (same trace + tracker = more events)</li>
 *   <li>Event taxonomy: each trace produces the correct event types in order</li>
 *   <li>Sealed hierarchy: SelfHealAction dispatch covers all 3 arms</li>
 * </ul>
 */
@DisplayName("P4 Event Grid Prototype")
class EventMeshDemoTest {

    // ========================================================================
    // E3 Trace Tests
    // ========================================================================

    @Nested
    @DisplayName("E3 trace (device fault → degraded)")
    class E3Trace {

        @Test
        @DisplayName("completes with TaskCompleted(verified=false, degraded=true)")
        void e3ProducesDegradedCompletion() {
            List<EventMeshDemo.MeshEvent> events = EventMeshDemo.runE3Trace();

            // The last event must be TaskCompleted
            EventMeshDemo.MeshEvent last = events.getLast();
            assertInstanceOf(EventMeshDemo.MeshEvent.TaskCompleted.class, last);

            EventMeshDemo.MeshEvent.TaskCompleted tc =
                    (EventMeshDemo.MeshEvent.TaskCompleted) last;
            assertFalse(tc.verified(), "verified should be false for degraded");
            assertTrue(tc.degraded(), "degraded should be true for device fault");
            assertTrue(tc.output().contains("degraded"),
                    "output should indicate degraded status");
        }

        @Test
        @DisplayName("contains NodeFailed for node_calculate")
        void e3ContainsToolFailure() {
            List<EventMeshDemo.MeshEvent> events = EventMeshDemo.runE3Trace();

            List<EventMeshDemo.MeshEvent.NodeFailed> failures = events.stream()
                    .filter(e -> e instanceof EventMeshDemo.MeshEvent.NodeFailed)
                    .map(e -> (EventMeshDemo.MeshEvent.NodeFailed) e)
                    .toList();

            assertEquals(1, failures.size(), "E3 should have exactly one NodeFailed");
            assertEquals("node_calculate", failures.getFirst().nodeId());
            assertTrue(failures.getFirst().error().contains("RuntimeException"),
                    "error message should indicate RuntimeException");
        }

        @Test
        @DisplayName("contains VerifyFailed with node_calculate in failedNodes")
        void e3VerifyDetectsFailure() {
            List<EventMeshDemo.MeshEvent> events = EventMeshDemo.runE3Trace();

            List<EventMeshDemo.MeshEvent.VerifyFailed> verifyFails = events.stream()
                    .filter(e -> e instanceof EventMeshDemo.MeshEvent.VerifyFailed)
                    .map(e -> (EventMeshDemo.MeshEvent.VerifyFailed) e)
                    .toList();

            assertFalse(verifyFails.isEmpty(), "E3 should have at least one VerifyFailed");
            EventMeshDemo.MeshEvent.VerifyFailed vf = verifyFails.getFirst();
            assertTrue(vf.failedNodes().contains("node_calculate"),
                    "failedNodes should include node_calculate");
        }

        @Test
        @DisplayName("diagnoses DeviceFailure (intersection of executor + verifier failures)")
        void e3DiagnosesDeviceFailure() {
            List<EventMeshDemo.MeshEvent> events = EventMeshDemo.runE3Trace();

            List<EventMeshDemo.MeshEvent.RootCauseFound> diagnoses = events.stream()
                    .filter(e -> e instanceof EventMeshDemo.MeshEvent.RootCauseFound)
                    .map(e -> (EventMeshDemo.MeshEvent.RootCauseFound) e)
                    .toList();

            assertEquals(1, diagnoses.size());
            EventMeshDemo.MeshEvent.RootCauseFound rcf = diagnoses.getFirst();
            assertInstanceOf(EventMeshDemo.SelfHealAction.Degrade.class, rcf.action(),
                    "E3 (tool exception) should dispatch Degrade, not replan");
            assertTrue(rcf.failedNodes().contains("node_calculate"));
        }

        @Test
        @DisplayName("dispatches AcceptPartial (not replan)")
        void e3DispatchesAcceptPartial() {
            List<EventMeshDemo.MeshEvent> events = EventMeshDemo.runE3Trace();

            List<EventMeshDemo.MeshEvent.ReplanDispatched> dispatches = events.stream()
                    .filter(e -> e instanceof EventMeshDemo.MeshEvent.ReplanDispatched)
                    .map(e -> (EventMeshDemo.MeshEvent.ReplanDispatched) e)
                    .toList();

            assertEquals(1, dispatches.size());
            assertEquals("AcceptPartial", dispatches.getFirst().actionName());
        }

        @Test
        @DisplayName("E3 full event sequence matches expected taxonomy")
        void e3EventSequence() {
            List<EventMeshDemo.MeshEvent> events = EventMeshDemo.runE3Trace();

            // Extract event type names in order
            List<String> typeNames = events.stream()
                    .map(e -> e.getClass().getSimpleName())
                    .toList();

            // Assert key transitions exist in order
            assertTrue(indexOf(typeNames, "GoalReceived") >= 0, "missing GoalReceived");
            assertTrue(indexOf(typeNames, "PlanGenerated") >= 0, "missing PlanGenerated");
            assertTrue(indexOf(typeNames, "NodeStarted") >= 0, "missing NodeStarted");
            assertTrue(indexOf(typeNames, "NodeFailed") >= 0, "missing NodeFailed");
            assertTrue(indexOf(typeNames, "NodeCompleted") >= 0, "missing NodeCompleted");
            assertTrue(indexOf(typeNames, "LayerCompleted") >= 0, "missing LayerCompleted");
            assertTrue(indexOf(typeNames, "VerifyFailed") >= 0, "missing VerifyFailed");
            assertTrue(indexOf(typeNames, "RootCauseFound") >= 0, "missing RootCauseFound");
            assertTrue(indexOf(typeNames, "ReplanDispatched") >= 0, "missing ReplanDispatched");
            assertTrue(indexOf(typeNames, "TaskCompleted") >= 0, "missing TaskCompleted");

            // VerifyFailed must come after LayerCompleted
            assertTrue(
                    indexOf(typeNames, "VerifyFailed") > indexOf(typeNames, "LayerCompleted"),
                    "VerifyFailed must follow LayerCompleted");

            // RootCauseFound must come after VerifyFailed
            assertTrue(
                    indexOf(typeNames, "RootCauseFound") > indexOf(typeNames, "VerifyFailed"),
                    "RootCauseFound must follow VerifyFailed");

            // TaskCompleted is the terminal event
            assertEquals("TaskCompleted", typeNames.getLast());
        }

        @Test
        @DisplayName("successful nodes (research, write) complete normally")
        void e3SuccessfulNodesSurvive() {
            List<EventMeshDemo.MeshEvent> events = EventMeshDemo.runE3Trace();

            Set<String> completedNodes = events.stream()
                    .filter(e -> e instanceof EventMeshDemo.MeshEvent.NodeCompleted)
                    .map(e -> ((EventMeshDemo.MeshEvent.NodeCompleted) e).nodeId())
                    .collect(Collectors.toSet());

            assertTrue(completedNodes.contains("node_research"),
                    "node_research should complete (LLM_CALL, no fault)");
            assertTrue(completedNodes.contains("node_write"),
                    "node_write should complete (LLM_CALL, no fault)");
            assertFalse(completedNodes.contains("node_calculate"),
                    "node_calculate should NOT complete (TOOL_CALL fault)");
        }
    }

    // ========================================================================
    // CostTracker Tests — ZERO-CHANGE COMPOSABILITY
    // ========================================================================

    @Nested
    @DisplayName("CostTrackerProcessor (zero-change composability)")
    class CostTracker {

        @Test
        @DisplayName("adding CostTracker produces CostTracked events alongside existing events")
        void costTrackerProducesOwnEvents() {
            List<EventMeshDemo.MeshEvent> events =
                    EventMeshDemo.runE3TraceWithCostTracker();

            List<EventMeshDemo.MeshEvent.CostTracked> costEvents = events.stream()
                    .filter(e -> e instanceof EventMeshDemo.MeshEvent.CostTracked)
                    .map(e -> (EventMeshDemo.MeshEvent.CostTracked) e)
                    .toList();

            assertFalse(costEvents.isEmpty(),
                    "CostTracker should emit CostTracked events");

            // Should have cost tracking for each successful node
            long nodeCompletedCosts = costEvents.stream()
                    .filter(ct -> "node_completed".equals(ct.source()))
                    .count();
            assertTrue(nodeCompletedCosts >= 2,
                    "At least 2 successful nodes should have cost tracking");
        }

        @Test
        @DisplayName("E3 degraded completion still produced with CostTracker")
        void costTrackerDoesNotInterfereWithE3() {
            List<EventMeshDemo.MeshEvent> events =
                    EventMeshDemo.runE3TraceWithCostTracker();

            // Same final state as E3 without CostTracker
            EventMeshDemo.MeshEvent last = events.getLast();
            assertInstanceOf(EventMeshDemo.MeshEvent.TaskCompleted.class, last);

            EventMeshDemo.MeshEvent.TaskCompleted tc =
                    (EventMeshDemo.MeshEvent.TaskCompleted) last;
            assertFalse(tc.verified());
            assertTrue(tc.degraded());
        }

        @Test
        @DisplayName("CostTracker requires ZERO changes to Planner/Executor/Verifier/RootCause/Replan")
        void costTrackerRequiresNoChanges() {
            // This test is proven by construction: runE3TraceWithCostTracker() uses
            // the same 5 processor classes as runE3Trace(). The only difference is
            // one additional `new CostTrackerProcessor(bus)` + `.start()` call.
            // No existing class was modified.

            // Verify: the 5 processors have exactly the same code path regardless
            // of CostTracker presence
            List<EventMeshDemo.MeshEvent> without = EventMeshDemo.runE3Trace();
            List<EventMeshDemo.MeshEvent> with = EventMeshDemo.runE3TraceWithCostTracker();

            // Filter out CostTracked events from the "with" trace
            List<EventMeshDemo.MeshEvent> withFiltered = with.stream()
                    .filter(e -> !(e instanceof EventMeshDemo.MeshEvent.CostTracked))
                    .toList();

            // Same number of non-CostTracked events
            assertEquals(without.size(), withFiltered.size(),
                    "Same number of non-cost events with/without CostTracker");

            // Same types in same order
            for (int i = 0; i < without.size(); i++) {
                assertEquals(without.get(i).getClass(), withFiltered.get(i).getClass(),
                        "Event type mismatch at index " + i);
            }
        }
    }

    // ========================================================================
    // Sealed Hierarchy Tests
    // ========================================================================

    @Nested
    @DisplayName("Sealed hierarchy (compile-time exhaustive)")
    class SealedHierarchy {

        @Test
        @DisplayName("SelfHealAction sealed hierarchy covers all 3 arms")
        void selfHealActionExhaustive() {
            // Degrade
            EventMeshDemo.SelfHealAction degrade =
                    new EventMeshDemo.SelfHealAction.Degrade("test");
            assertEquals("test", ((EventMeshDemo.SelfHealAction.Degrade) degrade).reason());

            // LocalReplan
            EventMeshDemo.SelfHealAction local =
                    EventMeshDemo.SelfHealAction.LocalReplan.of();
            assertEquals(2, ((EventMeshDemo.SelfHealAction.LocalReplan) local).maxRounds());

            // GlobalReplan
            EventMeshDemo.SelfHealAction global =
                    new EventMeshDemo.SelfHealAction.GlobalReplan();
            assertInstanceOf(EventMeshDemo.SelfHealAction.GlobalReplan.class, global);

            // Verify sealed: only 3 permitted subtypes
            Class<?>[] permitted = EventMeshDemo.SelfHealAction.class.getPermittedSubclasses();
            assertEquals(3, permitted.length);
        }

        @Test
        @DisplayName("MeshEvent sealed hierarchy has 14 subtypes")
        void meshEvent14Subtypes() {
            Class<?>[] permitted = EventMeshDemo.MeshEvent.class.getPermittedSubclasses();
            assertEquals(14, permitted.length,
                    "14 event types in sealed hierarchy");
        }
    }

    // ========================================================================
    // EventBus Tests
    // ========================================================================

    @Nested
    @DisplayName("EventBus")
    class EventBusTests {

        @Test
        @DisplayName("publish and subscribe round-trip")
        void publishAndSubscribe() {
            EventMeshDemo.EventBus bus = new EventMeshDemo.EventBus();
            List<EventMeshDemo.MeshEvent> collected = new java.util.ArrayList<>();
            bus.events().subscribe(collected::add);

            bus.publish(new EventMeshDemo.MeshEvent.GoalReceived(
                    "t1", System.currentTimeMillis(), "test goal"));
            bus.publish(new EventMeshDemo.MeshEvent.VerifyRequested(
                    "t1", System.currentTimeMillis()));

            assertEquals(2, collected.size());
            assertInstanceOf(EventMeshDemo.MeshEvent.GoalReceived.class, collected.get(0));
            assertInstanceOf(EventMeshDemo.MeshEvent.VerifyRequested.class, collected.get(1));
        }
    }

    // ========================================================================
    // No-Regression: NodeType Enum
    // ========================================================================

    @Test
    @DisplayName("NodeType enum has expected values")
    void nodeTypeEnum() {
        assertEquals(3, EventMeshDemo.MeshEvent.NodeType.values().length);
        assertEquals(EventMeshDemo.MeshEvent.NodeType.TOOL_CALL,
                EventMeshDemo.MeshEvent.NodeType.valueOf("TOOL_CALL"));
        assertEquals(EventMeshDemo.MeshEvent.NodeType.LLM_CALL,
                EventMeshDemo.MeshEvent.NodeType.valueOf("LLM_CALL"));
        assertEquals(EventMeshDemo.MeshEvent.NodeType.SUB_AGENT,
                EventMeshDemo.MeshEvent.NodeType.valueOf("SUB_AGENT"));
    }

    // ========================================================================
    // helpers
    // ========================================================================

    private static int indexOf(List<String> list, String element) {
        for (int i = 0; i < list.size(); i++) {
            if (list.get(i).equals(element)) return i;
        }
        return -1;
    }
}
