# Copy to .env.local (gitignored) and fill in your own values.
# Loaded by scripts/run-local.sh. Real keys/endpoints live ONLY in your local
# .env.local and are never committed.

# --- LLM (required to actually run an agent) ---
# The app ships a model catalog (see application.yaml); users pick a model per session.
# Fill in keys only for the providers you want available — the rest stay hidden/unusable.
#
# Default model: "deepseek-chat" (points at the real DeepSeek endpoint out of the box).
# Just drop in your DeepSeek key and you're running:
WORKMATE_LLM_API_KEY=sk-your-deepseek-key
# WORKMATE_LLM_API_BASE=https://api.deepseek.com/v1   # any OpenAI-compatible endpoint
# WORKMATE_LLM_MODEL=deepseek-chat
# WORKMATE_LLM_DEFAULT_MODEL=deepseek-chat
#
# Hosted alternative — "gpt-4o-mini" catalog entry:
# WORKMATE_OPENAI_API_KEY=sk-your-openai-key
# WORKMATE_OPENAI_API_BASE=https://api.openai.com/v1
#
# Local model — "local-model" catalog entry (Ollama/vLLM/LM Studio):
# WORKMATE_LOCAL_API_BASE=http://localhost:11434/v1
# WORKMATE_LOCAL_MODEL=your-local-model
# WORKMATE_LOCAL_API_KEY=sk-local-placeholder

# --- Developer Studio (authoring UI; on by default for local dev) ---
WORKMATE_STUDIO_ENABLED=true

# --- Cloud sessions (local stub; on by default for local demo) ---
# WORKMATE_CLOUD_ENABLED=true

# --- OAuth mock redirect page (/oauth/mock-authorize; dogfood only) ---
# WORKMATE_OAUTH_MOCK_ENABLED=true

# --- Production hardening (disables Studio + cloud + OAuth mock) ---
# SPRING_PROFILES_ACTIVE=production

# --- MCP (must be set BEFORE starting API — read at JVM boot) ---
# WORKMATE_MCP_ENABLED=true
# WORKMATE_MCP_DOCS_FS_ENABLED=true
# WORKMATE_MCP_FS_ROOT=/path/to/docs

# --- qieman MCP (Streamable HTTP); only the API key is secret and lives here, never committed ---
# WORKMATE_MCP_QIEMAN_ENABLED=true
# WORKMATE_MCP_QIEMAN_API_KEY=your-qieman-api-key
# WORKMATE_MCP_QIEMAN_URL=https://stargate.yingmi.com/mcp/v2

# --- Mock OA MCP (stdio, local dogfood only) ---
# WORKMATE_MCP_OA_ENABLED=true
# WORKMATE_MCP_OA_SCRIPT=../scripts/dogfood/mock-oa-mcp/server.mjs

# --- Inbound automation webhook (off by default; secret required when enabled) ---
# WORKMATE_WEBHOOK_GENERIC_ENABLED=true
# WORKMATE_WEBHOOK_GENERIC_SECRET=set-a-strong-random-secret
