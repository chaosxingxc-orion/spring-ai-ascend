# env.yaml.example — 客户侧部署配置模板（按 AKDI §1.7.2 规范）
apiVersion: akdi.dev/v1
kind: DeployEnv
spec:
  target: compose
  externalDeps:
    llm-api:
      apiKey: ""
      apiBase: "http://localhost:4000/v1"
      model: "gpt-5.4-mini"
  # 平台自带中间件（AKDI 部署并纳管，默认值由平台提供，客户可按需覆盖）
  managedDeps:
    redis:
      password: "akdi123"
    mem0:
      endpoint: "http://mem0:8080"
